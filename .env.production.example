###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=0
# Generate with: php bin/console secret:generate-keys  OR  openssl rand -hex 32
APP_SECRET=CHANGE_ME_32_hex_chars
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Neon PostgreSQL — copy from your Neon project dashboard
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?serverVersion=16&charset=utf8&sslmode=require"
###< doctrine/doctrine-bundle ###

###> qr-base-url ###
# Set to your public domain so QR codes in PDFs resolve correctly
APP_BASE_URL=https://yourdomain.com
###< qr-base-url ###

###> knpuniversity/oauth2-client-bundle ###
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id_here
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
###< knpuniversity/oauth2-client-bundle ###

###> twilio/sms ###
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid_here
###< twilio/sms ###

###> ai/suggestion ###
AI_SUGGESTION_ENABLED=true
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile
###< ai/suggestion ###

###> stripe/refunds ###
STRIPE_SECRET_KEY=sk_live_your_stripe_live_key_here
###< stripe/refunds ###

###> flouci/payment ###
FLOUCI_APP_PUBLIC=your_flouci_public_key_here
FLOUCI_APP_SECRET=your_flouci_secret_key_here
###< flouci/payment ###

###> openweathermap ###
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
###< openweathermap ###

CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"

RESEND_API_KEY="your_resend_api_key_here"
NVIDIA_API_KEY="your_nvidia_api_key_here"
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_BOOKING_HOST=booking-com15.p.rapidapi.com

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default
###< symfony/messenger ###

# Optional: only set if running behind a reverse proxy (leave unset on Namecheap)
# TRUSTED_PROXIES=127.0.0.1
