<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found · Travagir</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap">
  <link rel="stylesheet" href="/styles/app.css">
  <link rel="stylesheet" href="/styles/enhancements.css">
  <style>
    .err-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px 24px;
      background: radial-gradient(ellipse at 50% 0%, rgba(79,110,247,0.12) 0%, transparent 60%),
                  var(--amazon-light, #111827);
    }
    .err-code {
      font-size: clamp(6rem, 20vw, 10rem);
      font-weight: 800;
      line-height: 1;
      background: linear-gradient(135deg, #4f6ef7, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin: 0;
      animation: tg-page-in .4s ease both;
    }
    .err-icon {
      font-size: 4rem;
      margin: 16px 0 0;
      animation: tg-empty-float 3s ease-in-out infinite;
    }
    .err-title {
      font-size: 1.6rem;
      font-weight: 800;
      color: #f1f5f9;
      margin: 12px 0 8px;
    }
    .err-msg {
      color: #64748b;
      font-size: 1rem;
      max-width: 400px;
      line-height: 1.6;
      margin: 0 auto 28px;
    }
    .err-actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
    .err-divider {
      width: 60px; height: 3px;
      background: linear-gradient(to right, #4f6ef7, #a78bfa);
      border-radius: 999px;
      margin: 16px auto;
    }
    @keyframes tg-empty-float {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-10px); }
    }
  </style>
</head>
<body>
  <div class="err-page">
    <p class="err-code">404</p>
    <div class="err-icon">🗺️</div>
    <div class="err-divider"></div>
    <h1 class="err-title">Lost in transit</h1>
    <p class="err-msg">The page you're looking for has flown the coop. It may have moved, been deleted, or never existed.</p>
    <div class="err-actions">
      <a href="/" class="btn btn-primary">← Back to Home</a>
      <a href="/voyages" class="btn btn-secondary">Browse Voyages</a>
    </div>
  </div>
</body>
</html>
