{% extends 'base.html.twig' %}
{% block title %}Create Reclamation{% endblock %}

{% block body %}
<div class="rf-page">

    <!-- Header -->
    <div class="rf-header">
        <div>
            <h1>Create Reclamation</h1>
            <p class="rf-subtitle">Describe your issue and we'll get back to you as soon as possible.</p>
        </div>
        <a href="{{ path('user_reclamations') }}" class="rf-back-btn">← My Reclamations</a>
    </div>

    <!-- Flash messages -->
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="rf-alert rf-alert-{{ type == 'error' ? 'danger' : type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <!-- Validation errors -->
    {% if errors %}
        <div class="rf-alert rf-alert-danger">
            {% for field, msgs in errors %}
                <div>{{ field|capitalize }}: {{ msgs|join(', ') }}</div>
            {% endfor %}
        </div>
    {% endif %}

    <!-- Form Card -->
    <div class="rf-card">

        {% if data.reservation_id is defined and data.reservation_id is not empty %}
        <div class="rf-reservation-banner">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Filing complaint for Reservation <strong>#{{ data.reservation_id }}</strong>
        </div>
        {% endif %}

        <form method="post" action="{{ path('user_reclamation_new') }}" class="rf-form" data-autosave="reclamation-new">
            <span class="tg-autosave" style="margin-bottom:8px;display:flex;">✅ Draft saved</span>

            {% if data.reservation_id is defined and data.reservation_id is not empty %}
                <input type="hidden" name="reservation_id" value="{{ data.reservation_id }}">
            {% elseif reservations is defined and reservations|length > 0 %}
                <div class="rf-field">
                    <label for="reservation_id" class="rf-label">Reservation <span class="rf-required">*</span></label>
                    <select name="reservation_id" id="reservation_id" class="rf-input" required>
                        <option value="">— Select a reservation —</option>
                        {% for res in reservations %}
                        <option value="{{ res.id }}" {% if data.reservation_id|default('') == res.id ~ '' %}selected{% endif %}>
                            #{{ res.id }} · {{ res.voyage_title|default('Voyage #' ~ res.voyage_id) }}
                            ({{ res.status }}) — {{ res.total_price }} TND
                        </option>
                        {% endfor %}
                    </select>
                </div>
            {% else %}
                <div class="rf-field">
                    <label for="reservation_id" class="rf-label">Reservation ID <span class="rf-required">*</span></label>
                    <input type="number" name="reservation_id" id="reservation_id" class="rf-input"
                           value="{{ data.reservation_id|default('') }}" placeholder="Enter your reservation number" required>
                </div>
            {% endif %}

            <div class="rf-field">
                <label for="title" class="rf-label">Title <span class="rf-required">*</span></label>
                <input type="text" name="title" id="title" class="rf-input"
                       value="{{ data.title|default('') }}" placeholder="Brief summary of your complaint" required>
            </div>

            <div class="rf-field">
                <label for="description" class="rf-label">Description <span class="rf-required">*</span></label>
                <textarea name="description" id="description" class="rf-input rf-textarea" rows="6"
                          placeholder="Please describe the issue in detail…" required>{{ data.description|default('') }}</textarea>
            </div>

            <div class="rf-field">
                <label class="rf-label">Priority / Urgency</label>
                <div class="rf-priority-grid">
                    {% set priorities = [
                        {value: 'LOW',    label: 'Low',    sub: 'Not urgent',             color: '#94a3b8', bg: 'rgba(100,116,139,0.1)', border: 'rgba(100,116,139,0.25)'},
                        {value: 'MEDIUM', label: 'Medium', sub: 'Standard (default)',      color: '#93c5fd', bg: 'rgba(68,121,207,0.1)',  border: 'rgba(68,121,207,0.25)'},
                        {value: 'HIGH',   label: 'High',   sub: 'Needs prompt attention',  color: '#fdba74', bg: 'rgba(234,88,12,0.1)',   border: 'rgba(234,88,12,0.25)'},
                        {value: 'URGENT', label: 'Urgent', sub: 'Critical issue',          color: '#fca5a5', bg: 'rgba(220,38,38,0.1)',   border: 'rgba(220,38,38,0.3)'}
                    ] %}
                    {% for p in priorities %}
                    <label class="rf-priority-opt">
                        <input type="radio" name="priority" value="{{ p.value }}"
                               {% if data.priority|default('MEDIUM') == p.value %}checked{% endif %}>
                        <span class="rf-priority-card" style="--pc:{{ p.color }};--pbg:{{ p.bg }};--pborder:{{ p.border }};">
                            <span class="rf-priority-dot"></span>
                            <span class="rf-priority-info">
                                <strong>{{ p.label }}</strong>
                                <small>{{ p.sub }}</small>
                            </span>
                        </span>
                    </label>
                    {% endfor %}
                </div>
            </div>

            <div class="rf-actions">
                <button type="submit" class="rf-submit-btn">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Submit Reclamation
                </button>
                <a href="{{ path('user_reclamations') }}" class="rf-cancel-btn">Cancel</a>
            </div>
        </form>
    </div>

</div>

<style>
/* ── Page ──────────────────────────────────────────────────── */
.rf-page {
    padding: 36px 24px;
    max-width: 680px;
    margin: 0 auto;
}

/* ── Header ────────────────────────────────────────────────── */
.rf-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border-dark);
    flex-wrap: wrap;
    gap: 12px;
}
.rf-header h1 {
    margin: 0 0 6px;
    font-size: 1.9rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #ffffff 0%, #febd69 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.rf-subtitle { margin: 0; color: var(--text-muted); font-size: 0.88em; }
.rf-back-btn {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.88em;
    font-weight: 600;
    padding: 8px 16px;
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    background: var(--amazon-white);
    transition: color .2s, border-color .2s;
    white-space: nowrap;
}
.rf-back-btn:hover { color: var(--amazon-orange); border-color: rgba(255,153,0,0.3); }

/* ── Alerts ────────────────────────────────────────────────── */
.rf-alert {
    padding: 12px 16px;
    border-radius: 10px;
    margin-bottom: 18px;
    font-size: 0.88em;
    line-height: 1.5;
}
.rf-alert-success { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); color: #86efac; }
.rf-alert-danger  { background: rgba(239,68,68,0.12);  border: 1px solid rgba(239,68,68,0.3);  color: #fca5a5; }
.rf-alert-warning { background: rgba(255,193,7,0.12);  border: 1px solid rgba(255,193,7,0.3);  color: #fde047; }

/* ── Reservation Banner ────────────────────────────────────── */
.rf-reservation-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: rgba(255,153,0,0.08);
    border-bottom: 1px solid rgba(255,153,0,0.15);
    font-size: 0.88em;
    color: var(--text-muted);
}
.rf-reservation-banner strong { color: var(--amazon-orange); }

/* ── Card ──────────────────────────────────────────────────── */
.rf-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}
.rf-form { padding: 28px; }

/* ── Fields ────────────────────────────────────────────────── */
.rf-field { margin-bottom: 22px; }
.rf-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    font-size: 0.9em;
    color: var(--text-primary);
}
.rf-required { color: #ef4444; margin-left: 2px; }

.rf-input {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--border-dark);
    border-radius: 10px;
    background: rgba(15,23,34,0.6);
    color: var(--text-primary);
    font-size: 0.93em;
    transition: border-color .2s, box-shadow .2s;
    box-sizing: border-box;
    outline: none;
    font-family: inherit;
}
.rf-input::placeholder { color: var(--text-muted); }
.rf-input:focus {
    border-color: rgba(255,153,0,0.5);
    box-shadow: 0 0 0 3px rgba(255,153,0,0.1);
}
.rf-textarea {
    resize: vertical;
    min-height: 130px;
    line-height: 1.6;
}

/* ── Priority Grid ─────────────────────────────────────────── */
.rf-priority-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
}
.rf-priority-opt { cursor: pointer; }
.rf-priority-opt input[type="radio"] { display: none; }

.rf-priority-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 14px;
    border-radius: 10px;
    border: 1px solid var(--border-dark);
    background: rgba(15,23,34,0.4);
    transition: all .18s ease;
    cursor: pointer;
    user-select: none;
}
.rf-priority-card:hover {
    border-color: var(--pborder);
    background: var(--pbg);
}
.rf-priority-opt input:checked + .rf-priority-card {
    border-color: var(--pc);
    background: var(--pbg);
    box-shadow: 0 0 0 1px var(--pc);
}

.rf-priority-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--pc);
    flex-shrink: 0;
    transition: box-shadow .18s;
}
.rf-priority-opt input:checked + .rf-priority-card .rf-priority-dot {
    box-shadow: 0 0 6px var(--pc);
}

.rf-priority-info {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
}
.rf-priority-info strong {
    font-size: 0.88em;
    color: var(--text-primary);
    font-weight: 700;
}
.rf-priority-info small {
    font-size: 0.75em;
    color: var(--text-muted);
    margin-top: 2px;
}

/* ── Actions ───────────────────────────────────────────────── */
.rf-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 8px;
    border-top: 1px solid var(--border-dark);
    margin-top: 8px;
}
.rf-submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 24px;
    background: var(--amazon-orange);
    color: #000;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.93em;
    cursor: pointer;
    transition: background .18s, box-shadow .18s, transform .15s;
}
.rf-submit-btn:hover {
    background: #e68a00;
    box-shadow: 0 4px 16px rgba(255,153,0,0.35);
    transform: translateY(-1px);
}
.rf-submit-btn:active { transform: scale(.98); }
.rf-cancel-btn {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.9em;
    font-weight: 600;
    transition: color .2s;
}
.rf-cancel-btn:hover { color: var(--text-primary); }

/* ── Responsive ────────────────────────────────────────────── */
@media (max-width: 600px) {
    .rf-page { padding: 20px 14px; }
    .rf-header { flex-direction: column; }
    .rf-priority-grid { grid-template-columns: 1fr; }
    .rf-form { padding: 20px; }
}
</style>
{% endblock %}
