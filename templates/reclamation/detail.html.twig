{% extends 'base.html.twig' %}
{% block title %}Reclamation #{{ reclamation.id }}{% endblock %}

{% block stylesheets %}
<style>
/* ── Page ──────────────────────────────────────────────────── */
.rd-page {
    padding: 32px 24px;
    max-width: 820px;
    margin: 0 auto;
}

/* ── Header ────────────────────────────────────────────────── */
.rd-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border-dark);
    flex-wrap: wrap;
    gap: 12px;
}
.rd-header-left h1 {
    margin: 0 0 8px;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #ffffff 0%, #febd69 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.rd-badges { display: flex; gap: 7px; flex-wrap: wrap; align-items: center; }
.rd-meta-id { font-size: 0.78em; color: var(--text-muted); align-self: center; }

/* ── Badge Pills ───────────────────────────────────────────── */
.badge-pill {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.73em;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid;
}
.badge-s-open        { background:rgba(255,153,0,0.15);  color:#febd69;  border-color:rgba(255,153,0,0.3); }
.badge-s-in-progress { background:rgba(68,121,207,0.15); color:#93c5fd;  border-color:rgba(68,121,207,0.3); }
.badge-s-resolved    { background:rgba(22,163,74,0.15);  color:#86efac;  border-color:rgba(22,163,74,0.3); }
.badge-s-closed      { background:rgba(100,116,139,0.15);color:#94a3b8;  border-color:rgba(100,116,139,0.3); }
.badge-p-urgent { background:rgba(220,38,38,0.15);  color:#fca5a5; border-color:rgba(220,38,38,0.3); }
.badge-p-high   { background:rgba(234,88,12,0.15);  color:#fdba74; border-color:rgba(234,88,12,0.3); }
.badge-p-medium { background:rgba(68,121,207,0.15); color:#93c5fd; border-color:rgba(68,121,207,0.3); }
.badge-p-low    { background:rgba(100,116,139,0.15);color:#94a3b8; border-color:rgba(100,116,139,0.3); }
.badge-r-approved { background:rgba(22,163,74,0.15);  color:#86efac; border-color:rgba(22,163,74,0.3); }
.badge-r-rejected { background:rgba(220,38,38,0.15);  color:#fca5a5; border-color:rgba(220,38,38,0.3); }
.badge-r-pending  { background:rgba(255,193,7,0.15);  color:#fde047; border-color:rgba(255,193,7,0.3); }

/* ── Info Card ─────────────────────────────────────────────── */
.rd-info-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 20px;
}
.rd-info-card-title {
    padding: 12px 20px;
    background: var(--amazon-navy);
    font-size: 0.73em;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-dark);
}
.rd-row {
    display: flex;
    border-bottom: 1px solid var(--border-dark);
}
.rd-row:last-child { border-bottom: none; }
.rd-label {
    width: 150px;
    min-width: 150px;
    padding: 12px 20px;
    background: rgba(0,0,0,0.15);
    font-size: 0.82em;
    font-weight: 600;
    color: var(--text-muted);
    display: flex;
    align-items: flex-start;
}
.rd-value {
    padding: 12px 20px;
    font-size: 0.88em;
    color: var(--text-primary);
    flex: 1;
    word-break: break-word;
    white-space: pre-wrap;
}
.rd-value-resolved { color: #86efac; }

/* ── Response Cards ────────────────────────────────────────── */
.rd-response-card {
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 24px;
    border: 1px solid;
}
.rd-response-card.responded {
    background: rgba(22,163,74,0.06);
    border-color: rgba(22,163,74,0.25);
}
.rd-response-card.awaiting {
    background: rgba(255,153,0,0.06);
    border-color: rgba(255,153,0,0.2);
}
.rd-response-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 20px;
    border-bottom: 1px solid;
    font-size: 0.82em;
    font-weight: 700;
    letter-spacing: 0.04em;
}
.rd-response-card.responded .rd-response-header { border-color:rgba(22,163,74,0.2); color:#86efac; }
.rd-response-card.awaiting  .rd-response-header { border-color:rgba(255,153,0,0.15); color:#febd69; }
.rd-response-body {
    padding: 16px 20px;
    font-size: 0.88em;
    line-height: 1.65;
    white-space: pre-wrap;
}
.rd-response-card.responded .rd-response-body { color: #d1fae5; }
.rd-response-card.awaiting  .rd-response-body { color: var(--text-muted); font-style: italic; }
.rd-response-footer { padding: 8px 20px 12px; font-size: 0.75em; color: var(--text-muted); }

/* ── Section Title ─────────────────────────────────────────── */
.rd-section-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 28px 0 14px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.rd-section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-dark);
}

/* ── Refund Table ──────────────────────────────────────────── */
.rd-refund-table-wrap {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 14px;
    overflow: hidden;
}
.rd-refund-table { width: 100%; border-collapse: collapse; }
.rd-refund-table th {
    background: var(--amazon-navy);
    color: var(--text-primary);
    font-size: 0.73em;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 11px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border-dark);
}
.rd-refund-table td {
    padding: 12px 16px;
    font-size: 0.86em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-dark);
    vertical-align: middle;
}
.rd-refund-table tr:last-child td { border-bottom: none; }
.rd-refund-table tr:hover td { background: rgba(255,153,0,0.04); }
.td-primary       { color: var(--text-primary) !important; font-weight: 600; }
.td-amount        { color: var(--text-muted); }
.td-amount-value  { color: #febd69 !important; font-weight: 700; }
.td-partial-note  { font-size: 0.75em; color: var(--text-muted); display: block; }

/* ── Refund eligibility boxes ──────────────────────────────── */
.rd-eligible-box {
    background: rgba(22,163,74,0.08);
    border: 1px solid rgba(22,163,74,0.25);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
}
.rd-eligible-text { display: flex; align-items: center; gap: 12px; }
.rd-eligible-text strong { color: #86efac; font-size: 0.95em; display: block; margin-bottom: 2px; }
.rd-eligible-text p { margin: 0; font-size: 0.8em; color: var(--text-muted); }
.rd-ineligible-box {
    background: rgba(100,116,139,0.08);
    border: 1px solid rgba(100,116,139,0.2);
    border-radius: 14px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    font-size: 0.87em;
}

/* ── Responsive ────────────────────────────────────────────── */
@media (max-width: 768px) {
    .rd-page { padding: 20px 14px; }
    .rd-header { flex-direction: column; }
    .rd-label { width: 110px; min-width: 110px; }
}
</style>
{% endblock %}

{% block body %}
<div class="rd-page">

{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ type == 'error' ? 'danger' : type }}" style="margin-bottom:12px;">{{ message }}</div>
    {% endfor %}
{% endfor %}

{% if reclamation %}

<!-- Header -->
<div class="rd-header">
    <div class="rd-header-left">
        <h1>{{ reclamation.title }}</h1>
        <div class="rd-badges">
            <span class="badge-pill badge-s-{{ reclamation.status|lower|replace({'_': '-'}) }}">{{ reclamation.status }}</span>
            <span class="badge-pill badge-p-{{ reclamation.priority|lower }}">{{ reclamation.priority }}</span>
            <span class="rd-meta-id">#{{ reclamation.id }} · Reservation #{{ reclamation.reservationId }}</span>
        </div>
    </div>
    <a href="{{ path('user_reclamations') }}" class="btn btn-secondary" style="font-size:0.85em;">← Back</a>
</div>

<!-- Complaint Details -->
<div class="rd-info-card">
    <div class="rd-info-card-title">Complaint Details</div>
    <div class="rd-row">
        <div class="rd-label">Description</div>
        <div class="rd-value">{{ reclamation.description }}</div>
    </div>
    <div class="rd-row">
        <div class="rd-label">Filed At</div>
        <div class="rd-value">{{ reclamation.createdAt ? reclamation.createdAt|date('M d, Y · H:i') : '—' }}</div>
    </div>
    {% if reclamation.updatedAt %}
    <div class="rd-row">
        <div class="rd-label">Last Updated</div>
        <div class="rd-value">{{ reclamation.updatedAt|date('M d, Y · H:i') }}</div>
    </div>
    {% endif %}
    {% if reclamation.resolutionDate %}
    <div class="rd-row">
        <div class="rd-label">Resolved At</div>
        <div class="rd-value rd-value-resolved">{{ reclamation.resolutionDate|date('M d, Y · H:i') }}</div>
    </div>
    {% endif %}
</div>

<!-- Admin Response -->
{% if reclamation.adminResponse %}
    <div class="rd-response-card responded">
        <div class="rd-response-header">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Admin Response
        </div>
        <div class="rd-response-body">{{ reclamation.adminResponse }}</div>
        {% if reclamation.responseDate %}
            <div class="rd-response-footer">Received on {{ reclamation.responseDate|date('M d, Y · H:i') }}</div>
        {% endif %}
    </div>
{% else %}
    <div class="rd-response-card awaiting">
        <div class="rd-response-header">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Awaiting Admin Response
        </div>
        <div class="rd-response-body">Our team is reviewing your complaint. You will be notified once a response is available.</div>
    </div>
{% endif %}

<!-- Refund Section -->
<div class="rd-section-title">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
    Refund
</div>

{% if refundRequests|length > 0 %}
    <div class="rd-refund-table-wrap">
        <table class="rd-refund-table">
            <thead>
                <tr>
                    <th>Request #</th>
                    <th>Requested</th>
                    <th>Approved</th>
                    <th>Status</th>
                    <th>Submitted</th>
                </tr>
            </thead>
            <tbody>
                {% for rr in refundRequests %}
                <tr>
                    <td class="td-primary">#{{ rr.id }}</td>
                    <td class="td-amount">{{ rr.amount }} TND</td>
                    <td>
                        {% if rr.approvedAmount is not null %}
                            <span class="td-amount-value">{{ rr.approvedAmount }} TND</span>
                            {% if rr.approvedAmount != rr.amount %}
                                <span class="td-partial-note">partial</span>
                            {% endif %}
                        {% elseif rr.status == 'APPROVED' %}
                            <span class="td-amount-value">{{ rr.amount }} TND</span>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td><span class="badge-pill badge-r-{{ rr.status|lower }}">{{ rr.status }}</span></td>
                    <td>{{ rr.createdAt ? rr.createdAt|date('M d, Y · H:i') : '—' }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% elseif eligibility is defined and eligibility.eligible %}
    <div class="rd-eligible-box">
        <div class="rd-eligible-text">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#86efac" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
                <strong>You are eligible for a refund</strong>
                <p>A refund request will be submitted for your full reservation amount.</p>
            </div>
        </div>
        <form method="post" action="{{ path('user_reclamation_request_refund', {'id': reclamation.id}) }}">
            <button type="submit" class="btn btn-primary" style="white-space:nowrap;">Request Refund</button>
        </form>
    </div>
{% else %}
    <div class="rd-ineligible-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {% if eligibility is defined and eligibility.reason is defined %}
            {{ eligibility.reason }}
        {% else %}
            Refund is not available for this reclamation.
        {% endif %}
    </div>
{% endif %}

{% else %}
    <p style="color:var(--text-muted);">Reclamation not found.</p>
{% endif %}

</div>
{% endblock %}
