{% extends 'base.html.twig' %}
{% block title %}Forgot Password | Travagir{% endblock %}
{% block meta_description %}Reset your Travagir account password.{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <span class="logo-icon">🔑</span>
                    <span class="logo-text">Travagir</span>
                </div>
                <h1>Forgot password?</h1>
                <p class="lead">Enter your email and we'll send you a reset link.</p>
            </div>

            {% if sent %}
                <div class="alert alert-success" style="text-align:center;padding:24px;">
                    <div style="font-size:2.5rem;margin-bottom:10px;">📬</div>
                    <strong>Check your inbox</strong><br>
                    <span style="font-size:.93rem;font-weight:400;">If that email is registered, a reset link is on its way. Check your spam folder too.</span>
                </div>
                <div style="text-align:center;margin-top:20px;">
                    <a href="{{ path('auth_login') }}" class="btn btn-primary">Back to Login</a>
                </div>
            {% else %}
                {% if error %}
                    <div class="alert alert-error"><span class="alert-icon">⚠</span> {{ error }}</div>
                {% endif %}

                <form class="auth-form" method="post" action="{{ path('auth_forgot_password') }}">
                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <div class="input-wrapper">
                            <span class="input-icon">✉</span>
                            <input type="email" id="email" name="email" placeholder="your@email.com"
                                   required autocomplete="email" class="auth-input">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary auth-submit" id="fp-submit">
                        Send Reset Link
                    </button>
                </form>

                <div class="auth-footer">
                    <p>Remember your password? <a href="{{ path('auth_login') }}">Sign in</a></p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
document.getElementById('fp-submit') && document.getElementById('fp-submit').closest('form').addEventListener('submit', function () {
    var btn = document.getElementById('fp-submit');
    btn.disabled = true;
    btn.textContent = 'Sending…';
});
</script>
{% endblock %}
