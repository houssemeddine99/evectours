{% extends 'base.html.twig' %}
{% block title %}Account Settings | Evec Tours{% endblock %}

{% block body %}
{% set authUser = app.session.get('auth_user') %}
<div class="sp-page">

    {# ── Header ── #}
    <div class="sp-header">
        <div>
            <h1>Account Settings</h1>
            <p class="sp-sub">Manage your profile, security, and preferences.</p>
        </div>
    </div>

    {# ── Alerts ── #}
    {% if error %}
        <div class="sp-alert sp-alert--error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            {{ error }}
        </div>
    {% endif %}
    {% if success %}
        <div class="sp-alert sp-alert--success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            {{ success }}
        </div>
    {% endif %}

    <div class="sp-layout">

        {# ── LEFT: Avatar card ── #}
        <div class="sp-sidebar">
            <div class="sp-avatar-card">
                <div class="sp-avatar-wrap" id="avatarWrap">
                    {% if formData.image_url %}
                        <img id="avatarImg" class="sp-avatar-img" src="{{ formData.image_url }}" alt="Avatar"
                             onerror="this.style.display='none';document.getElementById('avatarInitial').style.display='flex';">
                        <div id="avatarInitial" class="sp-avatar-initial" style="display:none;">
                            {{ formData.username|slice(0,1)|upper }}
                        </div>
                    {% else %}
                        <img id="avatarImg" class="sp-avatar-img" src="" alt="" style="display:none;">
                        <div id="avatarInitial" class="sp-avatar-initial">
                            {{ formData.username|slice(0,1)|upper }}
                        </div>
                    {% endif %}
                </div>
                <div class="sp-avatar-name">{{ formData.username }}</div>
                <div class="sp-avatar-email">{{ formData.email }}</div>
                <span class="sp-role-badge">{{ authUser and authUser.is_admin|default(false) ? 'Admin' : 'Member' }}</span>
            </div>

            <div class="sp-quick-links">
                <a href="{{ path('account_bookings') }}" class="sp-quick-link">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    My Bookings
                </a>
                <a href="{{ path('user_reclamations') }}" class="sp-quick-link">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                    My Reclamations
                </a>
                <a href="{{ path('account_favorites') }}" class="sp-quick-link">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l7.78-7.78a5.5 5.5 0 000-7.78z"/></svg>
                    Favorites
                </a>
            </div>
        </div>

        {# ── RIGHT: Forms ── #}
        <div class="sp-main">

            {# Profile section #}
            <form method="post" action="{{ path('account_settings_update') }}" class="sp-card" id="profileForm">
                <div class="sp-card-head">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Profile Information
                </div>
                <div class="sp-card-body">
                    <div class="sp-row">
                        <div class="sp-field">
                            <label for="username">Username <span class="sp-req">*</span></label>
                            <input type="text" id="username" name="username" class="sp-input"
                                   value="{{ formData.username }}" required minlength="3" maxlength="50"
                                   oninput="document.querySelector('.sp-avatar-name').textContent=this.value||'—';document.querySelectorAll('.sp-avatar-initial').forEach(e=>e.textContent=(this.value||'?')[0].toUpperCase())">
                        </div>
                        <div class="sp-field">
                            <label for="email">Email <span class="sp-req">*</span></label>
                            <input type="email" id="email" name="email" class="sp-input"
                                   value="{{ formData.email }}" required
                                   oninput="document.querySelector('.sp-avatar-email').textContent=this.value||'—'">
                        </div>
                    </div>
                    <div class="sp-row">
                        <div class="sp-field">
                            <label for="tel">Phone Number</label>
                            <input type="tel" id="tel" name="tel" class="sp-input"
                                   value="{{ formData.tel }}" placeholder="+216 XX XXX XXX">
                        </div>
                        <div class="sp-field">
                            <label for="image_url">Avatar URL</label>
                            <input type="url" id="image_url" name="image_url" class="sp-input"
                                   value="{{ formData.image_url }}" placeholder="https://…/photo.jpg"
                                   oninput="updateAvatar(this.value)">
                        </div>
                    </div>
                </div>
                <div class="sp-card-foot">
                    <button type="submit" class="sp-btn sp-btn--primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        Save Profile
                    </button>
                </div>
            </form>

            {# Password section #}
            <form method="post" action="{{ path('account_settings_update') }}" class="sp-card" id="passwordForm">
                <div class="sp-card-head">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    Change Password
                </div>
                <div class="sp-card-body">
                    <p class="sp-hint-text">Leave these fields blank to keep your current password.</p>
                    {# Pass through profile fields as hidden so the POST handler has them #}
                    <input type="hidden" name="username"  value="{{ formData.username }}">
                    <input type="hidden" name="email"     value="{{ formData.email }}">
                    <input type="hidden" name="tel"       value="{{ formData.tel }}">
                    <input type="hidden" name="image_url" value="{{ formData.image_url }}">

                    <div class="sp-field" style="margin-bottom:16px;">
                        <label for="current_password">Current Password</label>
                        <input type="password" id="current_password" name="current_password" class="sp-input"
                               placeholder="Your current password" autocomplete="current-password">
                    </div>
                    <div class="sp-row">
                        <div class="sp-field">
                            <label for="new_password">New Password</label>
                            <input type="password" id="new_password" name="new_password" class="sp-input"
                                   placeholder="Min. 6 characters" minlength="6" autocomplete="new-password">
                        </div>
                        <div class="sp-field">
                            <label for="confirm_password">Confirm New Password</label>
                            <input type="password" id="confirm_password" name="confirm_password" class="sp-input"
                                   placeholder="Repeat new password" autocomplete="new-password">
                        </div>
                    </div>
                    <div class="sp-pw-strength" id="pwStrength" style="display:none;">
                        <div class="sp-pw-bar"><div class="sp-pw-fill" id="pwFill"></div></div>
                        <span id="pwLabel"></span>
                    </div>
                </div>
                <div class="sp-card-foot">
                    <button type="submit" class="sp-btn sp-btn--primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        Update Password
                    </button>
                </div>
            </form>

            {# Danger zone #}
            <div class="sp-card sp-card--danger">
                <div class="sp-card-head sp-card-head--danger">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    Danger Zone
                </div>
                <div class="sp-card-body">
                    <div class="sp-danger-row">
                        <div>
                            <strong>Delete Account</strong>
                            <p>Permanently delete your account and all associated data. This cannot be undone.</p>
                        </div>
                        <button type="button" class="sp-btn sp-btn--danger" onclick="document.getElementById('deleteModal').style.display='flex'">
                            Delete Account
                        </button>
                    </div>
                </div>
            </div>

        </div>{# /sp-main #}
    </div>{# /sp-layout #}
</div>

{# ── Delete confirmation modal ── #}
<div id="deleteModal" class="sp-modal-overlay" style="display:none;">
    <div class="sp-modal">
        <div class="sp-modal-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
        </div>
        <h3>Delete your account?</h3>
        <p>This will permanently erase your profile, bookings, and all data. There is no way back.</p>
        <div class="sp-modal-actions">
            <button class="sp-btn sp-btn--ghost" onclick="document.getElementById('deleteModal').style.display='none'">Cancel</button>
            <form method="post" action="{{ path('account_delete') }}" style="display:inline;">
                <button type="submit" class="sp-btn sp-btn--danger">Yes, delete my account</button>
            </form>
        </div>
    </div>
</div>

<script>
function updateAvatar(url) {
    var img = document.getElementById('avatarImg');
    var ini = document.getElementById('avatarInitial');
    if (url) {
        img.src = url;
        img.style.display = 'block';
        ini.style.display = 'none';
        img.onerror = function() {
            img.style.display = 'none';
            ini.style.display = 'flex';
        };
    } else {
        img.style.display = 'none';
        ini.style.display = 'flex';
    }
}

// Password strength indicator
var pwInput = document.getElementById('new_password');
if (pwInput) {
    pwInput.addEventListener('input', function() {
        var val = this.value;
        var wrap = document.getElementById('pwStrength');
        var fill = document.getElementById('pwFill');
        var lbl  = document.getElementById('pwLabel');
        if (!val) { wrap.style.display = 'none'; return; }
        wrap.style.display = 'flex';
        var score = 0;
        if (val.length >= 6)  score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;
        var pct = (score / 5) * 100;
        var colors = ['#ef4444','#f97316','#eab308','#22c55e','#16a34a'];
        var labels = ['Very weak','Weak','Fair','Strong','Very strong'];
        fill.style.width = pct + '%';
        fill.style.background = colors[score - 1] || '#ef4444';
        lbl.textContent = labels[score - 1] || 'Very weak';
        lbl.style.color = colors[score - 1] || '#ef4444';
    });
}
</script>

<style>
/* ── Page ── */
.sp-page { max-width: 1000px; margin: 0 auto; padding: 36px 20px; }

/* ── Header ── */
.sp-header { margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border-dark); }
.sp-header h1 { margin: 0 0 6px; font-size: 1.9rem; font-weight: 800; letter-spacing: -.5px;
    background: linear-gradient(135deg, #ffffff 0%, #febd69 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.sp-sub { margin: 0; color: var(--text-muted); font-size: .88em; }

/* ── Alerts ── */
.sp-alert { display: flex; align-items: center; gap: 10px; padding: 12px 16px;
    border-radius: 10px; margin-bottom: 20px; font-size: .88em; }
.sp-alert--error   { background: rgba(239,68,68,.1);  border: 1px solid rgba(239,68,68,.3);  color: #fca5a5; }
.sp-alert--success { background: rgba(22,163,74,.1);  border: 1px solid rgba(22,163,74,.3);  color: #86efac; }

/* ── Layout ── */
.sp-layout { display: grid; grid-template-columns: 220px 1fr; gap: 24px; align-items: start; }
@media (max-width: 700px) { .sp-layout { grid-template-columns: 1fr; } }

/* ── Sidebar ── */
.sp-sidebar { display: flex; flex-direction: column; gap: 16px; }
.sp-avatar-card {
    background: var(--amazon-white); border: 1px solid var(--border-dark);
    border-radius: 14px; padding: 24px 16px; text-align: center;
}
.sp-avatar-wrap {
    width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 14px;
    background: linear-gradient(135deg, #ff9900, #e07800);
    overflow: hidden; position: relative;
    box-shadow: 0 0 0 3px rgba(255,153,0,.25);
}
.sp-avatar-img  { width: 100%; height: 100%; object-fit: cover; display: block; }
.sp-avatar-initial {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    font-size: 2rem; font-weight: 800; color: #000;
}
.sp-avatar-name  { font-weight: 700; font-size: .95rem; color: var(--text-primary); margin-bottom: 3px; }
.sp-avatar-email { font-size: .76rem; color: var(--text-muted); word-break: break-all; margin-bottom: 10px; }
.sp-role-badge {
    display: inline-block; padding: 2px 10px; border-radius: 20px;
    font-size: .68rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase;
    background: rgba(255,153,0,.12); color: #ff9900; border: 1px solid rgba(255,153,0,.25);
}

.sp-quick-links { background: var(--amazon-white); border: 1px solid var(--border-dark); border-radius: 12px; overflow: hidden; }
.sp-quick-link {
    display: flex; align-items: center; gap: 9px; padding: 11px 14px;
    color: var(--text-muted); text-decoration: none; font-size: .85rem;
    border-bottom: 1px solid var(--border-dark); transition: background .15s, color .15s;
}
.sp-quick-link:last-child { border-bottom: none; }
.sp-quick-link:hover { background: rgba(255,153,0,.07); color: var(--amazon-orange); }
.sp-quick-link svg { flex-shrink: 0; opacity: .6; }

/* ── Main ── */
.sp-main { display: flex; flex-direction: column; gap: 20px; }

/* ── Cards ── */
.sp-card { background: var(--amazon-white); border: 1px solid var(--border-dark); border-radius: 14px; overflow: hidden; }
.sp-card--danger { border-color: rgba(239,68,68,.25); }
.sp-card-head {
    display: flex; align-items: center; gap: 9px;
    padding: 14px 20px; background: rgba(0,0,0,.15);
    border-bottom: 1px solid var(--border-dark);
    font-size: .82rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: var(--text-muted);
}
.sp-card-head--danger { color: #fca5a5; background: rgba(239,68,68,.06); border-bottom-color: rgba(239,68,68,.2); }
.sp-card-body { padding: 20px; }
.sp-card-foot { padding: 14px 20px; border-top: 1px solid var(--border-dark); background: rgba(0,0,0,.08); display: flex; justify-content: flex-end; }

/* ── Form fields ── */
.sp-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 500px) { .sp-row { grid-template-columns: 1fr; } }
.sp-field { display: flex; flex-direction: column; margin-bottom: 14px; }
.sp-field:last-child { margin-bottom: 0; }
.sp-field label { font-size: .82rem; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; }
.sp-req { color: #ef4444; }
.sp-input {
    padding: 10px 13px; border: 1px solid var(--border-dark); border-radius: 9px;
    background: rgba(15,23,34,.6); color: var(--text-primary); font-size: .9rem;
    font-family: inherit; outline: none; transition: border-color .18s, box-shadow .18s;
}
.sp-input:focus { border-color: rgba(255,153,0,.5); box-shadow: 0 0 0 3px rgba(255,153,0,.1); }
.sp-input::placeholder { color: var(--text-muted); }
.sp-hint-text { font-size: .82rem; color: var(--text-muted); margin: 0 0 16px; }

/* ── Password strength ── */
.sp-pw-strength { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
.sp-pw-bar { flex: 1; height: 4px; background: rgba(255,255,255,.1); border-radius: 2px; overflow: hidden; }
.sp-pw-fill { height: 100%; border-radius: 2px; transition: width .3s, background .3s; }
#pwLabel { font-size: .75rem; font-weight: 600; white-space: nowrap; }

/* ── Danger row ── */
.sp-danger-row { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
.sp-danger-row strong { font-size: .9rem; color: var(--text-primary); display: block; margin-bottom: 3px; }
.sp-danger-row p { margin: 0; font-size: .82rem; color: var(--text-muted); }

/* ── Buttons ── */
.sp-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 20px; border-radius: 9px; font-size: .88rem; font-weight: 700;
    cursor: pointer; border: none; font-family: inherit; transition: opacity .18s, box-shadow .18s, transform .15s;
}
.sp-btn:hover { opacity: .88; transform: translateY(-1px); }
.sp-btn:active { transform: scale(.98); }
.sp-btn--primary { background: var(--amazon-orange); color: #000; }
.sp-btn--danger  { background: #dc2626; color: #fff; }
.sp-btn--ghost   { background: transparent; color: var(--text-muted); border: 1px solid var(--border-dark); }
.sp-btn--ghost:hover { color: var(--text-primary); }

/* ── Modal ── */
.sp-modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.65); backdrop-filter: blur(4px);
    z-index: 99999; align-items: center; justify-content: center;
}
.sp-modal {
    background: #111827; border: 1px solid rgba(239,68,68,.3); border-radius: 16px;
    padding: 32px; max-width: 420px; width: calc(100% - 40px); text-align: center;
}
.sp-modal-icon { margin-bottom: 16px; }
.sp-modal h3 { margin: 0 0 10px; font-size: 1.15rem; color: #f1f5f9; }
.sp-modal p  { margin: 0 0 24px; font-size: .88rem; color: #94a3b8; }
.sp-modal-actions { display: flex; gap: 10px; justify-content: center; }
</style>
{% endblock %}
