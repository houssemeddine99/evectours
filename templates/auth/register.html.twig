{% extends 'base.html.twig' %}

{% block title %}Register | Travagir{% endblock %}

{% block body %}
    <section class="auth-section">
        <h1>Register</h1>
        <p class="lead">Create your account to start planning your travels.</p>

        <div class="auth-container">
            <form class="contact-form" method="post" action="{{ path('auth_register') }}">
                {% if error %}
                    <p class="error-message">{{ error }}</p>
                {% endif %}

                <label>Username
                    <input type="text" name="username" value="{{ username }}" placeholder="Your username" required>
                </label>

                <label>Email
                    <input type="email" name="email" value="{{ email }}" placeholder="you@example.com" required>
                </label>

                <label>Password
                    <input type="password" name="password" placeholder="********" required>
                </label>

                <label>Confirm Password
                    <input type="password" name="confirm_password" placeholder="********" required>
                </label>

                <button type="submit" class="btn btn-primary">Register</button>
                <p class="meta">Already have an account? <a href="{{ path('auth_login') }}">Login here</a></p>
            </form>
        </div>
    </section>
{% endblock %}
