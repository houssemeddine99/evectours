{% extends 'base.html.twig' %}
{% block title %}Reset Password | Travagir{% endblock %}
{% block meta_description %}Set a new password for your Travagir account.{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <span class="logo-icon">🔐</span>
                    <span class="logo-text">Travagir</span>
                </div>
                <h1>Reset password</h1>
            </div>

            {% if invalid %}
                <div class="alert alert-error" style="text-align:center;padding:24px;">
                    <div style="font-size:2.5rem;margin-bottom:10px;">⛔</div>
                    <strong>Link expired or invalid</strong><br>
                    <span style="font-size:.93rem;font-weight:400;">This reset link has expired or already been used.</span>
                </div>
                <div style="text-align:center;margin-top:20px;">
                    <a href="{{ path('auth_forgot_password') }}" class="btn btn-primary">Request a new link</a>
                </div>

            {% elseif success %}
                <div class="alert alert-success" style="text-align:center;padding:24px;">
                    <div style="font-size:2.5rem;margin-bottom:10px;">✅</div>
                    <strong>Password updated!</strong><br>
                    <span style="font-size:.93rem;font-weight:400;">You can now sign in with your new password.</span>
                </div>
                <div style="text-align:center;margin-top:20px;">
                    <a href="{{ path('auth_login') }}" class="btn btn-primary">Sign In</a>
                </div>

            {% else %}
                {% if error %}
                    <div class="alert alert-error"><span class="alert-icon">⚠</span> {{ error }}</div>
                {% endif %}
                <p class="lead" style="margin-bottom:20px;">Choose a strong new password.</p>

                <form class="auth-form" method="post" action="{{ path('auth_reset_password') }}" id="rp-form">
                    <input type="hidden" name="token" value="{{ token }}">

                    <div class="form-group">
                        <label for="password">New Password</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="password" name="password" placeholder="Min. 8 characters"
                                   required minlength="8" autocomplete="new-password" class="auth-input">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password_confirm">Confirm Password</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="password_confirm" name="password_confirm" placeholder="Repeat password"
                                   required minlength="8" autocomplete="new-password" class="auth-input">
                        </div>
                        <span id="pw-match-hint" style="font-size:.82rem;margin-top:4px;display:none;"></span>
                    </div>

                    <button type="submit" class="btn btn-primary auth-submit" id="rp-submit">
                        Set New Password
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
</div>

<script>
(function () {
    var pw  = document.getElementById('password');
    var pw2 = document.getElementById('password_confirm');
    var hint = document.getElementById('pw-match-hint');
    var btn  = document.getElementById('rp-submit');
    if (!pw2) return;

    function check() {
        if (!pw2.value) { hint.style.display = 'none'; return; }
        if (pw.value === pw2.value) {
            hint.textContent = '✅ Passwords match';
            hint.style.color = '#22c55e';
        } else {
            hint.textContent = '❌ Passwords do not match';
            hint.style.color = '#f87171';
        }
        hint.style.display = 'block';
    }

    pw.addEventListener('input', check);
    pw2.addEventListener('input', check);

    document.getElementById('rp-form') && document.getElementById('rp-form').addEventListener('submit', function (e) {
        if (pw.value !== pw2.value) { e.preventDefault(); return; }
        btn.disabled = true;
        btn.textContent = 'Saving…';
    });
})();
</script>
{% endblock %}
