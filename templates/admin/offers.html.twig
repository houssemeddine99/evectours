{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'offers' %}
{% block title %}Offers | Evec Tours Admin{% endblock %}

{% block admin_body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>Manage Offers</h1>
            <p class="lead">Create, edit, and delete promotional offers</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_offer_new') }}" class="btn btn-primary">
                <span>➕</span> Add New Offer
            </a>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">
                ← Back to Dashboard
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Voyage</th>
                    <th>Discount</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Flash Sale</th>
                <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for offer in offers %}
                <tr>
                    <td>{{ offer.id }}</td>
                    <td><strong>{{ offer.title }}</strong></td>
                    <td>
                        <div class="voyage-info">
                            <span>{{ offer.voyage_title }}</span>
                            <small>{{ offer.destination }}</small>
                        </div>
                    </td>
                    <td><span class="discount-badge">{{ offer.discount_percentage }}%</span></td>
                    <td>{{ offer.start_date }}</td>
                    <td>{{ offer.end_date }}</td>
                    <td>
                        {% if offer.flash_sale_active is defined and offer.flash_sale_active %}
                            <span class="flash-live-badge">⚡ LIVE</span>
                            <div class="flash-countdown-admin" data-ends="{{ offer.flash_sale_ends_at }}"></div>
                        {% else %}
                            <span style="color:var(--text-muted);font-size:0.8rem;">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="status-badge {{ offer.is_active ? 'active' : 'inactive' }}">
                            {{ offer.is_active ? 'Active' : 'Inactive' }}
                        </span>
                    </td>
                    <td class="actions-cell">
                        <a href="{{ path('admin_offer_edit', {id: offer.id}) }}" class="btn btn-sm btn-edit">Edit</a>
                        <a href="{{ path('admin_offer_delete', {id: offer.id}) }}" class="btn btn-sm btn-delete" onclick="return confirm('Are you sure you want to delete this offer?');">Delete</a>

                        {% if offer.flash_sale_active is defined and offer.flash_sale_active %}
                            <form method="post" action="{{ path('admin_offer_flash_sale_deactivate', {id: offer.id}) }}" class="delete-form" style="display:inline;">
                                <button type="submit" class="btn btn-sm" style="background:#b45309;color:#fff;">⚡ Stop Flash</button>
                            </form>
                        {% else %}
                            <button type="button" class="btn btn-sm btn-flash" onclick="openFlashModal({{ offer.id }}, '{{ offer.title|e('js') }}')">⚡ Flash Sale</button>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="empty-state">No offers found. Create your first offer!</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<style>
.admin-page {
    padding: 30px 20px;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-actions {
    display: flex;
    gap: 12px;
}

.btn {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}

.btn-primary {
    background: var(--amazon-orange);
    color: #000;
}

.btn-primary:hover {
    background: #e68a00;
}

.btn-secondary {
    background: var(--amazon-white);
    color: var(--text-primary);
    border: 1px solid var(--border-dark);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
}

.btn-sm {
    padding: 6px 12px;
    font-size: 0.85rem;
}

.btn-edit {
    background: #3b82f6;
    color: white;
}

.btn-delete {
    background: #ef4444;
    color: white;
}

.alert {
    padding: 14px 20px;
    border-radius: 8px;
    margin-bottom: 24px;
}

.alert-success {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid #22c55e;
    color: #22c55e;
}

.alert-error {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid #ef4444;
    color: #ef4444;
}

.admin-table-container {
    background: var(--amazon-white);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-dark);
}

.admin-table {
    width: 100%;
    border-collapse: collapse;
}

.admin-table th,
.admin-table td {
    padding: 14px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border-dark);
}

.admin-table th {
    background: rgba(15, 23, 34, 0.5);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.admin-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.03);
}

.admin-table tbody tr:last-child td {
    border-bottom: none;
}

.voyage-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.voyage-info small {
    color: var(--text-muted);
    font-size: 0.85rem;
}

.discount-badge {
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 700;
}

.status-badge {
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
}

.status-badge.active {
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
}

.status-badge.inactive {
    background: rgba(107, 114, 128, 0.2);
    color: #6b7280;
}

.actions-cell {
    display: flex;
    gap: 8px;
}

.delete-form {
    display: inline;
}

.empty-state {
    text-align: center;
    color: var(--text-muted);
    padding: 40px !important;
}

@media (max-width: 1024px) {
    .admin-table {
        display: block;
        overflow-x: auto;
    }
}
.btn-flash { background: linear-gradient(90deg,#b45309,#f59e0b); color:#000; font-weight:700; }
.flash-live-badge { background:#f59e0b; color:#000; border-radius:10px; padding:2px 8px; font-size:0.78rem; font-weight:700; }
.flash-countdown-admin { font-size:0.8rem; color:#f59e0b; font-family:monospace; margin-top:3px; }
.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.75); display:flex; align-items:center; justify-content:center; z-index:9999; }
.modal-box { background:#1a1a2e; border:1px solid #333; border-radius:14px; padding:28px; max-width:420px; width:90%; }
.modal-box h3 { margin:0 0 16px; }
.modal-box label { display:block; margin-bottom:6px; font-size:0.9rem; color:#94a3b8; }
.modal-box input[type=number] { width:100%; padding:10px 14px; border-radius:8px; border:1px solid #444; background:#0f0f1a; color:#fff; font-size:1rem; margin-bottom:16px; }
.modal-actions { display:flex; gap:10px; }
</style>

{# Flash Sale Modal #}
<div id="flash-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <h3>⚡ Activate Flash Sale</h3>
        <p id="flash-modal-title" style="color:#94a3b8;margin-bottom:16px;"></p>
        <form id="flash-modal-form" method="post">
            <label for="flash-discount-input">Extra discount % (on top of regular offer)</label>
            <input type="number" id="flash-discount-input" name="flash_discount" value="10" min="1" max="50">
            <p style="font-size:0.8rem;color:#6b7280;margin-bottom:16px;">Flash sale will run for 24 hours. A live countdown will appear on the offers page.</p>
            <div class="modal-actions">
                <button type="submit" class="btn btn-primary" style="flex:1;">Activate 24h Flash Sale</button>
                <button type="button" onclick="closeFlashModal()" class="btn btn-secondary" style="flex:1;">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
function openFlashModal(id, title) {
    document.getElementById('flash-modal-title').textContent = 'Offer: ' + title;
    document.getElementById('flash-modal-form').action = '/admin/offers/' + id + '/flash-sale/activate';
    document.getElementById('flash-modal').style.display = 'flex';
}
function closeFlashModal() {
    document.getElementById('flash-modal').style.display = 'none';
}
document.getElementById('flash-modal').addEventListener('click', function(e) {
    if (e.target === this) closeFlashModal();
});

document.querySelectorAll('.flash-countdown-admin').forEach(function (el) {
    var endsAt = new Date(el.dataset.ends).getTime();
    function update() {
        var diff = endsAt - Date.now();
        if (diff <= 0) { el.textContent = 'ended'; return; }
        var h = Math.floor(diff / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        el.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0') + ' left';
    }
    update();
    setInterval(update, 1000);
});
</script>
{% endblock %}