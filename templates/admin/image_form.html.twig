{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'images' %}

{% block title %}{% if image %}Edit Image{% else %}New Image{% endif %} | Admin{% endblock %}

{% block admin_body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>{% if image %}Edit Image{% else %}Add New Image{% endif %}</h1>
            <p class="lead">{% if image %}Update image details{% else %}Add a new voyage image{% endif %}</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_images') }}" class="btn btn-secondary">
                ← Back to Images
            </a>
        </div>
    </div>

    <div class="form-container">
        <form method="post" class="admin-form">
            <div class="form-group">
                <label for="voyage_id">Voyage *</label>
                <select id="voyage_id" name="voyage_id" required class="form-control">
                    <option value="">Select a voyage</option>
                    {% for v in voyages %}
                        <option value="{{ v.id }}" {% if image and image.voyage_id == v.id %}selected{% endif %}>
                            {{ v.title }} - {{ v.destination }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label for="image_url">Image URL *</label>
                <input type="url" id="image_url" name="image_url" value="{{ image.image_url|default('') }}" required class="form-control" placeholder="https://example.com/image.jpg">
            </div>

            <div class="form-group">
                <label for="cloudinary_public_id">Cloudinary Public ID</label>
                <input type="text" id="cloudinary_public_id" name="cloudinary_public_id" value="{{ image.cloudinary_public_id|default('') }}" class="form-control" placeholder="voyages/image_name">
                <small class="form-hint">Optional: The public ID in Cloudinary for this image</small>
            </div>

            {% if image and image.image_url %}
            <div class="form-group">
                <label>Preview</label>
                <img src="{{ image.image_url }}" alt="Preview" class="image-preview">
            </div>
            {% endif %}

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    {% if image %}Update Image{% else %}Add Image{% endif %}
                </button>
                <a href="{{ path('admin_images') }}" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<style>
.admin-page {
    padding: 30px 20px;
    max-width: 800px;
    margin: 0 auto;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-actions {
    display: flex;
    gap: 12px;
}

.btn {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}

.btn-primary {
    background: var(--amazon-orange);
    color: #000;
}

.btn-primary:hover {
    background: #e68a00;
}

.btn-secondary {
    background: var(--amazon-white);
    color: var(--text-primary);
    border: 1px solid var(--border-dark);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
}

.form-container {
    background: var(--amazon-white);
    border-radius: 12px;
    padding: 30px;
    border: 1px solid var(--border-dark);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-primary);
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    background: rgba(15, 23, 34, 0.5);
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.form-control:focus {
    outline: none;
    border-color: var(--amazon-orange);
    box-shadow: 0 0 0 3px rgba(255, 153, 0, 0.15);
}

.form-control::placeholder {
    color: var(--text-muted);
}

select.form-control {
    cursor: pointer;
}

.form-hint {
    display: block;
    margin-top: 6px;
    color: var(--text-muted);
    font-size: 0.85rem;
}

.image-preview {
    max-width: 300px;
    max-height: 200px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--border-dark);
}

.form-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}
</style>
{% endblock %}