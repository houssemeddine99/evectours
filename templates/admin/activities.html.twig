{% extends 'base.html.twig' %}

{% block title %}Admin – Activities{% endblock %}

{% block body %}
    <h1>Activities Overview</h1>
    {% if activities is empty %}
        <p>No activities found.</p>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Duration (h)</th>
                    <th>Price per Person</th>
                    <th>Voyage</th>
                </tr>
            </thead>
            <tbody>
                {% for activity in activities %}
                    <tr>
                        <td>{{ activity.id }}</td>
                        <td>{{ activity.name }}</td>
                        <td>{{ activity.description|default('') }}</td>
                        <td>{{ activity.duration_hours|default('') }}</td>
                        <td>{{ activity.price_per_person|default('') }}</td>
                        <td>
                            {% if activity.voyage_id is defined %}
                                {{ activity.voyage_title }} ({{ activity.destination }})
                            {% else %}
                                –
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
