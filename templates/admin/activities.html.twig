{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'activities' %}

{% block title %}Admin – Activities{% endblock %}

{% block admin_body %}
    <div class="admin-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1>Activities Overview</h1>
        <a href="{{ path('admin_activity_new') }}" class="btn btn-primary" style="padding: 10px 15px; background: #28a745; color: white; text-decoration: none; border-radius: 4px;">
            + Add New Activity
        </a>
    </div>

    {% if activities is empty %}
        <p>No activities found.</p>
    {% else %}
        <div class="admin-table-container" style="overflow-x: auto;">
            <table class="admin-table" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                
                        <th>Name</th>
                        <th>Duration (h)</th>
                        <th>Price</th>
                        <th>Voyage</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for activity in activities %}
                        <tr style="border-bottom: 1px solid #dee2e6;">
                      
                            <td><strong>{{ activity.name }}</strong></td>
                            <td>{{ activity.duration_hours|default('N/A') }}</td>
                            <td>{{ activity.price_per_person|default('0') }} €</td>
                            <td>
                                {% if activity.voyage_title is defined %}
                                    {{ activity.voyage_title }}
                                {% else %}
                                    <span style="color: #999;">No Voyage</span>
                                {% endif %}
                            </td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="{{ path('admin_activity_edit', {id: activity.id}) }}" class="btn-sm" style="color: #4e73df; text-decoration: none;">Edit</a>
                                    
                                    <a href="{{ path('admin_activity_delete', {id: activity.id}) }}" 
                                       class="btn-sm" 
                                       style="color: #e74a3b; text-decoration: none;"
                                       onclick="return confirm('Are you sure you want to delete this activity?');">
                                       Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}