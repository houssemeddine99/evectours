{% extends 'base.html.twig' %}

{% block title %}Admin – Reclamations{% endblock %}

{% block body %}
    <h1>All Reclamations (Admin)</h1>
    {% if reclamations|length > 0 %}
    <form method="get" action="{{ path('admin_reclamations') }}" style="margin-bottom: 20px;">
    <input type="email" name="email" value="{{ currentEmail }}" placeholder="Filter by User Email...">
    <button type="submit">Search</button>
    {% if currentEmail %}
        <a href="{{ path('admin_reclamations') }}">Clear</a>
    {% endif %}
</form>
        <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Reservation ID</th>
                    <th>User ID</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Created At</th>
                    <th>Updated At</th>
                    <th>Admin Response</th>
                    <th>Response Date</th>
                    <th>Resolution Date</th>
                </tr>
            </thead>
            <tbody>
                {% for rec in reclamations %}
                    <tr>
                        <td>{{ rec.id }}</td>
                        <td>{{ rec.reservationId }}</td>
                        <td>{{ rec.userId }}</td>
                        <td><a href="{{ path('admin_reclamation_detail', {'id': rec.id}) }}">{{ rec.title }}</a></td>
                        <td>{{ rec.description }}</td>
                        <td>{{ rec.status }}</td>
                        <td>{{ rec.priority }}</td>
                        <td>{{ rec.createdAt ? rec.createdAt|date('Y-m-d H:i') : '' }}</td>
                        <td>{{ rec.updatedAt ? rec.updatedAt|date('Y-m-d H:i') : '' }}</td>
                        <td>{{ rec.adminResponse|default('') }}</td>
                        <td>{{ rec.responseDate ? rec.responseDate|date('Y-m-d H:i') : '' }}</td>
                        <td>{{ rec.resolutionDate ? rec.resolutionDate|date('Y-m-d H:i') : '' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
        {# 2. Pagination Controls #}
<div class="pagination">
    {% if currentPage > 1 %}
        <a href="{{ path('admin_reclamations', {page: currentPage - 1, email: currentEmail, limit: limit}) }}">Previous</a>
    {% endif %}

    <span>Page {{ currentPage }} of {{ totalPages }}</span>

    {% if currentPage < totalPages %}
        <a href="{{ path('admin_reclamations', {page: currentPage + 1, email: currentEmail, limit: limit}) }}">Next</a>
    {% endif %}
</div>
    {% else %}
        <p>No reclamations found.</p>
    {% endif %}
{% endblock %}
