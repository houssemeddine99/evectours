{% extends 'base.html.twig' %}

{% block stylesheets %}{% block admin_stylesheets %}{% endblock %}{% endblock %}

{% block body %}
<div class="admin-shell">
  <!-- Sidebar -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-header">
      <span class="sidebar-logo">⚙ Admin</span>
      <button class="sidebar-close" onclick="toggleSidebar()" title="Close">✕</button>
    </div>

    <nav class="sidebar-nav">
      <a href="{{ path('admin_dashboard') }}" class="sidebar-link {% if active_section == 'dashboard' %}active{% endif %}">
        <span class="sidebar-icon">🏠</span><span>Dashboard</span>
      </a>

      <div class="sidebar-group">Users &amp; Bookings</div>
      <a href="{{ path('admin_users') }}" class="sidebar-link {% if active_section == 'users' %}active{% endif %}">
        <span class="sidebar-icon">👥</span><span>Users</span>
      </a>
      <a href="{{ path('admin_reservations') }}" class="sidebar-link {% if active_section == 'reservations' %}active{% endif %}">
        <span class="sidebar-icon">📋</span><span>Reservations</span>
      </a>
      <a href="{{ path('admin_reclamations') }}" class="sidebar-link {% if active_section == 'reclamations' %}active{% endif %}">
        <span class="sidebar-icon">📝</span><span>Reclamations</span>
      </a>
      <a href="{{ path('admin_refunds') }}" class="sidebar-link {% if active_section == 'refunds' %}active{% endif %}">
        <span class="sidebar-icon">💰</span><span>Refunds</span>
      </a>
      <a href="{{ path('admin_reviews') }}" class="sidebar-link {% if active_section == 'reviews' %}active{% endif %}">
        <span class="sidebar-icon">⭐</span><span>Reviews</span>
      </a>

      <div class="sidebar-group">Content</div>
      <a href="{{ path('admin_voyages') }}" class="sidebar-link {% if active_section == 'voyages' %}active{% endif %}">
        <span class="sidebar-icon">✈️</span><span>Voyages</span>
      </a>
      <a href="{{ path('admin_activities') }}" class="sidebar-link {% if active_section == 'activities' %}active{% endif %}">
        <span class="sidebar-icon">🎯</span><span>Activities</span>
      </a>
      <a href="{{ path('admin_offers') }}" class="sidebar-link {% if active_section == 'offers' %}active{% endif %}">
        <span class="sidebar-icon">🏷️</span><span>Offers</span>
      </a>
      <a href="{{ path('admin_images') }}" class="sidebar-link {% if active_section == 'images' %}active{% endif %}">
        <span class="sidebar-icon">🖼️</span><span>Images</span>
      </a>

      <div class="sidebar-group">Analytics</div>
      <a href="{{ path('admin_voyage_visits') }}" class="sidebar-link {% if active_section == 'visits' %}active{% endif %}">
        <span class="sidebar-icon">📊</span><span>Voyage Visits</span>
      </a>
      <a href="{{ path('admin_search_history') }}" class="sidebar-link {% if active_section == 'search' %}active{% endif %}">
        <span class="sidebar-icon">🔎</span><span>Search History</span>
      </a>
      <a href="{{ path('admin_login_stats') }}" class="sidebar-link {% if active_section == 'login_stats' %}active{% endif %}">
        <span class="sidebar-icon">🔐</span><span>Login Stats</span>
      </a>

      <div class="sidebar-group">Tools</div>
      <a href="{{ path('admin_ai_assistant') }}" class="sidebar-link {% if active_section == 'ai' %}active{% endif %}">
        <span class="sidebar-icon">🤖</span><span>AI Assistant</span>
      </a>
    </nav>
  </aside>

  <!-- Overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <!-- Main content -->
  <div class="admin-main">
    <!-- Mobile top bar -->
    <div class="admin-topbar">
      <button class="topbar-toggle" onclick="toggleSidebar()" title="Menu">☰</button>
      <span class="topbar-title">Evec Tours Admin</span>
    </div>

    <div class="admin-content">
      {% block admin_body %}{% endblock %}
    </div>
  </div>
</div>

<style>
/* ── Admin Shell Layout ── */
.admin-shell {
  display: flex;
  min-height: calc(100vh - 62px); /* below sticky header */
  background: var(--amazon-light);
}

/* ── Sidebar ── */
.admin-sidebar {
  width: 220px;
  flex-shrink: 0;
  background: #080d1a;
  border-right: 1px solid rgba(30,122,224,.18);
  display: flex;
  flex-direction: column;
  position: sticky;
  top: 62px;
  height: calc(100vh - 62px);
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: #1e3050 transparent;
  z-index: 200;
  transition: transform .25s ease;
}

.sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 16px 14px;
  border-bottom: 1px solid rgba(30,122,224,.15);
}

.sidebar-logo {
  font-weight: 700;
  font-size: .95rem;
  color: var(--amazon-orange-soft);
  letter-spacing: .3px;
}

.sidebar-close {
  display: none;
  background: transparent;
  border: none;
  color: var(--text-muted);
  font-size: 1rem;
  cursor: pointer;
  padding: 4px;
  line-height: 1;
}

.sidebar-nav {
  padding: 10px 8px 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-group {
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-muted);
  padding: 14px 10px 4px;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: 9px;
  color: var(--text-muted);
  font-size: .88rem;
  font-weight: 500;
  text-decoration: none;
  transition: all .18s ease;
  white-space: nowrap;
}

.sidebar-link:hover {
  background: rgba(30,122,224,.12);
  color: var(--evec-blue-light);
}

.sidebar-link.active {
  background: rgba(245,195,0,.12);
  color: var(--amazon-orange-soft);
  font-weight: 700;
}

.sidebar-icon {
  font-size: 1rem;
  flex-shrink: 0;
  width: 20px;
  text-align: center;
}

/* ── Main area ── */
.admin-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.admin-topbar {
  display: none;
  align-items: center;
  gap: 14px;
  padding: 12px 16px;
  background: #080d1a;
  border-bottom: 1px solid rgba(30,122,224,.18);
  position: sticky;
  top: 62px;
  z-index: 100;
}

.topbar-toggle {
  background: transparent;
  border: 1px solid rgba(255,255,255,.15);
  border-radius: 8px;
  color: var(--text-primary);
  font-size: 1.2rem;
  cursor: pointer;
  padding: 5px 10px;
  line-height: 1;
}

.topbar-title {
  font-weight: 700;
  font-size: .95rem;
  color: var(--amazon-orange-soft);
}

.admin-content {
  padding: 28px 24px;
  flex: 1;
}

/* ── Overlay (mobile) ── */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.55);
  z-index: 199;
  backdrop-filter: blur(2px);
}

/* ── Mobile ── */
@media (max-width: 900px) {
  .admin-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    transform: translateX(-100%);
    z-index: 500;
  }

  .admin-sidebar.open {
    transform: translateX(0);
  }

  .admin-sidebar.open ~ .sidebar-overlay,
  .sidebar-overlay.open {
    display: block;
  }

  .sidebar-close {
    display: block;
  }

  .admin-topbar {
    display: flex;
  }

  .admin-content {
    padding: 20px 16px;
  }
}
</style>

<script>
function toggleSidebar() {
  const sidebar = document.getElementById('adminSidebar');
  const overlay = document.getElementById('sidebarOverlay');
  sidebar.classList.toggle('open');
  overlay.classList.toggle('open');
}
</script>
{% endblock %}
