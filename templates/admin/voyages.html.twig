{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'voyages' %}
{% block title %}Voyages | Evec Tours Admin{% endblock %}

{% block admin_body %}
<div class="av-page">
  <div class="page-header">
    <div>
      <h1>Voyages</h1>
      <p class="lead">Create, edit, and manage travel packages</p>
    </div>
    <a href="{{ path('admin_voyage_new') }}" class="btn btn-primary">✈️ Add Voyage</a>
  </div>

  {% for msg in app.flashes('success') %}
    <div class="alert alert-success">✓ {{ msg }}</div>
  {% endfor %}
  {% for msg in app.flashes('error') %}
    <div class="alert alert-error">⚠ {{ msg }}</div>
  {% endfor %}

  <div class="table-wrap">
    <table class="av-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Photo</th>
          <th>Title</th>
          <th>Destination</th>
          <th>Price</th>
          <th>Dates</th>
          <th>Acts</th>
          <th>Offers</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for v in voyages %}
        <tr>
          <td class="td-id">#{{ v.id }}</td>
          <td class="td-thumb">
            {% if v.image_url and v.image_url[0] %}
              <img src="{{ v.image_url[0] }}" alt="{{ v.title }}" class="v-thumb">
            {% else %}
              <div class="v-thumb-ph">✈</div>
            {% endif %}
          </td>
          <td class="td-title"><strong>{{ v.title }}</strong></td>
          <td class="td-dest">{{ v.destination }}</td>
          <td class="td-price">{{ v.price|number_format(0) }} TND</td>
          <td class="td-dates">
            <span>{{ v.start_date }}</span>
            <span class="dates-sep">→</span>
            <span>{{ v.end_date }}</span>
          </td>
          <td><span class="count-badge">{{ v.activities_count }}</span></td>
          <td><span class="count-badge offers">{{ v.offers_count }}</span></td>
          <td class="td-actions">
            <a href="{{ path('admin_voyage_manage', {id: v.id}) }}" class="btn-act btn-act-manage" title="Manage">⚙</a>
            <a href="{{ path('admin_voyage_edit', {id: v.id}) }}" class="btn-act btn-act-edit" title="Edit">✏</a>
            <form method="post" action="{{ path('admin_voyage_delete', {id: v.id}) }}" class="inline-form"
                  onsubmit="return confirm('Delete "{{ v.title|e('html_attr') }}"? This cannot be undone.');">
              <button type="submit" class="btn-act btn-act-delete" title="Delete">🗑</button>
            </form>
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="9" class="empty-row">No voyages found. <a href="{{ path('admin_voyage_new') }}">Create the first one.</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<style>
.av-page { max-width:1100px; }

.page-header { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px; margin-bottom:24px; }
.page-header h1 { margin:0 0 4px; font-size:1.8rem; }
.page-header .lead { margin:0; color:var(--text-muted); }

.table-wrap {
  background: #080e1c;
  border: 1px solid var(--border-dark);
  border-radius: 14px;
  overflow-x: auto;
}

.av-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 800px;
}

.av-table th {
  padding: 13px 14px;
  background: rgba(15,23,34,.6);
  color: var(--text-muted);
  font-size: .78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  text-align: left;
  border-bottom: 1px solid var(--border-dark);
}

.av-table td {
  padding: 12px 14px;
  border-bottom: 1px solid rgba(255,255,255,.04);
  vertical-align: middle;
}

.av-table tbody tr:hover { background: rgba(74,158,255,.04); }
.av-table tbody tr:last-child td { border-bottom: none; }

.td-id { font-family:monospace; color:var(--amazon-orange); font-weight:700; }

.v-thumb {
  width: 60px; height: 40px;
  object-fit: cover;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,.1);
  display: block;
}

.v-thumb-ph {
  width: 60px; height: 40px;
  border-radius: 6px;
  background: rgba(255,255,255,.06);
  display: flex; align-items:center; justify-content:center;
  font-size: 1.2rem;
  color: var(--text-muted);
}

.td-title strong { color:var(--text-primary); }
.td-dest { color:var(--text-muted); font-size:.9rem; }
.td-price { color:var(--amazon-orange); font-weight:700; white-space:nowrap; }
.td-dates { color:var(--text-muted); font-size:.85rem; white-space:nowrap; }
.dates-sep { color:var(--border-dark); margin:0 4px; }

.count-badge {
  display: inline-block;
  padding: 3px 9px;
  border-radius: 10px;
  font-size: .78rem;
  font-weight: 700;
  background: rgba(74,158,255,.15);
  color: var(--evec-blue-light);
}
.count-badge.offers {
  background: rgba(245,195,0,.15);
  color: var(--amazon-orange-soft);
}

.td-actions { display:flex; gap:6px; align-items:center; }

.btn-act {
  width: 32px; height: 32px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  display: flex; align-items:center; justify-content:center;
  font-size: .95rem;
  text-decoration: none;
  transition: all .18s ease;
  background: transparent;
}

.btn-act-manage { background:rgba(74,158,255,.15); color:var(--evec-blue-light); }
.btn-act-manage:hover { background:#3b82f6; color:#fff; }

.btn-act-edit { background:rgba(251,191,36,.15); color:#fbbf24; }
.btn-act-edit:hover { background:#d97706; color:#fff; }

.btn-act-delete { background:rgba(239,68,68,.15); color:#ef4444; }
.btn-act-delete:hover { background:#dc2626; color:#fff; }

.inline-form { display:inline; margin:0; padding:0; }

.empty-row {
  text-align: center;
  padding: 50px;
  color: var(--text-muted);
  font-size: .95rem;
}
.empty-row a { color:var(--amazon-orange); }
</style>
{% endblock %}
