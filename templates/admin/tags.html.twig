{% extends 'base.html.twig' %}

{% block title %}Manage Tags | Admin{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>Manage Tags</h1>
            <p class="lead">Create and delete voyage category tags</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_voyages') }}" class="btn btn-secondary">← Back to Voyages</a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="form-container" style="max-width:500px;margin-bottom:30px;">
        <h2 style="margin-top:0">Add New Tag</h2>
        <form method="post" action="{{ path('admin_tags') }}" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
            <div class="form-group" style="flex:1;min-width:160px;margin-bottom:0">
                <label>Tag Name *</label>
                <input type="text" name="name" required class="form-control" placeholder="e.g. Adventure">
            </div>
            <div class="form-group" style="margin-bottom:0">
                <label>Color</label>
                <input type="color" name="color" value="#ff9900" class="form-control" style="width:60px;padding:4px;">
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
        </form>
    </div>

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>Name</th><th>Color</th><th>Action</th></tr>
            </thead>
            <tbody>
                {% for tag in tags %}
                <tr>
                    <td>{{ tag.id }}</td>
                    <td><span class="tag-badge" style="background:{{ tag.color ?? '#ff9900' }}22;color:{{ tag.color ?? '#ff9900' }};border:1px solid {{ tag.color ?? '#ff9900' }};padding:4px 12px;border-radius:20px;font-weight:600;">{{ tag.name }}</span></td>
                    <td><span style="display:inline-block;width:24px;height:24px;background:{{ tag.color ?? '#ff9900' }};border-radius:4px;vertical-align:middle;"></span> {{ tag.color ?? '—' }}</td>
                    <td>
                        <form method="post" action="{{ path('admin_tag_delete', {id: tag.id}) }}" onsubmit="return confirm('Delete tag?');">
                            <button type="submit" class="btn btn-sm btn-delete">Delete</button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="empty-state">No tags yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
<style>
.admin-page{padding:30px 20px;max-width:900px;margin:0 auto}
.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;flex-wrap:wrap;gap:20px}
.page-header h1{margin:0 0 8px 0;font-size:2rem}
.form-container{background:var(--amazon-white);border-radius:12px;padding:30px;border:1px solid var(--border-dark)}
.form-group{margin-bottom:20px}
.form-group label{display:block;margin-bottom:8px;font-weight:600}
.form-control{width:100%;padding:10px 14px;border:1px solid var(--border-dark);border-radius:8px;background:rgba(15,23,34,.5);color:var(--text-primary);font-size:1rem}
.btn{padding:10px 20px;border-radius:8px;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:8px;border:none;cursor:pointer;font-size:.95rem}
.btn-primary{background:var(--amazon-orange);color:#000}
.btn-secondary{background:var(--amazon-white);color:var(--text-primary);border:1px solid var(--border-dark)}
.btn-sm{padding:6px 12px;font-size:.85rem}
.btn-delete{background:#ef4444;color:#fff}
.admin-table-container{background:var(--amazon-white);border-radius:12px;overflow:hidden;border:1px solid var(--border-dark)}
.admin-table{width:100%;border-collapse:collapse}
.admin-table th,.admin-table td{padding:14px 16px;text-align:left;border-bottom:1px solid var(--border-dark)}
.admin-table th{background:rgba(15,23,34,.5);font-weight:600;text-transform:uppercase;font-size:.9rem;letter-spacing:.5px}
.empty-state{text-align:center;color:var(--text-muted);padding:40px!important}
.alert{padding:14px 20px;border-radius:8px;margin-bottom:24px}
.alert-success{background:rgba(34,197,94,.15);border:1px solid #22c55e;color:#22c55e}
</style>
{% endblock %}
