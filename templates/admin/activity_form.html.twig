{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'activities' %}

{% block title %}{% if activity %}Edit Activity{% else %}New Activity{% endif %} | Admin{% endblock %}

{% block admin_body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>{% if activity %}Edit Activity{% else %}Create New Activity{% endif %}</h1>
            <p class="lead">{% if activity %}Update activity details{% else %}Add a new voyage activity{% endif %}</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_activities') }}" class="btn btn-secondary">
                ← Back to Activities
            </a>
        </div>
    </div>

    <div class="form-container">
        <form method="post" class="admin-form">
            <div class="form-group">
                <label for="voyage_id">Voyage *</label>
                <select id="voyage_id" name="voyage_id" required class="form-control">
                    <option value="">Select a voyage</option>
                    {% for v in voyages %}
                        <option value="{{ v.id }}" {% if activity and activity.voyage_id == v.id %}selected{% endif %}>
                            {{ v.title }} - {{ v.destination }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" value="{{ activity.name|default('') }}" required class="form-control">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="4" class="form-control">{{ activity.description|default('') }}</textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="duration_hours">Duration (hours)</label>
                    <input type="number" id="duration_hours" name="duration_hours" value="{{ activity.duration_hours|default('') }}" min="1" class="form-control">
                </div>

                <div class="form-group">
                    <label for="price_per_person">Price per Person ($)</label>
                    <input type="number" id="price_per_person" name="price_per_person" value="{{ activity.price_per_person|default('') }}" step="0.01" min="0" class="form-control">
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    {% if activity %}Update Activity{% else %}Create Activity{% endif %}
                </button>
                <a href="{{ path('admin_activities') }}" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<style>
.admin-page {
    padding: 30px 20px;
    max-width: 800px;
    margin: 0 auto;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-actions {
    display: flex;
    gap: 12px;
}

.btn {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}

.btn-primary {
    background: var(--amazon-orange);
    color: #000;
}

.btn-primary:hover {
    background: #e68a00;
}

.btn-secondary {
    background: var(--amazon-white);
    color: var(--text-primary);
    border: 1px solid var(--border-dark);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
}

.form-container {
    background: var(--amazon-white);
    border-radius: 12px;
    padding: 30px;
    border: 1px solid var(--border-dark);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-primary);
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    background: rgba(15, 23, 34, 0.5);
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.form-control:focus {
    outline: none;
    border-color: var(--amazon-orange);
    box-shadow: 0 0 0 3px rgba(255, 153, 0, 0.15);
}

.form-control::placeholder {
    color: var(--text-muted);
}

textarea.form-control {
    resize: vertical;
    min-height: 100px;
}

select.form-control {
    cursor: pointer;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.form-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}
</style>
{% endblock %}