{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'reviews' %}

{% block title %}Reviews{% if voyage %} — {{ voyage.title }}{% endif %} | Admin{% endblock %}

{% block admin_body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>⭐ Traveller Reviews{% if voyage %} — {{ voyage.title }}{% endif %}</h1>
            <p class="lead">{{ reviews|length }} review{{ reviews|length != 1 ? 's' : '' }}{% if voyage_id %} for this voyage{% else %} across all voyages{% endif %}</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">← Back to Dashboard</a>
        </div>
    </div>

    {% for msg in app.flashes('success') %}
        <div class="alert alert-success">{{ msg }}</div>
    {% endfor %}

    {% if reviews is empty %}
        <div class="empty-state">
            <p>No reviews found.</p>
        </div>
    {% else %}
    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Voyage ID</th>
                    <th>User ID</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for review in reviews %}
                <tr>
                    <td>{{ review.id }}</td>
                    <td>
                        <a href="{{ path('admin_reviews', {voyage_id: review.voyage_id}) }}">
                            #{{ review.voyage_id }}
                        </a>
                    </td>
                    <td>{{ review.user_id }}</td>
                    <td class="rating-cell">
                        {% for i in 1..5 %}
                            <span style="color: {{ i <= review.rating ? '#f59e0b' : '#444' }}">★</span>
                        {% endfor %}
                        <span class="rating-num">({{ review.rating }})</span>
                    </td>
                    <td class="comment-cell">{{ review.comment ?? '—' }}</td>
                    <td>{{ review.created_at }}</td>
                    <td>
                        <form method="post" action="{{ path('admin_review_delete', {id: review.id}) }}"
                              onsubmit="return confirm('Delete this review?')">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>

<style>
    .admin-table-wrap { overflow-x: auto; margin-top: 24px; }
    .admin-table { width: 100%; border-collapse: collapse; font-size: .92rem; }
    .admin-table th { background: rgba(255,255,255,.06); padding: 10px 14px; text-align: left; font-weight: 700; border-bottom: 1px solid var(--border-dark); }
    .admin-table td { padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,.05); vertical-align: top; }
    .admin-table tr:hover td { background: rgba(255,255,255,.03); }
    .rating-cell { white-space: nowrap; }
    .rating-num { color: var(--text-muted); font-size: .82rem; margin-left: 4px; }
    .comment-cell { max-width: 340px; word-break: break-word; color: var(--text-muted); }
    .btn-sm { padding: 5px 12px; font-size: .82rem; }
    .btn-danger { background: rgba(239,68,68,.15); color: #ef4444; border: 1px solid #ef4444; border-radius: 6px; cursor: pointer; }
    .btn-danger:hover { background: #ef4444; color: #fff; }
    .empty-state { text-align: center; padding: 60px 0; color: var(--text-muted); }
    .alert-success { background: rgba(34,197,94,.12); border: 1px solid #22c55e; color: #22c55e; padding: 12px 18px; border-radius: 8px; margin-bottom: 16px; }
</style>
{% endblock %}
