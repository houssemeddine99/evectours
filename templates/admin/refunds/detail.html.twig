{% extends 'base.html.twig' %}

{% block title %}Admin – Refund Detail{% endblock %}

{% block body %}
    <h1>Refund Request #{{ refund.id }}</h1>
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }}" style="margin-bottom:12px;">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if refund %}
        <div class="admin-table-container">
            <table class="admin-table">
                <tbody>
                    <tr><th>ID</th><td>{{ refund.id }}</td></tr>
                    <tr><th>Requester ID</th><td>{{ refund.requesterId|default('—') }}</td></tr>
                    <tr>
                        <th>Amount</th>
                        <td><strong>{{ refund.amount|default('0.00') }} TND</strong></td>
                    </tr>
                    <tr><th>Reason</th><td>{{ refund.reason|default('—') }}</td></tr>
                    <tr>
                        <th>Current Status</th>
                        <td>
                            {% set s = refund.status %}
                            <span style="padding:3px 10px;border-radius:12px;font-weight:600;font-size:0.85em;
                                background:{% if s == 'APPROVED' %}#d4edda;color:#155724{% elseif s == 'REJECTED' %}#f8d7da;color:#721c24{% else %}#fff3cd;color:#856404{% endif %};">
                                {{ s }}
                            </span>
                        </td>
                    </tr>
                    <tr><th>Reclamation ID</th><td>{{ refund.reclamationId|default('—') }}</td></tr>
                    <tr><th>Reservation ID</th><td>{{ refund.reservationId|default('—') }}</td></tr>
                    <tr><th>Created At</th><td>{{ refund.createdAt ? refund.createdAt|date('Y-m-d H:i') : '—' }}</td></tr>
                </tbody>
            </table>
        </div>

        <h2 style="margin-top:28px;">Update Refund Status</h2>
        <form method="post" action="{{ path('admin_refund_detail', {'id': refund.id}) }}" style="max-width:520px;">
            <div class="form-group" style="margin-bottom:14px;">
                <label for="status">New Status</label>
                <select id="status" name="status" class="form-control">
                    <option value="PENDING"  {% if refund.status == 'PENDING'  %}selected{% endif %}>PENDING</option>
                    <option value="APPROVED" {% if refund.status == 'APPROVED' %}selected{% endif %}>APPROVED</option>
                    <option value="REJECTED" {% if refund.status == 'REJECTED' %}selected{% endif %}>REJECTED</option>
                </select>
            </div>

            <div class="form-group" style="margin-bottom:6px;">
                <label for="payment_reference">
                    Stripe Payment Reference
                    <span style="color:#888;font-size:0.83em;">(required when approving)</span>
                </label>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <input
                        type="text"
                        id="payment_reference"
                        name="payment_reference"
                        class="form-control"
                        placeholder="pi_xxx or ch_xxx"
                        style="flex:1;min-width:220px;"
                    />
                    <button
                        type="button"
                        id="btn-generate"
                        class="btn btn-secondary"
                        style="white-space:nowrap;"
                    >
                        🧪 Generate Test Reference
                    </button>
                </div>
            </div>

            <div id="generate-status" style="margin:8px 0 12px;padding:8px 12px;border-radius:6px;display:none;font-size:0.9em;"></div>

            <button type="submit" class="btn btn-success">Save Changes</button>
        </form>

        <p style="margin-top:16px;"><a href="{{ path('admin_refunds') }}" class="btn btn-primary">← Back to Refunds</a></p>
    {% else %}
        <p>Refund not found.</p>
    {% endif %}

    <script>
    (function () {
        var btn       = document.getElementById('btn-generate');
        var refInput  = document.getElementById('payment_reference');
        var statusEl  = document.getElementById('generate-status');
        var generateUrl = '{{ path('admin_refund_generate_test', {'id': refund.id}) }}';

        function showStatus(msg, ok) {
            statusEl.textContent = msg;
            statusEl.style.display = 'block';
            statusEl.style.background = ok ? '#d4edda' : '#f8d7da';
            statusEl.style.color      = ok ? '#155724' : '#721c24';
            statusEl.style.border     = '1px solid ' + (ok ? '#c3e6cb' : '#f5c6cb');
        }

        btn.addEventListener('click', function () {
            btn.disabled = true;
            btn.textContent = '⏳ Generating…';
            statusEl.style.display = 'none';

            fetch(generateUrl, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function(resp) {
                return resp.text().then(function(text) {
                    try {
                        return JSON.parse(text);
                    } catch(e) {
                        throw new Error('Server returned non-JSON: ' + text.substring(0, 200));
                    }
                });
            })
            .then(function(data) {
                if (data.success) {
                    refInput.value = data.reference;
                    document.getElementById('status').value = 'APPROVED';
                    showStatus('✅ Reference generated: ' + data.reference, true);
                } else {
                    showStatus('❌ ' + (data.error || 'Unknown error'), false);
                }
            })
            .catch(function(e) {
                showStatus('❌ ' + e.message, false);
            })
            .finally(function() {
                btn.disabled = false;
                btn.textContent = '🧪 Generate Test Reference';
            });
        });
    })();
    </script>
{% endblock %}
