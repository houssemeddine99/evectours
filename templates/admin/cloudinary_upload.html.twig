{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'images' %}

{% block title %}Upload Image to Cloudinary | Admin{% endblock %}

{% block admin_body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>Upload Image to Cloudinary</h1>
            <p class="lead">Use this form to upload an image file directly to Cloudinary and save the image record.</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_images') }}" class="btn btn-secondary">← Back to Images</a>
        </div>
    </div>

    <div class="form-container">
        <form method="post" enctype="multipart/form-data" class="admin-form">
            {% if selectedVoyageId is not defined or selectedVoyageId == 0 %}
                <div class="form-group">
                    <label for="voyage_id">Voyage *</label>
                    <select id="voyage_id" name="voyage_id" required class="form-control">
                        <option value="">Select a voyage</option>
                        {% for v in voyages %}
                            <option value="{{ v.id }}" {% if data.voyage_id|default('') == v.id %}selected{% endif %}>
                                {{ v.title }} - {{ v.destination }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            {% else %}
                <input type="hidden" name="voyage_id" value="{{ selectedVoyageId }}">
            {% endif %}

            <div class="form-group">
                <label for="image">Image File *</label>
                <input type="file" id="image" name="image" accept="image/*" required class="form-control">
            </div>

            <div class="form-group">
                <label for="cloudinary_public_id">Cloudinary Public ID</label>
                <input type="text" id="cloudinary_public_id" name="cloudinary_public_id" value="{{ data.cloudinary_public_id|default('') }}" class="form-control" placeholder="voyages/image_name">
                <small class="form-hint">Optional: specify the Cloudinary public ID for this image.</small>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Upload to Cloudinary</button>
                <a href="{{ path('admin_images') }}" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<style>
.admin-page {
    padding: 30px 20px;
    max-width: 800px;
    margin: 0 auto;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-actions {
    display: flex;
    gap: 12px;
}

.btn {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}

.btn-primary {
    background: var(--amazon-orange);
    color: #000;
}

.btn-secondary {
    background: var(--amazon-white);
    color: var(--text-primary);
    border: 1px solid var(--border-dark);
}

.form-container {
    background: var(--amazon-white);
    border-radius: 12px;
    padding: 30px;
    border: 1px solid var(--border-dark);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-primary);
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    background: rgba(15, 23, 34, 0.5);
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.form-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}
</style>
{% endblock %}
