{% extends 'base.html.twig' %}
{% block title %}Admin Dashboard | Travagir{% endblock %}

{% block body %}
<div class="admin-dashboard">
    <!-- Page Header -->
    <div class="dashboard-header">
        <div class="header-content">
            <h1>Admin Dashboard</h1>
            <p class="lead">Welcome back! Here's an overview of your travel agency.</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_users_new') }}" class="btn btn-primary">
                <span>➕</span> Add New User
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <div class="stat-card stat-users">
            <div class="stat-icon">👥</div>
            <div class="stat-content">
                <span class="stat-value">{{ stats.total_users }}</span>
                <span class="stat-label">Total Users</span>
            </div>
            <a href="{{ path('admin_users') }}" class="stat-link">View All →</a>
        </div>

        <div class="stat-card stat-reservations">
            <div class="stat-icon">📋</div>
            <div class="stat-content">
                <span class="stat-value">{{ stats.total_reservations }}</span>
                <span class="stat-label">Total Reservations</span>
            </div>
            <a href="{{ path('admin_reservations') }}" class="stat-link">View All →</a>
        </div>

        <div class="stat-card stat-pending">
            <div class="stat-icon">⏳</div>
            <div class="stat-content">
                <span class="stat-value">{{ stats.pending_reservations }}</span>
                <span class="stat-label">Pending Reservations</span>
            </div>
            <a href="{{ path('admin_reservations') }}?status=PENDING" class="stat-link">Review →</a>
        </div>

        <div class="stat-card stat-revenue">
            <div class="stat-icon">💰</div>
            <div class="stat-content">
                <span class="stat-value">${{ stats.total_revenue|number_format(2) }}</span>
                <span class="stat-label">Total Revenue</span>
            </div>
        </div>

        <div class="stat-card stat-confirmed">
            <div class="stat-icon">✅</div>
            <div class="stat-content">
                <span class="stat-value">{{ stats.confirmed_reservations }}</span>
                <span class="stat-label">Confirmed</span>
            </div>
        </div>

        <div class="stat-card stat-voyages">
            <div class="stat-icon">✈️</div>
            <div class="stat-content">
                <span class="stat-value">{{ stats.total_voyages }}</span>
                <span class="stat-label">Active Voyages</span>
            </div>
            <a href="{{ path('travel_voyages') }}" class="stat-link">View All →</a>
        </div>
    </div>

    <!-- Quick Actions -->
    <section class="quick-actions">
        <h2>Quick Actions</h2>
        <div class="actions-grid">
            <a href="{{ path('admin_users') }}" class="action-card">
                <span class="action-icon">👤</span>
                <span class="action-title">Manage Users</span>
                <span class="action-desc">View, edit, and delete user accounts</span>
            </a>
            <a href="{{ path('admin_reservations') }}" class="action-card">
                <span class="action-icon">📝</span>
                <span class="action-title">Manage Reservations</span>
                <span class="action-desc">Review and process booking requests</span>
            </a>
            <a href="{{ path('admin_voyages') }}" class="action-card">
                <span class="action-icon">✈️</span>
                <span class="action-title">Manage Voyages</span>
                <span class="action-desc">Create, edit, and delete travel packages</span>
            </a>
            <a href="{{ path('admin_offers') }}" class="action-card">
                <span class="action-icon">🏷️</span>
                <span class="action-title">Manage Offers</span>
                <span class="action-desc">Create and manage promotional deals</span>
            </a>
            <a href="{{ path('admin_activities') }}" class="action-card">
                <span class="action-icon">🎯</span>
                <span class="action-title">Manage Activities</span>
                <span class="action-desc">Create and manage voyage activities</span>
            </a>
            <a href="{{ path('admin_images') }}" class="action-card">
                <span class="action-icon">🖼️</span>
                <span class="action-title">Manage Images</span>
                <span class="action-desc">Upload and manage voyage images</span>
            </a>
            <!-- New navigation to login statistics -->
            <a href="{{ path('admin_login_stats') }}" class="action-card">
                <span class="action-icon">🔐</span>
                <span class="action-title">Login Statistics</span>
                <span class="action-desc">View admin login activity and metrics</span>
            </a>
            <!-- New navigation to search history -->
            <a href="{{ path('admin_search_history') }}" class="action-card">
                <span class="action-icon">🔎</span>
                <span class="action-title">Search History</span>
                <span class="action-desc">View user search logs and analytics</span>
            </a>
              <a href="{{ path('admin_voyage_visits') }}" class="action-card">
                <span class="action-icon">✈️</span>
                <span class="action-title">voyage Visits</span>
                <span class="action-desc">View voyage visit statistics</span>
            </a>
            <!-- New navigation to reclamations list -->
            <a href="{{ path('admin_reclamations') }}" class="action-card">
                <span class="action-icon">📝</span>
                <span class="action-title">Reclamations</span>
                <span class="action-desc">View and manage user reclamations</span>
            </a>
            <!-- New navigation to refunds management -->
            <a href="{{ path('admin_refunds') }}" class="action-card">
                <span class="action-icon">💰</span>
                <span class="action-title">Refunds</span>
                <span class="action-desc">View and edit refunded reservations</span>
            </a>
        </div>
    </section>

    <!-- Recent Activity -->
    <div class="recent-sections">
        <!-- Recent Reservations -->
        <section class="recent-section">
            <div class="section-header">
                <h2>Recent Reservations</h2>
                <a href="{{ path('admin_reservations') }}" class="view-all">View All →</a>
            </div>
            {% if recent_reservations|length > 0 %}
            <div class="recent-list">
                {% for reservation in recent_reservations %}
                <div class="recent-item">
                    <div class="item-info">
                        <strong>{{ reservation.user_name }}</strong>
                        <span class="item-detail">{{ reservation.voyage_id }}</span>
                    </div>
                    <div class="item-meta">
                        <span class="item-price">${{ reservation.total_price|number_format(2) }}</span>
                        <span class="status status-{{ reservation.status|lower }}">{{ reservation.status }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="empty-state">No reservations yet.</p>
            {% endif %}
        </section>

        <!-- Recent Users -->
        <section class="recent-section">
            <div class="section-header">
                <h2>Recent Users</h2>
                <a href="{{ path('admin_users') }}" class="view-all">View All →</a>
            </div>
            {% if recent_users|length > 0 %}
            <div class="recent-list">
                {% for user in recent_users %}
                <div class="recent-item">
                    <div class="item-info">
                        <strong>{{ user.username }}</strong>
                        <span class="item-detail">{{ user.email }}</span>
                    </div>
                    <div class="item-meta">
                        <span class="item-date">{{ user.created_at|date('M d, Y') }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="empty-state">No users registered yet.</p>
            {% endif %}
        </section>
    </div>

    <!-- Status Overview -->
    <section class="status-overview">
        <h2>Reservation Status Overview</h2>
        <div class="status-bars">
            <div class="status-bar-item">
                <div class="status-bar-header">
                    <span>Pending</span>
                    <span>{{ stats.pending_reservations }}</span>
                </div>
                <div class="status-bar">
                    <div class="status-bar-fill pending" style="width: {{ stats.total_reservations > 0 ? (stats.pending_reservations / stats.total_reservations * 100) : 0 }}%"></div>
                </div>
            </div>
            <div class="status-bar-item">
                <div class="status-bar-header">
                    <span>Confirmed</span>
                    <span>{{ stats.confirmed_reservations }}</span>
                </div>
                <div class="status-bar">
                    <div class="status-bar-fill confirmed" style="width: {{ stats.total_reservations > 0 ? (stats.confirmed_reservations / stats.total_reservations * 100) : 0 }}%"></div>
                </div>
            </div>
            <div class="status-bar-item">
                <div class="status-bar-header">
                    <span>Cancelled</span>
                    <span>{{ stats.cancelled_reservations }}</span>
                </div>
                <div class="status-bar">
                    <div class="status-bar-fill cancelled" style="width: {{ stats.total_reservations > 0 ? (stats.cancelled_reservations / stats.total_reservations * 100) : 0 }}%"></div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
.admin-dashboard {
    padding: 30px 20px;
}

.dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.dashboard-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.dashboard-header .lead {
    margin: 0;
    color: var(--text-muted);
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.stat-card {
    background: linear-gradient(145deg, rgba(27, 38, 56, 0.9), rgba(35, 47, 75, 0.8));
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--amazon-orange), var(--amazon-orange-soft));
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
}

.stat-icon {
    font-size: 2rem;
}

.stat-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
}

.stat-label {
    font-size: 0.9rem;
    color: var(--text-muted);
}

.stat-link {
    font-size: 0.85rem;
    color: var(--amazon-orange);
    text-decoration: none;
    font-weight: 600;
}

.stat-link:hover {
    text-decoration: underline;
}

/* Quick Actions */
.quick-actions {
    margin-bottom: 40px;
}

.quick-actions h2 {
    margin: 0 0 20px 0;
    font-size: 1.5rem;
}

.actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
}

.action-card {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 12px;
    padding: 20px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 0.3s ease;
}

.action-card:hover {
    border-color: var(--amazon-orange);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(255, 153, 0, 0.15);
}

.action-icon {
    font-size: 1.8rem;
}

.action-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
}

.action-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
}

/* Recent Sections */
.recent-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
}

.recent-section {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    padding: 24px;
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.section-header h2 {
    margin: 0;
    font-size: 1.3rem;
}

.view-all {
    color: var(--amazon-orange);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
}

.view-all:hover {
    text-decoration: underline;
}

.recent-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.recent-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    background: rgba(15, 23, 34, 0.5);
    border-radius: 8px;
    gap: 12px;
}

.item-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
}

.item-info strong {
    color: var(--text-primary);
    font-size: 0.95rem;
}

.item-detail {
    color: var(--text-muted);
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.item-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
}

.item-price {
    color: var(--amazon-orange);
    font-weight: 700;
}

.item-date {
    color: var(--text-muted);
    font-size: 0.85rem;
}

.empty-state {
    text-align: center;
    color: var(--text-muted);
    padding: 30px;
}

/* Status Overview */
.status-overview {
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
    padding: 24px;
}

.status-overview h2 {
    margin: 0 0 20px 0;
    font-size: 1.3rem;
}

.status-bars {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.status-bar-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.status-bar-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
}

.status-bar-header span:first-child {
    color: var(--text-primary);
    font-weight: 600;
}

.status-bar-header span:last-child {
    color: var(--text-muted);
}

.status-bar {
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    overflow: hidden;
}

.status-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
}

.status-bar-fill.pending {
    background: linear-gradient(90deg, #ffc107, #ffdb4d);
}

.status-bar-fill.confirmed {
    background: linear-gradient(90deg, #16a34a, #22c55e);
}

.status-bar-fill.cancelled {
    background: linear-gradient(90deg, #dc2626, #ef4444);
}

/* Responsive */
@media (max-width: 768px) {
    .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .recent-sections {
        grid-template-columns: 1fr;
    }
    
    .recent-item {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .item-meta {
        align-items: flex-start;
        flex-direction: row;
        gap: 12px;
    }
}
</style>
{% endblock %}