{% extends 'admin/_layout.html.twig' %}
{% set active_section = 'dashboard' %}
{% block title %}Dashboard | Evec Tours Admin{% endblock %}

{% block admin_body %}
<div class="dash">
  <!-- Header -->
  <div class="dash-header">
    <div>
      <h1>Dashboard</h1>
      <p class="lead">Welcome back! Here's an overview of Evec Tours.</p>
    </div>
    <div class="dash-header-actions">
      <a href="{{ path('admin_voyage_new') }}" class="btn btn-primary">✈️ Add Voyage</a>
      <a href="{{ path('admin_reservations') }}" class="btn btn-secondary">📋 Reservations</a>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="stats-grid">
    <a href="{{ path('admin_users') }}" class="stat-card" style="--accent:#4a9eff">
      <div class="stat-icon">👥</div>
      <div class="stat-body">
        <span class="stat-val">{{ stats.total_users }}</span>
        <span class="stat-lbl">Total Users</span>
      </div>
    </a>

    <a href="{{ path('travel_voyages') }}" class="stat-card" style="--accent:#f5c300">
      <div class="stat-icon">✈️</div>
      <div class="stat-body">
        <span class="stat-val">{{ stats.total_voyages }}</span>
        <span class="stat-lbl">Active Voyages</span>
      </div>
    </a>

    <a href="{{ path('admin_reservations') }}" class="stat-card" style="--accent:#22c55e">
      <div class="stat-icon">📋</div>
      <div class="stat-body">
        <span class="stat-val">{{ stats.total_reservations }}</span>
        <span class="stat-lbl">Total Bookings</span>
      </div>
    </a>

    <a href="{{ path('admin_reservations') }}?status=PENDING" class="stat-card" style="--accent:#fbbf24">
      <div class="stat-icon">⏳</div>
      <div class="stat-body">
        <span class="stat-val">{{ stats.pending_reservations }}</span>
        <span class="stat-lbl">Pending</span>
      </div>
    </a>

    <div class="stat-card" style="--accent:#10b981">
      <div class="stat-icon">✅</div>
      <div class="stat-body">
        <span class="stat-val">{{ stats.confirmed_reservations }}</span>
        <span class="stat-lbl">Confirmed</span>
      </div>
    </div>

    <div class="stat-card" style="--accent:#f5c300">
      <div class="stat-icon">💰</div>
      <div class="stat-body">
        <span class="stat-val">{{ stats.total_revenue|number_format(0) }} TND</span>
        <span class="stat-lbl">Total Revenue</span>
      </div>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="recent-row">
    <!-- Recent Reservations -->
    <section class="recent-card">
      <div class="recent-head">
        <h2>Recent Bookings</h2>
        <a href="{{ path('admin_reservations') }}" class="view-all">View All →</a>
      </div>
      {% if recent_reservations|length > 0 %}
        {% for r in recent_reservations %}
        <div class="recent-item">
          <div class="ri-left">
            <strong>{{ r.user_name ?? 'Unknown' }}</strong>
            <span>{{ r.voyage_title ?? ('Voyage #' ~ r.voyage_id) }}</span>
          </div>
          <div class="ri-right">
            <span class="ri-price">{{ r.total_price|number_format(0) }} TND</span>
            <span class="status status-{{ r.status|lower }}">{{ r.status }}</span>
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p class="empty-note">No bookings yet.</p>
      {% endif %}
    </section>

    <!-- Recent Users -->
    <section class="recent-card">
      <div class="recent-head">
        <h2>Recent Users</h2>
        <a href="{{ path('admin_users') }}" class="view-all">View All →</a>
      </div>
      {% if recent_users|length > 0 %}
        {% for u in recent_users %}
        <div class="recent-item">
          <div class="ri-left">
            <div class="ri-avatar">{{ u.username|first|upper }}</div>
            <div>
              <strong>{{ u.username }}</strong>
              <span>{{ u.email }}</span>
            </div>
          </div>
          <div class="ri-right">
            {% if u.is_admin ?? false %}
              <span class="role-badge admin">Admin</span>
            {% else %}
              <span class="role-badge user">User</span>
            {% endif %}
            <span class="ri-date">{{ u.created_at ? u.created_at|date('d M Y') : '' }}</span>
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p class="empty-note">No users yet.</p>
      {% endif %}
    </section>
  </div>

  <!-- Booking Status Bars -->
  <section class="status-panel">
    <h2>Booking Status Overview</h2>
    {% set total = stats.total_reservations > 0 ? stats.total_reservations : 1 %}
    <div class="status-bars">
      <div class="sb-item">
        <div class="sb-row">
          <span>Pending</span>
          <span>{{ stats.pending_reservations }}</span>
        </div>
        <div class="sb-track"><div class="sb-fill pending" style="width:{{ (stats.pending_reservations / total * 100)|round }}%"></div></div>
      </div>
      <div class="sb-item">
        <div class="sb-row">
          <span>Confirmed</span>
          <span>{{ stats.confirmed_reservations }}</span>
        </div>
        <div class="sb-track"><div class="sb-fill confirmed" style="width:{{ (stats.confirmed_reservations / total * 100)|round }}%"></div></div>
      </div>
      <div class="sb-item">
        <div class="sb-row">
          <span>Cancelled</span>
          <span>{{ stats.cancelled_reservations }}</span>
        </div>
        <div class="sb-track"><div class="sb-fill cancelled" style="width:{{ (stats.cancelled_reservations / total * 100)|round }}%"></div></div>
      </div>
    </div>
  </section>
</div>

<style>
.dash { max-width: 1100px; }

/* Header */
.dash-header { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px; margin-bottom:28px; }
.dash-header h1 { margin:0 0 4px; font-size:1.8rem; }
.dash-header .lead { margin:0; color:var(--text-muted); }
.dash-header-actions { display:flex; gap:12px; flex-wrap:wrap; }

/* Stats */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
  gap: 16px;
  margin-bottom: 32px;
}

.stat-card {
  background: linear-gradient(145deg, #080e1c, #0d1a30);
  border: 1px solid var(--border-dark);
  border-radius: 14px;
  padding: 20px;
  display: flex;
  gap: 14px;
  align-items: center;
  position: relative;
  overflow: hidden;
  text-decoration: none;
  transition: transform .2s, box-shadow .2s;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--accent, var(--amazon-orange));
}

.stat-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(0,0,0,.35);
}

.stat-icon { font-size: 1.8rem; flex-shrink:0; }
.stat-body { display:flex; flex-direction:column; gap:2px; }
.stat-val { font-size:1.6rem; font-weight:800; color:#fff; line-height:1; }
.stat-lbl { font-size:.82rem; color:var(--text-muted); }

/* Recent row */
.recent-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}

.recent-card {
  background: #080e1c;
  border: 1px solid var(--border-dark);
  border-radius: 14px;
  padding: 20px;
}

.recent-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.recent-head h2 { margin:0; font-size:1.1rem; }

.view-all {
  color: var(--amazon-orange);
  font-size: .85rem;
  font-weight:600;
  text-decoration: none;
}
.view-all:hover { text-decoration: underline; }

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  border-radius: 9px;
  background: rgba(255,255,255,.03);
  margin-bottom: 8px;
  gap: 12px;
}
.recent-item:last-child { margin-bottom:0; }

.ri-left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}
.ri-left strong { display:block; color:var(--text-primary); font-size:.9rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:140px; }
.ri-left span { display:block; color:var(--text-muted); font-size:.8rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:140px; }

.ri-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}

.ri-price { color:var(--amazon-orange); font-weight:700; font-size:.9rem; white-space:nowrap; }
.ri-date { color:var(--text-muted); font-size:.78rem; white-space:nowrap; }

.ri-avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--evec-blue), var(--evec-blue-light));
  display: flex; align-items:center; justify-content:center;
  font-weight:700; color:#fff; font-size:.9rem;
  flex-shrink: 0;
}

.role-badge { display:inline-block; padding:2px 8px; border-radius:5px; font-size:.72rem; font-weight:700; text-transform:uppercase; }
.role-badge.admin { background:rgba(245,195,0,.15); color:var(--amazon-orange-soft); }
.role-badge.user  { background:rgba(74,158,255,.15); color:var(--evec-blue-light); }

.empty-note { color:var(--text-muted); text-align:center; padding:20px; font-size:.9rem; }

/* Status panel */
.status-panel {
  background: #080e1c;
  border: 1px solid var(--border-dark);
  border-radius: 14px;
  padding: 20px 24px;
}
.status-panel h2 { margin:0 0 20px; font-size:1.1rem; }

.status-bars { display:flex; flex-direction:column; gap:14px; }
.sb-item { display:flex; flex-direction:column; gap:6px; }
.sb-row { display:flex; justify-content:space-between; font-size:.88rem; }
.sb-row span:first-child { color:var(--text-primary); font-weight:600; }
.sb-row span:last-child { color:var(--text-muted); }
.sb-track { height:8px; background:rgba(255,255,255,.08); border-radius:4px; overflow:hidden; }
.sb-fill { height:100%; border-radius:4px; transition: width .6s ease; }
.sb-fill.pending   { background: linear-gradient(90deg,#fbbf24,#fde68a); }
.sb-fill.confirmed { background: linear-gradient(90deg,#10b981,#34d399); }
.sb-fill.cancelled { background: linear-gradient(90deg,#ef4444,#f87171); }

@media (max-width:640px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .dash-header { flex-direction:column; align-items:flex-start; }
}
</style>
{% endblock %}
