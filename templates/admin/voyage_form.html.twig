{% extends 'base.html.twig' %}

{% block title %}{% if voyage %}Edit Voyage{% else %}New Voyage{% endif %} | Admin{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="page-header">
        <div class="header-content">
            <h1>{% if voyage %}Edit Voyage{% else %}Create New Voyage{% endif %}</h1>
            <p class="lead">{% if voyage %}Update voyage details{% else %}Add a new travel package{% endif %}</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_voyages') }}" class="btn btn-secondary">
                ← Back to Voyages
            </a>
        </div>
    </div>

    <div class="form-container">
        <form method="post" class="admin-form">
            <div class="form-group">
                <label for="title">Title *</label>
                <input type="text" id="title" name="title" value="{{ voyage.title|default('') }}" required class="form-control">
            </div>

            <div class="form-group">
                <label for="destination">Destination *</label>
                <input type="text" id="destination" name="destination" value="{{ voyage.destination|default('') }}" required class="form-control">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="price">Price ($)</label>
                    <input type="number" id="price" name="price" value="{{ voyage.price|default('') }}" step="0.01" min="0" class="form-control">
                </div>

                <div class="form-group">
                    <label for="start_date">Start Date</label>
                    <input type="date" id="start_date" name="start_date" value="{{ voyage.start_date|default('') }}" class="form-control">
                </div>

                <div class="form-group">
                    <label for="end_date">End Date</label>
                    <input type="date" id="end_date" name="end_date" value="{{ voyage.end_date|default('') }}" class="form-control">
                </div>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" class="form-control">{{ voyage.description|default('') }}</textarea>
            </div>

            <div class="form-group">
                <label for="image_url">Image URLs (one per line)</label>
                <textarea id="image_url" name="image_url" rows="4" class="form-control" placeholder="https://example.com/image1.jpg&#10;https://example.com/image2.jpg">{% if voyage and voyage.image_url %}{{ voyage.image_url|join('\n') }}{% endif %}</textarea>
                <small class="form-hint">Enter each image URL on a new line</small>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    {% if voyage %}Update Voyage{% else %}Create Voyage{% endif %}
                </button>
                <a href="{{ path('admin_voyages') }}" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<style>
.admin-page {
    padding: 30px 20px;
    max-width: 800px;
    margin: 0 auto;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-actions {
    display: flex;
    gap: 12px;
}

.btn {
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
}

.btn-primary {
    background: var(--amazon-orange);
    color: #000;
}

.btn-primary:hover {
    background: #e68a00;
}

.btn-secondary {
    background: var(--amazon-white);
    color: var(--text-primary);
    border: 1px solid var(--border-dark);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
}

.form-container {
    background: var(--amazon-white);
    border-radius: 12px;
    padding: 30px;
    border: 1px solid var(--border-dark);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--text-primary);
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    background: rgba(15, 23, 34, 0.5);
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.form-control:focus {
    outline: none;
    border-color: var(--amazon-orange);
    box-shadow: 0 0 0 3px rgba(255, 153, 0, 0.15);
}

.form-control::placeholder {
    color: var(--text-muted);
}

textarea.form-control {
    resize: vertical;
    min-height: 100px;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.form-hint {
    display: block;
    margin-top: 6px;
    color: var(--text-muted);
    font-size: 0.85rem;
}

.form-actions {
    display: flex;
    gap: 12px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}
</style>
{% endblock %}