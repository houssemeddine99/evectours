<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Ticket #{{ reservation.id }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, Helvetica, sans-serif; background: #fff; color: #1a1a2e; font-size: 13px; }

        .ticket { border: 2px solid #1a1a2e; border-radius: 12px; overflow: hidden; max-width: 680px; margin: 20px auto; }

        .ticket-header { background: #1a1a2e; color: white; padding: 24px 32px; display: table; width: 100%; }
        .header-left { display: table-cell; vertical-align: middle; }
        .header-right { display: table-cell; vertical-align: middle; text-align: right; }
        .header-left h1 { font-size: 22px; letter-spacing: 3px; }
        .header-left p { font-size: 11px; color: #aaa; margin-top: 4px; }
        .status-badge { background: #22c55e; color: white; padding: 5px 14px; border-radius: 20px; font-size: 11px; font-weight: bold; }
        .ticket-num { font-size: 11px; color: #aaa; margin-top: 6px; }

        .ticket-body { padding: 24px 32px; }
        .fields-grid { display: table; width: 100%; border-collapse: collapse; }
        .field-row { display: table-row; }
        .field-cell { display: table-cell; width: 50%; padding: 10px 0; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
        .field-label { font-size: 9px; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-bottom: 4px; }
        .field-value { font-size: 14px; font-weight: bold; color: #1a1a2e; }

        .ticket-footer { background: #f8fafc; border-top: 2px dashed #e2e8f0; padding: 20px 32px; display: table; width: 100%; }
        .footer-left { display: table-cell; vertical-align: middle; text-align: center; width: 140px; }
        .footer-center { display: table-cell; vertical-align: middle; text-align: center; }
        .footer-right { display: table-cell; vertical-align: middle; text-align: right; }

        .qr-img { width: 100px; height: 100px; border: 2px solid #e2e8f0; border-radius: 6px; }
        .qr-label { font-size: 9px; color: #64748b; margin-top: 4px; }

        .carbon-badge { display: inline-block; padding: 4px 10px; border-radius: 12px; font-size: 10px; font-weight: bold; }

        .price-label { font-size: 10px; color: #64748b; margin-bottom: 4px; }
        .price-value { font-size: 24px; font-weight: bold; color: #0f3460; }
        .price-ref { font-size: 10px; color: #64748b; margin-top: 4px; }

        .barcode { text-align: center; padding: 12px 32px; border-top: 1px solid #e2e8f0; font-family: monospace; font-size: 10px; letter-spacing: 5px; color: #94a3b8; }
    </style>
</head>
<body>
<div class="ticket">
    <div class="ticket-header">
        <div class="header-left">
            <h1>✈ TRAVAGIR</h1>
            <p>Official Travel Confirmation</p>
        </div>
        <div class="header-right">
            <div class="status-badge">✓ CONFIRMED</div>
            <div class="ticket-num">Ticket #{{ reservation.id }}</div>
        </div>
    </div>

    <div class="ticket-body">
        <div class="fields-grid">
            <div class="field-row">
                <div class="field-cell">
                    <div class="field-label">Voyage</div>
                    <div class="field-value">{{ reservation.voyage_title|default('—') }}</div>
                </div>
                <div class="field-cell">
                    <div class="field-label">Destination</div>
                    <div class="field-value">{{ reservation.destination|default('—') }}</div>
                </div>
            </div>
            <div class="field-row">
                <div class="field-cell">
                    <div class="field-label">Departure</div>
                    <div class="field-value">{{ reservation.voyage_start ? reservation.voyage_start|date('d M Y') : 'TBD' }}</div>
                </div>
                <div class="field-cell">
                    <div class="field-label">Return</div>
                    <div class="field-value">{{ reservation.voyage_end ? reservation.voyage_end|date('d M Y') : 'TBD' }}</div>
                </div>
            </div>
            <div class="field-row">
                <div class="field-cell">
                    <div class="field-label">Passengers</div>
                    <div class="field-value">{{ reservation.number_of_people }} person{{ reservation.number_of_people > 1 ? 's' : '' }}</div>
                </div>
                <div class="field-cell">
                    <div class="field-label">Booked On</div>
                    <div class="field-value">{{ reservation.reservation_date ? reservation.reservation_date|date('d M Y') : '—' }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="ticket-footer">
        <div class="footer-left">
            <img class="qr-img" src="{{ qr_url }}" alt="QR">
            <div class="qr-label">Scan to verify</div>
        </div>
        <div class="footer-center">
            {% if carbon %}
                <div class="carbon-badge" style="background:{{ carbon.color }}22;color:{{ carbon.color }};border:1px solid {{ carbon.color }}66;">
                    {{ carbon.badge }} {{ carbon.label }} · {{ carbon.co2_per_person }} kg CO₂/person
                </div>
            {% endif %}
        </div>
        <div class="footer-right">
            <div class="price-label">Total Amount Paid</div>
            <div class="price-value">{{ reservation.total_price|number_format(2, '.', ',') }} TND</div>
            <div class="price-ref">Ref: {{ reservation.payment_reference|default('N/A') }}</div>
        </div>
    </div>

    <div class="barcode">| TRV-{{ reservation.id }}-{{ reservation.voyage_id }}-{{ reservation.user_id ?? '??' }} |</div>
</div>
</body>
</html>
