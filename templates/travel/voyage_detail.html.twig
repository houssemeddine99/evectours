{% extends 'base.html.twig' %}

{% block title %}{{ voyage.title|default('Voyage details') }} | Travagir{% endblock %}

{% block body %}
    <section class="voyage-hero">
        <div class="hero-overlay"></div>
        <div class="voyage-gallery-section">
            <div class="image-gallery">
                {% set images = voyage.image_url|default([]) %}
                {% if images is iterable and images|length > 0 %}
                    <div class="gallery-container">
                        <div class="gallery-main" style="background: linear-gradient(135deg, #0a0f1c 0%, #1a2f4a 100%);">
                            <img src="{{ images[0] }}" alt="{{ voyage.title|default('Voyage image') }}" class="voyage-hero-image" id="mainImage">
                            <div class="gallery-gradient-overlay"></div>
                            {% if images|length > 1 %}
                                <button class="gallery-nav gallery-prev" onclick="changeImage(-1)" aria-label="Previous image">❮</button>
                                <button class="gallery-nav gallery-next" onclick="changeImage(1)" aria-label="Next image">❯</button>
                                <div class="image-counter" id="imageCounter">1 / {{ images|length }}</div>
                            {% endif %}
                        </div>
                        {% if images|length > 1 %}
                            <div class="gallery-thumbnails">
                                {% for image in images %}
                                    <img src="{{ image }}" alt="Thumbnail {{ loop.index }}" class="thumbnail {% if loop.first %}active{% endif %}" onclick="selectImage({{ loop.index0 }})">
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="gallery-container">
                        <div class="gallery-main" style="background: linear-gradient(135deg, #0a0f1c 0%, #1a2f4a 100%);">
                            <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=1200&q=80" alt="{{ voyage.title|default('Voyage image') }}" class="voyage-hero-image">
                            <div class="gallery-gradient-overlay"></div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    <section class="voyage-detail-container">
        <div class="voyage-detail-wrapper">
            <div class="voyage-main-card">
                <div class="voyage-header-section">
                    <div class="voyage-headline-enhanced">
                        <div class="headline-content">
                            <p class="meta-location">
                                {% if country_info is defined and country_info and country_info.flag_emoji %}
                                    {{ country_info.flag_emoji }}
                                {% else %}
                                    🌍
                                {% endif %}
                                {{ voyage.destination|default('') }}
                            </p>
                            <h1 class="voyage-title-premium">{{ voyage.title|default('') }}</h1>
                            <p class="voyage-tagline">Discover unforgettable experiences in your next adventure</p>
                            {% if voyage.tags is defined and voyage.tags|length > 0 %}
                                <div class="detail-tags">
                                    {% for tag in voyage.tags %}
                                        <a href="{{ path('travel_voyages', {tag: tag.name}) }}" class="tag-pill" style="border-color:{{ tag.color ?? '#ff9900' }};color:{{ tag.color ?? '#ff9900' }}">{{ tag.name }}</a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="voyage-date-badge">
                            <span class="badge-icon">📅</span>
                            <span class="badge-text">{{ voyage.start_date ? voyage.start_date|date('d M Y') : 'TBD' }} → {{ voyage.end_date ? voyage.end_date|date('d M Y') : 'TBD' }}</span>
                        </div>
                    </div>

                    <div class="voyage-quick-info">
                        <div class="info-card">
                            <span class="info-icon">💰</span>
                            <div class="info-content">
                                <p class="info-label">Starting Price</p>
                                <p class="info-value">{{ voyage.price is not empty ? '$' ~ voyage.price|number_format(2, '.', ',') : 'Contact us' }}</p>
                                {% if offer is defined and offer %}
                                    <p class="offer-badge">🎉 {{ offer.discount_percentage }}% OFF</p>
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-card">
                            <span class="info-icon">⏱️</span>
                            <div class="info-content">
                                <p class="info-label">Duration</p>
                                <p class="info-value">{{ duration_days }} day{{ duration_days != 1 ? 's' : '' }}</p>
                            </div>
                        </div>
                        <div class="info-card">
                            <span class="info-icon">✈️</span>
                            <div class="info-content">
                                <p class="info-label">Voyage Type</p>
                                <p class="info-value">Premium</p>
                            </div>
                        </div>
                    </div>
                </div>

                {# Country Info Section #}
                {% if country_info is defined and country_info %}
                <div class="country-info-section">
                    <h2 class="section-title">🗺 Destination Info</h2>
                    <div class="country-grid">
                        {% if country_info.flag_svg %}
                            <div class="country-flag-wrap">
                                <img src="{{ country_info.flag_svg }}" alt="{{ country_info.name }} flag" class="country-flag">
                            </div>
                        {% endif %}
                        <div class="country-facts">
                            <div class="fact-item"><span class="fact-icon">🏳</span><span class="fact-label">Country</span><span class="fact-value">{{ country_info.name }}</span></div>
                            {% if country_info.capital %}<div class="fact-item"><span class="fact-icon">🏛</span><span class="fact-label">Capital</span><span class="fact-value">{{ country_info.capital }}</span></div>{% endif %}
                            {% if country_info.language %}<div class="fact-item"><span class="fact-icon">💬</span><span class="fact-label">Language</span><span class="fact-value">{{ country_info.language }}</span></div>{% endif %}
                            {% if country_info.currency %}<div class="fact-item"><span class="fact-icon">💱</span><span class="fact-label">Currency</span><span class="fact-value">{{ country_info.currency }}</span></div>{% endif %}
                            {% if country_info.timezone %}<div class="fact-item"><span class="fact-icon">🕐</span><span class="fact-label">Timezone</span><span class="fact-value">{{ country_info.timezone }}</span></div>{% endif %}
                        </div>
                    </div>
                </div>
                <div class="voyage-separator"></div>
                {% endif %}

                <div class="voyage-separator"></div>

                {% if offer is defined and offer %}
                <div class="voyage-offer-section">
                    <div class="offer-banner">
                        <div class="offer-badge-large">🎉 Special Offer Available!</div>
                        <h3 class="offer-title">{{ offer.title }}</h3>
                        <p class="offer-description">{{ offer.description|default('Limited time offer for this voyage!') }}</p>
                        <div class="offer-details">
                            <span class="offer-discount"><strong>{{ offer.discount_percentage }}% Discount</strong></span>
                            {% if offer.end_date %}
                                <span class="offer-expiry">Expires on {{ offer.end_date|date('d M Y') }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="voyage-separator"></div>
                {% endif %}

                <div class="voyage-description-section">
                    <h2 class="section-title">About This Journey</h2>
                    <p class="voyage-description">{{ voyage.description|default('No description available yet. Please check the full itinerary for more details.') }}</p>
                </div>

                {# AI Itinerary Section #}
                <div class="voyage-itinerary-section">
                    <div class="itinerary-header">
                        <h2 class="section-title">🗓 AI Itinerary Preview</h2>
                        <button id="loadItineraryBtn" class="btn-itinerary" onclick="loadItinerary()">Generate Itinerary</button>
                    </div>
                    <div id="itineraryContent" class="itinerary-content" style="display:none"></div>
                    <div id="itineraryLoading" class="itinerary-loading" style="display:none">✨ Generating your itinerary…</div>
                </div>

                <div class="voyage-separator"></div>

                {% if voyage.activities|default([]) is not empty %}
                <div class="voyage-activities-section">
                    <h2 class="section-title">✨ Included Activities</h2>
                    <div class="activities-grid">
                        {% for activity in voyage.activities %}
                            <div class="activity-card">
                                <div class="activity-header">
                                    <h3>{{ activity.name|default('Activity') }}</h3>
                                    <span class="activity-duration">⏱ {{ activity.duration_hours ?? 'N/A' }}h</span>
                                </div>
                                <p class="activity-description">{{ activity.description|default('Description not available.') }}</p>
                                <div class="activity-footer">
                                    <span class="activity-price">{{ activity.price_per_person is not empty ? '$' ~ activity.price_per_person|number_format(2, '.', ',') : 'Included' }}</span>
                                    <span class="activity-label">per person</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                <div class="voyage-actions">
                    <a class="btn btn-primary btn-reserve" href="{{ path('travel_voyage_reserve', {id: voyage.id}) }}">
                        <span class="btn-text">Reserve Your Spot</span>
                        <span class="btn-arrow">→</span>
                    </a>
                    <button class="btn btn-fav {% if is_favorite %}btn-fav-active{% endif %}" id="favBtn" onclick="toggleFavorite({{ voyage.id }})" title="{% if is_favorite %}Remove from favorites{% else %}Add to favorites{% endif %}">
                        {{ is_favorite ? '♥ Saved' : '♡ Save' }}
                    </button>
                    <button class="btn btn-compare" id="cmpBtn" onclick="toggleCompare({{ voyage.id }})" title="Add to comparison">
                        ⊕ Compare
                    </button>
                    <a class="btn btn-secondary btn-back" href="{{ path('travel_voyages') }}">
                        <span class="btn-text">Back to voyages</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script>
        const images = {{ voyage.image_url is iterable ? voyage.image_url|json_encode|raw : '[]' }};
        let currentImageIndex = 0;

        function changeImage(direction) {
            if (images.length <= 1) return;
            currentImageIndex = (currentImageIndex + direction + images.length) % images.length;
            updateImage();
        }

        function selectImage(index) {
            currentImageIndex = index;
            updateImage();
        }

        function updateImage() {
            const mainImage = document.getElementById('mainImage');
            const imageCounter = document.getElementById('imageCounter');
            const thumbnails = document.querySelectorAll('.thumbnail');
            if (mainImage) mainImage.src = images[currentImageIndex];
            if (imageCounter) imageCounter.textContent = (currentImageIndex + 1) + ' / ' + images.length;
            thumbnails.forEach((thumb, index) => thumb.classList.toggle('active', index === currentImageIndex));
        }

        document.addEventListener('keydown', function(e) {
            if (images.length <= 1) return;
            if (e.key === 'ArrowLeft') changeImage(-1);
            else if (e.key === 'ArrowRight') changeImage(1);
        });

        async function toggleFavorite(voyageId) {
            const btn = document.getElementById('favBtn');
            try {
                const res = await fetch('/favorites/toggle/' + voyageId, { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} });
                if (res.status === 401) { window.location.href = '/login'; return; }
                const data = await res.json();
                btn.classList.toggle('btn-fav-active', data.added);
                btn.textContent = data.added ? '♥ Saved' : '♡ Save';
            } catch(e) { console.error(e); }
        }

        async function toggleCompare(voyageId) {
            const btn = document.getElementById('cmpBtn');
            const inList = btn.classList.contains('cmp-active');
            const url = inList ? '/compare/remove/' + voyageId : '/compare/add/' + voyageId;
            try {
                const res = await fetch(url, { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} });
                const data = await res.json();
                if (res.ok) {
                    btn.classList.toggle('cmp-active', !inList);
                    btn.textContent = !inList ? '✓ In Compare' : '⊕ Compare';
                } else if (data.status === 'max_reached') {
                    alert('Max 3 voyages can be compared. Go to /compare to view.');
                }
            } catch(e) { console.error(e); }
        }

        async function loadItinerary() {
            const btn = document.getElementById('loadItineraryBtn');
            const content = document.getElementById('itineraryContent');
            const loading = document.getElementById('itineraryLoading');

            btn.style.display = 'none';
            loading.style.display = 'block';

            try {
                const res = await fetch('{{ path('voyage_ai_itinerary', {slug: voyage.slug}) }}');
                const data = await res.json();
                loading.style.display = 'none';
                if (data.itinerary) {
                    content.innerHTML = data.itinerary.split('\n').map(line => line.trim() ? '<p>' + line + '</p>' : '').join('');
                    content.style.display = 'block';
                } else {
                    content.innerHTML = '<p class="ai-error">Could not generate itinerary at this time.</p>';
                    content.style.display = 'block';
                }
            } catch(e) {
                loading.style.display = 'none';
                content.innerHTML = '<p class="ai-error">Network error.</p>';
                content.style.display = 'block';
            }
        }
    </script>

    <style>
        .country-info-section { margin: 24px 0; }
        .country-grid { display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap; background: rgba(255,255,255,.04); border: 1px solid var(--border-dark); border-radius: 12px; padding: 20px; }
        .country-flag-wrap { flex-shrink: 0; }
        .country-flag { width: 100px; height: 66px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border-dark); }
        .country-facts { display: flex; flex-wrap: wrap; gap: 12px; flex: 1; }
        .fact-item { display: flex; gap: 8px; align-items: center; background: rgba(255,255,255,.06); padding: 8px 14px; border-radius: 8px; font-size: .9rem; }
        .fact-icon { font-size: 1rem; }
        .fact-label { color: var(--text-muted); font-size: .82rem; }
        .fact-value { font-weight: 600; }
        .detail-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
        .tag-pill { display: inline-block; padding: 3px 12px; border-radius: 14px; border: 1px solid; font-size: .82rem; font-weight: 600; text-decoration: none; }
        .voyage-itinerary-section { margin: 28px 0; }
        .itinerary-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
        .btn-itinerary { background: linear-gradient(135deg,#6366f1,#8b5cf6); color: #fff; border: none; border-radius: 8px; padding: 9px 18px; cursor: pointer; font-weight: 600; font-size: .9rem; }
        .itinerary-content p { margin: 6px 0; line-height: 1.6; font-size: .95rem; }
        .itinerary-loading { color: var(--text-muted); font-style: italic; padding: 12px 0; }
        .ai-error { color: #ef4444; }
        .btn-fav { background: rgba(239,68,68,.15); color: #ef4444; border: 1px solid #ef4444; }
        .btn-fav-active,.btn-fav:hover { background: #ef4444; color: #fff; }
        .btn-compare { background: rgba(255,153,0,.15); color: var(--amazon-orange); border: 1px solid var(--amazon-orange); }
        .btn-compare.cmp-active,.btn-compare:hover { background: var(--amazon-orange); color: #000; }
        .voyage-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px; }
        .voyage-actions .btn { padding: 12px 24px; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 1rem; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    </style>
{% endblock %}
