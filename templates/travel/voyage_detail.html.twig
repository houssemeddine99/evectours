{% extends 'base.html.twig' %}

{% block stylesheets %}<link rel="stylesheet" href="/styles/voyage-detail.css">{% endblock %}
{% block title %}{{ voyage.title|default('Voyage details') }} | Evec Tours{% endblock %}
{% block meta_description %}{{ voyage.description|default('Discover ' ~ voyage.destination ~ ' with Evec Tours — curated voyages and exclusive travel offers.')|striptags|slice(0,160) }}{% endblock %}
{% block og_title %}{{ voyage.title|default('Voyage') }} — Evec Tours{% endblock %}
{% block og_description %}{{ voyage.description|default('Discover ' ~ voyage.destination ~ ' with Evec Tours.')|striptags|slice(0,200) }}{% endblock %}
{% block og_image %}{% set _img = voyage.image_url is iterable and voyage.image_url|length > 0 ? voyage.image_url[0] : '' %}{% if _img %}{{ _img }}{% else %}{{ parent() }}{% endif %}{% endblock %}
{% block twitter_title %}{{ voyage.title|default('Voyage') }} — Evec Tours{% endblock %}
{% block twitter_description %}{{ voyage.description|default('')|striptags|slice(0,200) }}{% endblock %}
{% block twitter_image %}{% set _img = voyage.image_url is iterable and voyage.image_url|length > 0 ? voyage.image_url[0] : '' %}{% if _img %}{{ _img }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block body %}
    <section class="voyage-hero">
        <div class="hero-overlay"></div>
        <div class="voyage-gallery-section">
            <div class="image-gallery">
                {% set images = voyage.image_url|default([]) %}
                {% if images is iterable and images|length > 0 %}
                    <div class="gallery-container">
                        <div class="gallery-main" style="background: linear-gradient(135deg, #0a0f1c 0%, #1a2f4a 100%);">
                            <img src="{{ images[0] }}" alt="{{ voyage.title|default('Voyage image') }}" class="voyage-hero-image" id="mainImage">
                            <div class="gallery-gradient-overlay"></div>
                            {% if images|length > 1 %}
                                <button class="gallery-nav gallery-prev" onclick="changeImage(-1)" aria-label="Previous image">❮</button>
                                <button class="gallery-nav gallery-next" onclick="changeImage(1)" aria-label="Next image">❯</button>
                                <div class="image-counter" id="imageCounter">1 / {{ images|length }}</div>
                            {% endif %}
                        </div>
                        {% if images|length > 1 %}
                            <div class="gallery-thumbnails">
                                {% for image in images %}
                                    <img src="{{ image }}" alt="Thumbnail {{ loop.index }}" class="thumbnail {% if loop.first %}active{% endif %}" onclick="selectImage({{ loop.index0 }})">
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% else %}
                    <div class="gallery-container">
                        <div class="gallery-main" style="background: linear-gradient(135deg, #0a0f1c 0%, #1a2f4a 100%);">
                            <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=1200&q=80" alt="{{ voyage.title|default('Voyage image') }}" class="voyage-hero-image">
                            <div class="gallery-gradient-overlay"></div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    <section class="voyage-detail-container">
        <div class="voyage-detail-wrapper">
            <div class="voyage-main-card">
                <div class="voyage-header-section">
                    <div class="voyage-headline-enhanced">
                        <div class="headline-content">
                            <p class="meta-location">
                                <span id="meta-flag">🌍</span>
                                {{ voyage.destination|default('') }}
                            </p>
                            <h1 class="voyage-title-premium">{{ voyage.title|default('') }}</h1>
                            <p class="voyage-tagline">Discover unforgettable experiences in your next adventure</p>
                        </div>
                        <div class="voyage-date-badge">
                            <span class="badge-icon">📅</span>
                            <span class="badge-text">{{ voyage.start_date ? voyage.start_date|date('d M Y') : 'TBD' }} → {{ voyage.end_date ? voyage.end_date|date('d M Y') : 'TBD' }}</span>
                        </div>
                    </div>

                    <div class="voyage-quick-info">
                        <div class="info-card">
                            <span class="info-icon">💰</span>
                            <div class="info-content">
                                <p class="info-label">Starting Price</p>
                                <p class="info-value">{{ voyage.price is not empty ? voyage.price|format_price : 'Contact us' }}</p>
                                {% if voyage.scarcity_label is defined and voyage.scarcity_label %}
                                    <span class="scarcity-badge scarcity-{{ voyage.scarcity_level }}">{{ voyage.scarcity_label }}</span>
                                {% endif %}
                                {% if offer is defined and offer %}
                                    <p class="offer-badge">🎉 {{ offer.discount_percentage }}% OFF</p>
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-card">
                            <span class="info-icon">⏱️</span>
                            <div class="info-content">
                                <p class="info-label">Duration</p>
                                <p class="info-value">{{ duration_days }} day{{ duration_days != 1 ? 's' : '' }}</p>
                            </div>
                        </div>
                        <div class="info-card">
                            <span class="info-icon">✈️</span>
                            <div class="info-content">
                                <p class="info-label">Voyage Type</p>
                                <p class="info-value">Premium</p>
                            </div>
                        </div>
                    </div>
                </div>

                {# Country Info Section — loaded async via /api/voyage-meta #}
                <div id="country-info-section">
                    <div class="country-info-skeleton">
                        <div class="skeleton-line skeleton-line--short"></div>
                        <div class="skeleton-line"></div>
                        <div class="skeleton-line"></div>
                    </div>
                </div>
                <div class="voyage-separator"></div>

                <div class="voyage-separator"></div>

                {% if offer is defined and offer %}
                <div class="voyage-offer-section">
                    <div class="offer-banner">
                        <div class="offer-badge-large">🎉 Special Offer Available!</div>
                        <h3 class="offer-title">{{ offer.title }}</h3>
                        <p class="offer-description">{{ offer.description|default('Limited time offer for this voyage!') }}</p>
                        <div class="offer-details">
                            <span class="offer-discount"><strong>{{ offer.discount_percentage }}% Discount</strong></span>
                            {% if offer.end_date %}
                                <span class="offer-expiry">Expires on {{ offer.end_date|date('d M Y') }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="voyage-separator"></div>
                {% endif %}

                <div class="voyage-description-section">
                    <div class="desc-section-header">
                        <h2 class="section-title">About This Journey</h2>
                        <button class="btn-listen" onclick="speakText('desc-text')">🔊 Listen</button>
                    </div>
                    <p class="voyage-description" id="desc-text">{{ voyage.description|default('No description available yet. Please check the full itinerary for more details.') }}</p>
                </div>

                {# AI Itinerary Section #}
                <div class="voyage-itinerary-section">
                    <div class="itinerary-header">
                        <h2 class="section-title">🗓 AI Itinerary Preview</h2>
                        <div class="itin-btn-group">
                            <button id="listenBtn" class="btn-listen" onclick="toggleListen()" style="display:none">🔊 Listen</button>
                            <button id="loadItineraryBtn" class="btn-itinerary" onclick="loadItinerary()">✨ Generate</button>
                        </div>
                    </div>
                    <div id="itineraryContent" class="itinerary-content" style="display:none"></div>
                    <div id="itineraryLoading" class="itinerary-loading" style="display:none">✨ Generating your itinerary…</div>
                </div>

                <div class="voyage-separator"></div>

                {% if voyage.activities|default([]) is not empty %}
                <div class="voyage-activities-section">
                    <h2 class="section-title">✨ Included Activities</h2>
                    <div class="activities-grid">
                        {% for activity in voyage.activities %}
                            <div class="activity-card">
                                <div class="activity-header">
                                    <h3>{{ activity.name|default('Activity') }}</h3>
                                    <span class="activity-duration">⏱ {{ activity.duration_hours ?? 'N/A' }}h</span>
                                </div>
                                <p class="activity-description">{{ activity.description|default('Description not available.') }}</p>
                                <div class="activity-footer">
                                    <span class="activity-price">{{ activity.price_per_person is not empty ? activity.price_per_person|format_price : 'Included' }}</span>
                                    <span class="activity-label">per person</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                <div class="voyage-actions">
                    <a class="btn btn-primary btn-reserve" href="{{ path('travel_voyage_reserve', {id: voyage.id}) }}">
                        <span class="btn-text">Reserve Your Spot</span>
                        <span class="btn-arrow">→</span>
                    </a>
                    <button class="btn btn-fav {% if is_favorite %}btn-fav-active{% endif %}" id="favBtn" onclick="toggleFavorite({{ voyage.id }})" title="{% if is_favorite %}Remove from favorites{% else %}Add to favorites{% endif %}">
                        {{ is_favorite ? '♥ Saved' : '♡ Save' }}
                    </button>
                    <a href="{{ path('compare_pick', {id: voyage.id}) }}" class="btn btn-compare" title="Compare with another voyage">
                        ⊕ Compare
                    </a>
                    <a class="btn btn-secondary btn-back" href="{{ path('travel_voyages') }}">
                        <span class="btn-text">Back to voyages</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    {# ======================== REVIEWS SECTION ======================== #}
    <section class="reviews-section">
        <div class="reviews-container">
            <div class="reviews-header">
                <h2 class="section-title">⭐ Traveller Reviews</h2>
                {% if review_count > 0 %}
                <div class="reviews-summary">
                    <span class="avg-rating">{{ review_avg|number_format(1) }}</span>
                    <span class="avg-stars">
                        {% for i in 1..5 %}
                            <span class="star {{ i <= review_avg|round ? 'star-filled' : (i - 0.5 <= review_avg ? 'star-half' : '') }}">★</span>
                        {% endfor %}
                    </span>
                    <span class="review-count">{{ review_count }} review{{ review_count != 1 ? 's' : '' }}</span>
                </div>
                {% endif %}
            </div>

            {# Review form #}
            {% if user_id > 1 %}
            <div class="review-form-card">
                <h3>{{ user_review ? 'Update Your Review' : 'Leave a Review' }}</h3>
                <form method="post" action="{{ path('voyage_submit_review', {id: voyage.id}) }}" class="review-form">
                    <div class="star-picker" id="starPicker">
                        {% for i in 1..5 %}
                        <input type="radio" name="rating" id="star{{ i }}" value="{{ i }}" {% if user_review and user_review.rating == i %}checked{% elseif not user_review and i == 5 %}checked{% endif %} class="star-radio">
                        <label for="star{{ i }}" title="{{ i }} star{{ i != 1 ? 's' : '' }}">★</label>
                        {% endfor %}
                    </div>
                    <textarea name="comment" class="review-textarea" placeholder="Share your experience (optional)" rows="3" maxlength="1000">{{ user_review ? user_review.comment : '' }}</textarea>
                    <button type="submit" class="btn btn-primary btn-review-submit">{{ user_review ? 'Update Review' : 'Submit Review' }}</button>
                </form>
            </div>
            {% else %}
            <p class="review-login-cta"><a href="{{ path('auth_login') }}">Log in</a> to leave a review.</p>
            {% endif %}

            {# Review list #}
            {% if reviews is not empty %}
            <div class="review-list">
                {% for review in reviews %}
                <div class="review-card {% if user_review and review.user_id == user_id %}review-card--own{% endif %}">
                    <div class="review-meta">
                        <span class="review-stars">
                            {% for i in 1..5 %}
                                <span class="{{ i <= review.rating ? 'star-filled' : 'star-empty' }}">★</span>
                            {% endfor %}
                        </span>
                        <span class="review-date">{{ review.created_at }}</span>
                        {% if user_review and review.user_id == user_id %}
                            <span class="review-own-badge">Your review</span>
                        {% endif %}
                    </div>
                    {% if review.comment %}
                    <p class="review-comment">{{ review.comment }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="no-reviews">No reviews yet. Be the first!</p>
            {% endif %}
        </div>
    </section>

    <script>
        const images = {{ voyage.image_url is iterable ? voyage.image_url|json_encode|raw : '[]' }};
        let currentImageIndex = 0;

        function changeImage(direction) {
            if (images.length <= 1) return;
            currentImageIndex = (currentImageIndex + direction + images.length) % images.length;
            updateImage();
        }

        function selectImage(index) {
            currentImageIndex = index;
            updateImage();
        }

        function updateImage() {
            const mainImage = document.getElementById('mainImage');
            const imageCounter = document.getElementById('imageCounter');
            const thumbnails = document.querySelectorAll('.thumbnail');
            if (mainImage) mainImage.src = images[currentImageIndex];
            if (imageCounter) imageCounter.textContent = (currentImageIndex + 1) + ' / ' + images.length;
            thumbnails.forEach((thumb, index) => thumb.classList.toggle('active', index === currentImageIndex));
        }

        document.addEventListener('keydown', function(e) {
            if (images.length <= 1) return;
            if (e.key === 'ArrowLeft') changeImage(-1);
            else if (e.key === 'ArrowRight') changeImage(1);
        });

        async function toggleFavorite(voyageId) {
            const btn = document.getElementById('favBtn');
            try {
                const res = await fetch('/favorites/toggle/' + voyageId, { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} });
                if (res.status === 401) { window.location.href = '/login'; return; }
                const data = await res.json();
                btn.classList.toggle('btn-fav-active', data.added);
                btn.textContent = data.added ? '♥ Saved' : '♡ Save';
            } catch(e) { console.error(e); }
        }

        async function toggleCompare(voyageId) {
            const btn = document.getElementById('cmpBtn');
            const inList = btn.classList.contains('cmp-active');
            const url = inList ? '/compare/remove/' + voyageId : '/compare/add/' + voyageId;
            try {
                const res = await fetch(url, { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} });
                const data = await res.json();
                if (res.ok) {
                    btn.classList.toggle('cmp-active', !inList);
                    btn.textContent = !inList ? '✓ In Compare' : '⊕ Compare';
                    if (!inList) {
                        if (typeof tgToast !== 'undefined') tgToast('Added to comparison — <a href="/compare" style="color:#fbbf24">View now →</a>', 'info', 5000);
                    }
                } else if (data.status === 'max_reached') {
                    if (typeof tgToast !== 'undefined') tgToast('Max 3 voyages. <a href="/compare" style="color:#fbbf24">View comparison →</a>', 'warning', 6000);
                }
            } catch(e) { console.error(e); }
        }

        function renderItinerary(text) {
            const lines = text.split('\n').filter(l => l.trim());
            return lines.map(line => {
                const m = line.match(/^Day\s+(\d+)\s*[:\-]\s*(.+)$/i);
                if (m) {
                    return `<div class="itin-day">
                        <span class="itin-badge">Day ${m[1]}</span>
                        <span class="itin-text">${m[2]}</span>
                    </div>`;
                }
                return `<div class="itin-dest">${line}</div>`;
            }).join('');
        }

        async function loadItinerary() {
            const btn = document.getElementById('loadItineraryBtn');
            const content = document.getElementById('itineraryContent');
            const loading = document.getElementById('itineraryLoading');
            const listenBtn = document.getElementById('listenBtn');

            btn.style.display = 'none';
            loading.style.display = 'block';

            try {
                const res = await fetch('{{ path('voyage_ai_itinerary', {slug: voyage.slug}) }}');
                const data = await res.json();
                loading.style.display = 'none';
                if (data.itinerary) {
                    content.innerHTML = renderItinerary(data.itinerary);
                    content.style.display = 'block';
                    listenBtn.style.display = 'inline-flex';
                } else {
                    content.innerHTML = '<p class="ai-error">Could not generate itinerary at this time.</p>';
                    content.style.display = 'block';
                }
            } catch(e) {
                loading.style.display = 'none';
                content.innerHTML = '<p class="ai-error">Network error.</p>';
                content.style.display = 'block';
            }
        }

        // ── TTS engine ────────────────────────────────────────────
        let _ttsBtn = null;

        function detectLang(text) {
            if (/[؀-ۿ]/.test(text)) return 'ar';
            if (/[一-鿿]/.test(text)) return 'zh-CN';
            if (/[Ѐ-ӿ]/.test(text)) return 'ru';
            return 'en-US';
        }

        function getBestVoice(lang) {
            const voices = window.speechSynthesis.getVoices();
            const base   = lang.split('-')[0];
            const ranked = ['Enhanced', 'Premium', 'Natural', 'Neural', 'Google', 'Microsoft'];
            for (const kw of ranked) {
                const v = voices.find(v => v.lang.startsWith(base) && v.name.includes(kw));
                if (v) return v;
            }
            return voices.find(v => v.lang.startsWith(base)) || null;
        }

        function speakText(elementId) {
            if (!window.speechSynthesis) { alert('Text-to-speech is not supported in your browser.'); return; }
            const el = document.getElementById(elementId);
            if (!el) return;

            // find the button that triggered this
            const btn = event.currentTarget;

            if (btn.dataset.playing === '1') {
                window.speechSynthesis.cancel();
                btn.dataset.playing = '0';
                btn.innerHTML = '🔊 Listen';
                return;
            }

            // stop any other playing
            window.speechSynthesis.cancel();
            document.querySelectorAll('[data-playing="1"]').forEach(b => { b.dataset.playing='0'; b.innerHTML='🔊 Listen'; });

            const text = el.innerText.trim();
            const lang = detectLang(text);
            const utt  = new SpeechSynthesisUtterance(text);
            utt.lang  = lang;
            utt.rate  = lang === 'ar' ? 0.85 : 0.92;
            utt.pitch = 1.05;

            // Wait for voices to load then pick best
            function doSpeak() {
                const voice = getBestVoice(lang);
                if (voice) utt.voice = voice;
                window.speechSynthesis.speak(utt);
                btn.dataset.playing = '1';
                btn.innerHTML = '⏹ Stop';
                utt.onend = () => { btn.dataset.playing = '0'; btn.innerHTML = '🔊 Listen'; };
            }

            if (window.speechSynthesis.getVoices().length > 0) {
                doSpeak();
            } else {
                window.speechSynthesis.onvoiceschanged = doSpeak;
            }
        }

        // Itinerary listen button wires to speakText
        function toggleListen() {
            speakText.call(document.getElementById('listenBtn'), { currentTarget: document.getElementById('listenBtn') });
            // override to use itineraryContent
            const btn = document.getElementById('listenBtn');
            if (!window.speechSynthesis) return;
            if (btn.dataset.playing === '1') {
                window.speechSynthesis.cancel();
                btn.dataset.playing = '0';
                btn.innerHTML = '🔊 Listen';
                return;
            }
            window.speechSynthesis.cancel();
            document.querySelectorAll('[data-playing="1"]').forEach(b => { b.dataset.playing='0'; b.innerHTML='🔊 Listen'; });
            const text = document.getElementById('itineraryContent').innerText.trim();
            const lang = detectLang(text);
            const utt  = new SpeechSynthesisUtterance(text);
            utt.lang  = lang;
            utt.rate  = lang === 'ar' ? 0.85 : 0.92;
            utt.pitch = 1.05;
            function doSpeak() {
                const voice = getBestVoice(lang);
                if (voice) utt.voice = voice;
                window.speechSynthesis.speak(utt);
                btn.dataset.playing = '1';
                btn.innerHTML = '⏹ Stop';
                utt.onend = () => { btn.dataset.playing='0'; btn.innerHTML='🔊 Listen'; };
            }
            if (window.speechSynthesis.getVoices().length > 0) doSpeak();
            else window.speechSynthesis.onvoiceschanged = doSpeak;
        }
    </script>

    <script>
    (function () {
        var destination = {{ voyage.destination|json_encode|raw }};

        fetch('/api/voyage-meta?destination=' + encodeURIComponent(destination))
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
                // Update flag emoji in header
                var flagEl = document.getElementById('meta-flag');
                if (flagEl && data && data.flag_emoji) {
                    flagEl.textContent = data.flag_emoji;
                }

                var section = document.getElementById('country-info-section');
                if (!section) return;

                if (!data) {
                    section.innerHTML = '';
                    return;
                }

                var flagImg = data.flag_svg
                    ? '<div class="country-flag-wrap"><img src="' + escHtml(data.flag_svg) + '" alt="' + escHtml(data.name) + ' flag" class="country-flag"></div>'
                    : '';

                var facts = '<div class="fact-item"><span class="fact-icon">🏳</span><span class="fact-label">Country</span><span class="fact-value">' + escHtml(data.name) + '</span></div>';
                if (data.capital)  facts += '<div class="fact-item"><span class="fact-icon">🏛</span><span class="fact-label">Capital</span><span class="fact-value">'  + escHtml(data.capital)  + '</span></div>';
                if (data.language) facts += '<div class="fact-item"><span class="fact-icon">💬</span><span class="fact-label">Language</span><span class="fact-value">' + escHtml(data.language) + '</span></div>';
                if (data.currency) facts += '<div class="fact-item"><span class="fact-icon">💱</span><span class="fact-label">Currency</span><span class="fact-value">' + escHtml(data.currency) + '</span></div>';
                if (data.timezone) facts += '<div class="fact-item"><span class="fact-icon">🕐</span><span class="fact-label">Timezone</span><span class="fact-value">' + escHtml(data.timezone) + '</span></div>';

                section.innerHTML =
                    '<div class="country-info-section">' +
                        '<h2 class="section-title">🗺 Destination Info</h2>' +
                        '<div class="country-grid">' + flagImg + '<div class="country-facts">' + facts + '</div></div>' +
                    '</div>';
            })
            .catch(function() {
                var section = document.getElementById('country-info-section');
                if (section) section.innerHTML = '';
            });

        function escHtml(str) {
            return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // Track this voyage as recently viewed
        {% set thumb = voyage.image_url is iterable and voyage.image_url|length > 0 ? voyage.image_url[0] : 'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=400&q=60' %}
        tgTrackVoyage(
            {{ voyage.id }},
            '{{ voyage.title|e('js') }}',
            '{{ thumb }}',
            '{{ url('travel_voyage_detail', {slug: voyage.slug}) }}'
        );
    })();
    </script>
{% endblock %}
