{% extends 'base.html.twig' %}

{% block title %}Evec Tours — Hôtels, Vols & Séjours en Tunisie au meilleur prix{% endblock %}
{% block meta_description %}Réservez vos hôtels, vols et séjours en Tunisie et dans le monde avec Evec Tours. Prix et disponibilités en direct, paiement sécurisé, support 24/7.{% endblock %}

{% set today  = "now"|date("Y-m-d") %}
{% set defIn  = "now"|date_modify("+14 days")|date("Y-m-d") %}
{% set defOut = "now"|date_modify("+17 days")|date("Y-m-d") %}
{% set defDep = "now"|date_modify("+30 days")|date("Y-m-d") %}
{% set popular = [
  {code:'HMM', name:'Hammamet',        img:'https://images.unsplash.com/photo-1590523278191-995cbcda646b?auto=format&fit=crop&w=800&q=80'},
  {code:'DJE', name:'Djerba',          img:'https://images.unsplash.com/photo-1518548419970-58e3b4079ab2?auto=format&fit=crop&w=800&q=80'},
  {code:'TN1', name:'Sousse / Kantaoui',img:'https://images.unsplash.com/photo-1512958789358-4ba50a4d2f6b?auto=format&fit=crop&w=800&q=80'},
  {code:'MIR', name:'Monastir – Skanès',img:'https://images.unsplash.com/photo-1533105079780-92b9be482077?auto=format&fit=crop&w=800&q=80'},
  {code:'TOE', name:'Tunis – Carthage', img:'https://images.unsplash.com/photo-1605540436563-5bca919ae766?auto=format&fit=crop&w=800&q=80'},
  {code:'MH1', name:'Mahdia',          img:'https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?auto=format&fit=crop&w=800&q=80'},
] %}

{% block body %}
<div class="pt-page">

  {# ── SEARCH HERO ── #}
  <section class="pt-hero">
    <div class="pt-hero-bg"></div>
    <div class="pt-hero-inner">
      <h1 class="pt-hero-title">Votre prochain voyage commence ici</h1>
      <p class="pt-hero-sub">Hôtels, vols et séjours — en Tunisie et dans le monde, au meilleur prix.</p>

      <div class="pt-box">
        <div class="pt-tabs">
          <button type="button" class="pt-tab active" data-tab="hotels">🏨 Hôtels</button>
          <button type="button" class="pt-tab" data-tab="flights">✈️ Vols</button>
          <button type="button" class="pt-tab" data-tab="stays">🧳 Séjours</button>
        </div>

        {# ---- Hôtels ---- #}
        <form class="pt-form" id="ptHotels" method="get" action="{{ path('travel_hotels') }}" autocomplete="off">
          <div class="pt-field pt-grow">
            <label>Destination</label><span class="pt-ic">📍</span>
            <input type="text" id="ptHDest" placeholder="Ville, région…" required>
            <input type="hidden" name="dest" id="ptHCode">
            <input type="hidden" name="dest_name" id="ptHName">
            <div class="pt-suggest" id="ptHSug" hidden></div>
          </div>
          <div class="pt-field"><label>Arrivée</label><span class="pt-ic">📅</span>
            <input type="date" name="checkIn" id="ptHIn" value="{{ defIn }}" min="{{ today }}" required></div>
          <div class="pt-field"><label>Départ</label><span class="pt-ic">📅</span>
            <input type="date" name="checkOut" id="ptHOut" value="{{ defOut }}" min="{{ today }}" required></div>
          <div class="pt-field pt-guests">
            <label>Voyageurs</label><span class="pt-ic">👤</span>
            <button type="button" class="pt-gbtn" id="ptGBtn"><span id="ptGLabel">2 adultes · 1 chambre</span></button>
            <div class="pt-gpop" id="ptGPop" hidden>
              {% for r in [{k:'adults',l:'Adultes',min:1,v:2},{k:'children',l:'Enfants',min:0,v:0},{k:'rooms',l:'Chambres',min:1,v:1}] %}
              <div class="pt-step"><span>{{ r.l }}</span><div class="pt-sc">
                <button type="button" data-step="{{ r.k }}" data-dir="-1">−</button>
                <input type="number" name="{{ r.k }}" id="ptG_{{ r.k }}" value="{{ r.v }}" min="{{ r.min }}" max="9" readonly>
                <button type="button" data-step="{{ r.k }}" data-dir="1">+</button>
              </div></div>
              {% endfor %}
              <button type="button" class="pt-gdone" id="ptGDone">OK</button>
            </div>
          </div>
          <button type="submit" class="pt-submit">Rechercher</button>
        </form>

        {# ---- Vols ---- #}
        <form class="pt-form" id="ptFlights" method="get" action="{{ path('travel_flights') }}" autocomplete="off" hidden>
          <div class="pt-field pt-grow">
            <label>De</label><span class="pt-ic">🛫</span>
            <input type="text" id="ptFFrom" placeholder="Ville ou aéroport" required>
            <input type="hidden" name="fromId" id="ptFFromId"><input type="hidden" name="from" id="ptFFromL">
            <div class="pt-suggest" id="ptFFromSug" hidden></div>
          </div>
          <div class="pt-field pt-grow">
            <label>Vers</label><span class="pt-ic">🛬</span>
            <input type="text" id="ptFTo" placeholder="Ville ou aéroport" required>
            <input type="hidden" name="toId" id="ptFToId"><input type="hidden" name="to" id="ptFToL">
            <div class="pt-suggest" id="ptFToSug" hidden></div>
          </div>
          <div class="pt-field"><label>Départ</label><span class="pt-ic">📅</span>
            <input type="date" name="departDate" id="ptFDep" value="{{ defDep }}" min="{{ today }}" required></div>
          <div class="pt-field pt-narrow"><label>Voyageurs</label><span class="pt-ic">👤</span>
            <select name="adults">{% for i in 1..9 %}<option value="{{ i }}">{{ i }} adulte{{ i>1?'s':'' }}</option>{% endfor %}</select></div>
          <button type="submit" class="pt-submit">Rechercher</button>
        </form>

        {# ---- Séjours ---- #}
        <form class="pt-form" id="ptStays" method="get" action="{{ path('travel_voyages') }}" hidden>
          <div class="pt-field pt-grow">
            <label>Envie de…</label><span class="pt-ic">🧭</span>
            <input type="text" name="q" placeholder="Omra, circuit, plage, week-end…">
          </div>
          <button type="submit" class="pt-submit">Découvrir nos séjours</button>
        </form>
      </div>

      <div class="pt-hero-badges">
        <span>🔒 Paiement sécurisé</span><span>🏨 Inventaire en direct</span><span>💬 Support 24/7</span>
      </div>
    </div>
  </section>

  <div class="pt-body">

    {# ── SERVICES ── #}
    <section class="pt-services">
      <a href="{{ path('travel_hotels') }}" class="pt-serv"><span>🏨</span><strong>Hôtels</strong><small>Tunisie & monde</small></a>
      <a href="{{ path('travel_flights') }}" class="pt-serv"><span>✈️</span><strong>Vols</strong><small>Meilleurs tarifs</small></a>
      <a href="{{ path('travel_voyages') }}" class="pt-serv"><span>🧳</span><strong>Séjours</strong><small>Tout compris</small></a>
      <a href="{{ path('travel_offers') }}" class="pt-serv"><span>🏷️</span><strong>Offres</strong><small>Promos du moment</small></a>
    </section>

    {# ── POPULAR DESTINATIONS ── #}
    <section class="pt-section">
      <div class="pt-shead"><h2>Destinations populaires</h2><a href="{{ path('travel_hotels') }}">Tout voir →</a></div>
      <div class="pt-dest-grid">
        {% for d in popular %}
          <a class="pt-dest" href="{{ path('travel_hotels', {dest:d.code, dest_name:d.name, checkIn:defIn, checkOut:defOut, adults:2, rooms:1}) }}">
            <img src="{{ d.img }}" alt="{{ d.name }}" loading="lazy"><div class="pt-dest-ov"></div>
            <span class="pt-dest-name">{{ d.name }}</span><span class="pt-dest-cta">Voir les hôtels →</span>
          </a>
        {% endfor %}
      </div>
    </section>

    {# ── DEALS / FEATURED SÉJOURS ── #}
    {% if featured_voyages is not empty %}
    <section class="pt-section">
      <div class="pt-shead"><h2>Séjours &amp; offres du moment</h2><a href="{{ path('travel_voyages') }}">Tout voir →</a></div>
      <div class="pt-deal-grid">
        {% for v in featured_voyages %}
          {% set thumb = v.image_url is iterable and v.image_url|length > 0 ? v.image_url[0] : 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?auto=format&fit=crop&w=1000&q=80' %}
          <a class="pt-deal" href="{{ path('travel_voyage_detail', {slug: v.slug}) }}">
            <div class="pt-deal-img"><img src="{{ thumb }}" alt="{{ v.title }}" loading="lazy">
              <span class="pt-deal-badge">📍 {{ v.destination|split(', ')|first }}</span></div>
            <div class="pt-deal-body">
              <h3>{{ v.title }}</h3>
              <p>{{ v.description|default('')|striptags|slice(0, 72) }}…</p>
              <div class="pt-deal-foot">
                <div class="pt-deal-price"><small>à partir de</small><strong>{{ v.price is not empty ? v.price|number_format(0) ~ ' TND' : 'Sur devis' }}</strong></div>
                <span class="pt-deal-btn">Voir →</span>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# ── WHY US ── #}
    <section class="pt-why">
      <div class="pt-why-item"><span>💳</span><div><strong>Meilleur prix garanti</strong><p>Des tarifs négociés en direct auprès des hôteliers.</p></div></div>
      <div class="pt-why-item"><span>🔒</span><div><strong>Réservation sécurisée</strong><p>Paiement protégé et confirmation immédiate.</p></div></div>
      <div class="pt-why-item"><span>💬</span><div><strong>Une équipe locale</strong><p>Des experts tunisiens joignables 7j/7 sur WhatsApp.</p></div></div>
      <div class="pt-why-item"><span>🌍</span><div><strong>Tunisie &amp; monde</strong><p>Des milliers d'hôtels et destinations à portée de clic.</p></div></div>
    </section>

    {# ── CTA ── #}
    <section class="pt-cta">
      <div><h2>Un projet de voyage sur-mesure ?</h2><p>Dites-nous votre envie, on s'occupe du reste.</p></div>
      <div class="pt-cta-btns">
        <a class="pt-cta-primary" href="{{ path('trip_planner') }}">✨ Planifier avec l'IA</a>
        <a class="pt-cta-ghost" href="https://wa.me/21698365730" target="_blank" rel="noopener">💬 WhatsApp</a>
      </div>
    </section>

  </div>
</div>

<style>
:root{ --pt-blue:#0078D8; --pt-blue-d:#005CB8; --pt-orange:#f0792b; --pt-ink:#0f172a; --pt-mut:#64748b; --pt-line:#e4eaf1; --pt-bg:#f4f7fb; }
.pt-page{ background:var(--pt-bg); }
[data-theme="dark"] .pt-page{ background:#0b1220; }

/* Hero */
.pt-hero{ position:relative; padding:60px 20px 96px; overflow:hidden; }
.pt-hero-bg{ position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,92,184,.92),rgba(0,120,216,.82)),url('https://images.unsplash.com/photo-1512958789358-4ba50a4d2f6b?auto=format&fit=crop&w=1600&q=80') center/cover; }
.pt-hero-inner{ position:relative; max-width:1080px; margin:0 auto; text-align:center; }
.pt-hero-title{ color:#fff; font-size:clamp(1.9rem,4.4vw,3rem); font-weight:800; margin:0 0 10px; letter-spacing:-.6px; text-shadow:0 2px 20px rgba(0,0,0,.2); }
.pt-hero-sub{ color:rgba(255,255,255,.94); font-size:1.1rem; margin:0 0 30px; }

/* Search box */
.pt-box{ background:#fff; border-radius:18px; box-shadow:0 30px 60px -24px rgba(0,0,0,.5); padding:8px; text-align:left; }
[data-theme="dark"] .pt-box{ background:#111a2b; }
.pt-tabs{ display:flex; gap:4px; padding:6px 6px 0; }
.pt-tab{ border:none; background:none; padding:11px 20px; font-size:.95rem; font-weight:700; color:var(--pt-mut); cursor:pointer; border-radius:11px 11px 0 0; }
.pt-tab.active{ background:var(--pt-bg); color:var(--pt-blue-d); }
[data-theme="dark"] .pt-tab.active{ background:#0b1220; color:#7cc0f5; }
.pt-form{ display:grid; grid-template-columns:2fr 1.1fr 1.1fr 1.5fr auto; gap:8px; padding:12px; align-items:end; }
.pt-form[hidden]{ display:none; }
.pt-form#ptStays{ grid-template-columns:1fr auto; }
.pt-field{ position:relative; display:flex; flex-direction:column; gap:5px; }
.pt-field > label{ font-size:.7rem; font-weight:700; color:var(--pt-mut); text-transform:uppercase; letter-spacing:.4px; padding-left:2px; }
.pt-ic{ position:absolute; left:11px; bottom:12px; font-size:.9rem; pointer-events:none; opacity:.85; }
.pt-field input, .pt-gbtn, .pt-field select{ height:46px; border:1px solid var(--pt-line); border-radius:11px; padding:0 12px 0 32px; font-size:.92rem; color:var(--pt-ink); background:#fff; width:100%; font-family:inherit; box-sizing:border-box; }
[data-theme="dark"] .pt-field input, [data-theme="dark"] .pt-gbtn, [data-theme="dark"] .pt-field select{ background:#0b1220; color:#e6edf6; border-color:#1e293b; }
.pt-field select{ padding-left:32px; cursor:pointer; }
.pt-field input:focus, .pt-gbtn:focus, .pt-field select:focus{ outline:none; border-color:var(--pt-blue); box-shadow:0 0 0 3px rgba(0,120,216,.14); }
.pt-gbtn{ text-align:left; cursor:pointer; display:flex; align-items:center; }
.pt-submit{ height:46px; padding:0 28px; border:none; border-radius:11px; background:var(--pt-orange); color:#fff; font-weight:800; font-size:.95rem; cursor:pointer; white-space:nowrap; transition:.15s; }
.pt-submit:hover{ filter:brightness(1.05); transform:translateY(-1px); }

.pt-suggest{ position:absolute; top:100%; left:0; right:0; margin-top:6px; background:#fff; border:1px solid var(--pt-line); border-radius:12px; box-shadow:0 20px 40px -16px rgba(0,0,0,.3); z-index:40; max-height:260px; overflow:auto; }
[data-theme="dark"] .pt-suggest{ background:#111a2b; border-color:#1e293b; }
.pt-suggest button{ display:flex; align-items:center; gap:10px; width:100%; text-align:left; padding:11px 14px; border:none; background:none; cursor:pointer; font-size:.9rem; color:var(--pt-ink); }
[data-theme="dark"] .pt-suggest button{ color:#e6edf6; }
.pt-suggest button:hover{ background:#f1f6fc; } [data-theme="dark"] .pt-suggest button:hover{ background:#0b1220; }
.pt-suggest .s-code{ margin-left:auto; font-size:.68rem; color:var(--pt-mut); background:#eef3f9; padding:2px 7px; border-radius:6px; }

.pt-gpop{ position:absolute; top:100%; right:0; margin-top:6px; width:250px; background:#fff; border:1px solid var(--pt-line); border-radius:12px; box-shadow:0 20px 40px -16px rgba(0,0,0,.3); z-index:40; padding:14px; }
[data-theme="dark"] .pt-gpop{ background:#111a2b; border-color:#1e293b; }
.pt-step{ display:flex; justify-content:space-between; align-items:center; padding:8px 0; font-size:.9rem; color:var(--pt-ink); } [data-theme="dark"] .pt-step{ color:#e6edf6; }
.pt-sc{ display:flex; align-items:center; gap:8px; }
.pt-sc button{ width:30px; height:30px; border:1px solid var(--pt-line); background:#fff; border-radius:8px; font-size:1.1rem; cursor:pointer; color:var(--pt-blue); }
.pt-sc input{ width:32px; text-align:center; border:none; font-size:.95rem; font-weight:700; background:none; color:inherit; padding:0; height:auto; }
.pt-gdone{ margin-top:8px; width:100%; height:36px; border:none; border-radius:9px; background:var(--pt-blue); color:#fff; font-weight:700; cursor:pointer; }

.pt-hero-badges{ display:flex; justify-content:center; gap:22px; margin-top:22px; flex-wrap:wrap; }
.pt-hero-badges span{ color:#fff; font-size:.88rem; font-weight:600; opacity:.95; }

/* Body */
.pt-body{ max-width:1120px; margin:0 auto; padding:30px 20px 70px; }
.pt-section{ margin-bottom:44px; }
.pt-shead{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:18px; }
.pt-shead h2{ font-size:1.5rem; font-weight:800; color:var(--pt-ink); margin:0; }
.pt-shead a{ color:var(--pt-blue-d); font-weight:700; text-decoration:none; font-size:.9rem; }
[data-theme="dark"] .pt-shead h2{ color:#e6edf6; }

/* Services */
.pt-services{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin:-52px auto 40px; position:relative; z-index:5; }
.pt-serv{ background:#fff; border:1px solid var(--pt-line); border-radius:16px; padding:18px; text-decoration:none; display:flex; flex-direction:column; gap:2px; box-shadow:0 14px 30px -18px rgba(15,23,42,.3); transition:.18s; }
.pt-serv:hover{ transform:translateY(-3px); border-color:var(--pt-blue); }
.pt-serv span{ font-size:1.7rem; }
.pt-serv strong{ color:var(--pt-ink); font-size:1rem; margin-top:4px; }
.pt-serv small{ color:var(--pt-mut); font-size:.8rem; }
[data-theme="dark"] .pt-serv{ background:#111a2b; border-color:#1e293b; } [data-theme="dark"] .pt-serv strong{ color:#e6edf6; }

/* Destinations */
.pt-dest-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.pt-dest{ position:relative; height:180px; border-radius:16px; overflow:hidden; text-decoration:none; display:block; }
.pt-dest img{ width:100%; height:100%; object-fit:cover; transition:.4s; }
.pt-dest:hover img{ transform:scale(1.07); }
.pt-dest-ov{ position:absolute; inset:0; background:linear-gradient(180deg,transparent 35%,rgba(0,0,0,.68)); }
.pt-dest-name{ position:absolute; left:16px; bottom:30px; color:#fff; font-weight:800; font-size:1.2rem; z-index:1; }
.pt-dest-cta{ position:absolute; left:16px; bottom:12px; color:#fff; font-size:.8rem; opacity:.9; z-index:1; }

/* Deals */
.pt-deal-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.pt-deal{ background:#fff; border:1px solid var(--pt-line); border-radius:16px; overflow:hidden; text-decoration:none; transition:.2s; }
.pt-deal:hover{ transform:translateY(-4px); box-shadow:0 20px 40px -22px rgba(15,23,42,.4); }
.pt-deal-img{ position:relative; height:170px; }
.pt-deal-img img{ width:100%; height:100%; object-fit:cover; }
.pt-deal-badge{ position:absolute; bottom:10px; left:10px; background:rgba(0,0,0,.6); color:#fff; font-size:.72rem; font-weight:600; padding:4px 10px; border-radius:6px; }
.pt-deal-body{ padding:16px; }
.pt-deal-body h3{ font-size:1.1rem; font-weight:800; color:var(--pt-ink); margin:0 0 5px; }
.pt-deal-body p{ color:var(--pt-mut); font-size:.86rem; margin:0 0 14px; line-height:1.5; }
.pt-deal-foot{ display:flex; justify-content:space-between; align-items:center; }
.pt-deal-price small{ display:block; font-size:.68rem; color:var(--pt-mut); text-transform:uppercase; }
.pt-deal-price strong{ font-size:1.25rem; color:var(--pt-orange); font-weight:800; }
.pt-deal-btn{ background:var(--pt-blue); color:#fff; font-weight:700; font-size:.82rem; padding:9px 16px; border-radius:10px; }
[data-theme="dark"] .pt-deal{ background:#111a2b; border-color:#1e293b; } [data-theme="dark"] .pt-deal-body h3{ color:#e6edf6; }

/* Why */
.pt-why{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:44px; }
.pt-why-item{ background:#fff; border:1px solid var(--pt-line); border-radius:16px; padding:20px; }
.pt-why-item span{ font-size:1.8rem; }
.pt-why-item strong{ display:block; color:var(--pt-ink); margin:10px 0 4px; }
.pt-why-item p{ color:var(--pt-mut); font-size:.85rem; margin:0; line-height:1.5; }
[data-theme="dark"] .pt-why-item{ background:#111a2b; border-color:#1e293b; } [data-theme="dark"] .pt-why-item strong{ color:#e6edf6; }

/* CTA */
.pt-cta{ background:linear-gradient(135deg,var(--pt-blue),var(--pt-blue-d)); border-radius:22px; padding:36px; display:flex; justify-content:space-between; align-items:center; gap:24px; flex-wrap:wrap; }
.pt-cta h2{ color:#fff; margin:0 0 6px; font-size:1.5rem; }
.pt-cta p{ color:rgba(255,255,255,.9); margin:0; }
.pt-cta-btns{ display:flex; gap:12px; flex-wrap:wrap; }
.pt-cta-primary{ background:var(--pt-orange); color:#fff; text-decoration:none; font-weight:800; padding:14px 26px; border-radius:12px; }
.pt-cta-ghost{ background:rgba(255,255,255,.15); color:#fff; text-decoration:none; font-weight:700; padding:14px 24px; border-radius:12px; border:1px solid rgba(255,255,255,.4); }

@media (max-width:900px){
  .pt-form, .pt-form#ptStays{ grid-template-columns:1fr 1fr; }
  .pt-grow{ grid-column:1 / -1; } .pt-submit{ grid-column:1 / -1; }
  .pt-services{ grid-template-columns:repeat(2,1fr); margin-top:-40px; }
  .pt-dest-grid, .pt-deal-grid, .pt-why{ grid-template-columns:1fr 1fr; }
  .pt-cta{ flex-direction:column; text-align:center; }
}
@media (max-width:560px){ .pt-dest-grid, .pt-deal-grid, .pt-why{ grid-template-columns:1fr; } }
</style>

<script>
(function(){
  // Tabs
  var forms = { hotels:document.getElementById('ptHotels'), flights:document.getElementById('ptFlights'), stays:document.getElementById('ptStays') };
  document.querySelectorAll('.pt-tab').forEach(function(t){
    t.addEventListener('click', function(){
      document.querySelectorAll('.pt-tab').forEach(function(b){ b.classList.remove('active'); });
      t.classList.add('active');
      Object.keys(forms).forEach(function(k){ forms[k].hidden = (k !== t.dataset.tab); });
    });
  });

  // Generic autocomplete
  function autocomplete(inputId, boxId, codeId, labelId, url, mapItem){
    var input=document.getElementById(inputId), box=document.getElementById(boxId),
        code=document.getElementById(codeId), label=document.getElementById(labelId), timer, last='';
    function hide(){ box.hidden=true; box.innerHTML=''; }
    input.addEventListener('input', function(){
      code.value=''; var q=input.value.trim(); if(q===last) return; last=q;
      clearTimeout(timer); if(q.length<2){ hide(); return; }
      timer=setTimeout(function(){
        fetch(url+'?q='+encodeURIComponent(q)).then(function(r){return r.json();}).then(function(list){
          if(!Array.isArray(list)||!list.length){ hide(); return; }
          box.innerHTML='';
          list.slice(0,8).forEach(function(it){
            var m=mapItem(it); var b=document.createElement('button'); b.type='button';
            b.innerHTML='<span>📍</span><span>'+m.name+'</span>'+(m.code?'<span class="s-code">'+m.code+'</span>':'');
            b.addEventListener('click', function(){ code.value=m.id; if(label) label.value=m.name; input.value=m.name; hide(); });
            box.appendChild(b);
          });
          box.hidden=false;
        }).catch(hide);
      },240);
    });
    document.addEventListener('click', function(e){ if(!e.target.closest('#'+inputId) && !e.target.closest('#'+boxId)) hide(); });
  }
  autocomplete('ptHDest','ptHSug','ptHCode','ptHName','{{ path('hotel_suggest') }}',
    function(d){ return {id:d.code, name:d.name, code:d.code}; });
  autocomplete('ptFFrom','ptFFromSug','ptFFromId','ptFFromL','{{ path('travel_search_flight_dest') }}',
    function(d){ return {id:d.id||'', name:d.name||d.id||'', code:(d.code||'')}; });
  autocomplete('ptFTo','ptFToSug','ptFToId','ptFToL','{{ path('travel_search_flight_dest') }}',
    function(d){ return {id:d.id||'', name:d.name||d.id||'', code:(d.code||'')}; });

  // Dates: checkout after checkin
  var hIn=document.getElementById('ptHIn'), hOut=document.getElementById('ptHOut');
  hIn.addEventListener('change', function(){ hOut.min=hIn.value; if(hOut.value<=hIn.value){ var d=new Date(hIn.value); d.setDate(d.getDate()+3); hOut.value=d.toISOString().slice(0,10);} });

  // Guests popover
  var gBtn=document.getElementById('ptGBtn'), gPop=document.getElementById('ptGPop'), gLabel=document.getElementById('ptGLabel'), gDone=document.getElementById('ptGDone');
  function relabel(){ var a=+document.getElementById('ptG_adults').value,c=+document.getElementById('ptG_children').value,r=+document.getElementById('ptG_rooms').value;
    var s=a+' adulte'+(a>1?'s':''); if(c>0) s+=', '+c+' enfant'+(c>1?'s':''); s+=' · '+r+' chambre'+(r>1?'s':''); gLabel.textContent=s; }
  gBtn.addEventListener('click', function(e){ e.stopPropagation(); gPop.hidden=!gPop.hidden; });
  gDone.addEventListener('click', function(){ gPop.hidden=true; });
  document.querySelectorAll('.pt-sc button').forEach(function(btn){ btn.addEventListener('click', function(){
    var f=document.getElementById('ptG_'+btn.dataset.step); f.value=Math.max(+f.min,Math.min(9,+f.value+(+btn.dataset.dir))); relabel(); }); });
  document.addEventListener('click', function(e){ if(!e.target.closest('.pt-guests')) gPop.hidden=true; });

  // Validate before submit
  document.getElementById('ptHotels').addEventListener('submit', function(e){
    if(!document.getElementById('ptHCode').value){ e.preventDefault(); document.getElementById('ptHDest').focus(); } });
  document.getElementById('ptFlights').addEventListener('submit', function(e){
    if(!document.getElementById('ptFFromId').value || !document.getElementById('ptFToId').value){ e.preventDefault(); document.getElementById('ptFFrom').focus(); } });
})();
</script>
{% endblock %}
