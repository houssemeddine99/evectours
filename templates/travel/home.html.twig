{% extends 'base.html.twig' %}

{% block title %}Home | Evec Tours — Your Trusted Travel Partner{% endblock %}

{% block javascripts %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  "name": "Evec Tours",
  "url": "https://evectours.com",
  "logo": "https://evectours.com/images/logo.png",
  "description": "Curated travel voyages, exclusive offers, and AI-powered trip planning.",
  "address": { "@type": "PostalAddress", "addressCountry": "TN" },
  "contactPoint": { "@type": "ContactPoint", "contactType": "customer service", "url": "https://evectours.com/contact" },
  "sameAs": ["https://evectours.com"]
}
</script>
{% endblock %}
{% block meta_description %}Evec Tours offers curated voyages, group adventures, and AI-powered trip planning. Discover Tunisia and the world with us.{% endblock %}

{% block body %}

    {# ── HERO ── #}
    <section class="hero hero--pro">
        <div class="hero-bg-overlay"></div>
        <div class="hero-content hero-content--pro">
            <p class="eyebrow-pro">✈️ Your Trusted Travel Partner</p>
            <h1 class="hero-title-pro">Discover <span class="hero-highlight">Unforgettable</span><br>Journeys Around the World</h1>
            <p class="hero-sub-pro">Curated voyages, exclusive offers, and AI-powered trip planning — all in one place.</p>
            <div class="hero-actions hero-actions--pro">
                <a class="btn btn-primary btn-hero" href="{{ path('travel_voyages') }}">🗺️ Explore Voyages</a>
                <a class="btn btn-ghost-pro" href="{{ path('travel_offers') }}">🏷️ Active Offers</a>
            </div>
        </div>
    </section>

    {# ── STATS COUNTER STRIP ── #}
    <section class="stats-strip">
        <div class="stats-strip-inner">
            <div class="stat-item">
                <span class="stat-num" data-target="{{ featured_voyages|length > 0 ? '50' : '10' }}">0</span><span class="stat-suffix">+</span>
                <span class="stat-label">Destinations</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-num" data-target="500">0</span><span class="stat-suffix">+</span>
                <span class="stat-label">Happy Travellers</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-num" data-target="98">0</span><span class="stat-suffix">%</span>
                <span class="stat-label">Satisfaction Rate</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-num" data-target="5">0</span><span class="stat-suffix">★</span>
                <span class="stat-label">Average Rating</span>
            </div>
        </div>
    </section>

    {# ── FEATURED VOYAGES ── #}
    <section class="voyages-section">
        <div class="section-title-row">
            <div>
                <p class="section-eyebrow">Handpicked for you</p>
                <h2>Featured Voyages</h2>
            </div>
            <a href="{{ path('travel_voyages') }}" class="view-all-link">View all →</a>
        </div>
        <div class="grid responsive-grid">
            {% for voyage in featured_voyages %}
                {% set thumb = voyage.image_url is iterable and voyage.image_url|length > 0 ? voyage.image_url[0] : 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?auto=format&fit=crop&w=1200&q=80' %}
                <article class="card card--pro">
                    <div class="card-img-wrap">
                        <img src="{{ thumb }}" alt="{{ voyage.title|default('Travel destination') }}" class="card-image" loading="lazy" decoding="async">
                        <div class="card-img-overlay"></div>
                        <span class="card-dest-badge">📍 {{ voyage.destination|split(', ')|first }}</span>
                    </div>
                    <div class="card-body">
                        <h3>{{ voyage.title|default('Untitled trip') }}</h3>
                        <p class="card-desc">{{ voyage.description|default('')|striptags|slice(0, 90) ~ '…' }}</p>
                        <div class="card-footer card-footer--pro">
                            <div class="card-price-pro">
                                <span class="price-label">From</span>
                                <strong>{{ voyage.price is not empty ? voyage.price|number_format(0) ~ ' TND' : 'On request' }}</strong>
                            </div>
                            <a href="{{ path('travel_voyage_detail', {slug: voyage.slug}) }}" class="btn btn-primary btn-sm">View →</a>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    </section>

    {# ── WHY CHOOSE US ── #}
    <section class="why-us">
        <div class="why-us-inner">
            <div class="why-us-text">
                <p class="section-eyebrow">Why Evec Tours</p>
                <h2>Travel Smarter, Not Harder</h2>
                <p class="why-us-desc">We combine AI-powered planning, local expertise, and exclusive deals to give you the best travel experience possible.</p>
                <a href="{{ path('travel_voyages') }}" class="btn btn-primary">Get Started →</a>
            </div>
            <div class="why-us-features">
                <div class="why-feature">
                    <div class="why-icon">🤖</div>
                    <div>
                        <h4>AI Itinerary Builder</h4>
                        <p>Generate a personalised day-by-day plan instantly with our AI assistant.</p>
                    </div>
                </div>
                <div class="why-feature">
                    <div class="why-icon">🔒</div>
                    <div>
                        <h4>Secure Booking</h4>
                        <p>SSL-encrypted payments and transparent pricing — no hidden fees.</p>
                    </div>
                </div>
                <div class="why-feature">
                    <div class="why-icon">🎯</div>
                    <div>
                        <h4>Curated Experiences</h4>
                        <p>Every voyage is hand-selected and quality-checked by our travel experts.</p>
                    </div>
                </div>
                <div class="why-feature">
                    <div class="why-icon">💬</div>
                    <div>
                        <h4>24/7 Support</h4>
                        <p>Chat with us anytime on WhatsApp — our travel experts reply fast.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── TRUST BADGES ── #}
    <section class="trust-strip">
        <div class="trust-inner">
            <div class="trust-badge"><span>🔒</span><span>Secure Payments</span></div>
            <div class="trust-badge"><span>✈️</span><span>Best Price Guarantee</span></div>
            <div class="trust-badge"><span>📞</span><span>24/7 WhatsApp Support</span></div>
            <div class="trust-badge"><span>🌟</span><span>Verified Reviews</span></div>
            <div class="trust-badge"><span>🗺️</span><span>Expert Local Guides</span></div>
        </div>
    </section>

    {# ── CTA BANNER ── #}
    <section class="cta-banner">
        <div class="cta-banner-inner">
            <div class="cta-text">
                <h2>Ready for your next adventure?</h2>
                <p>Tell our AI your dream trip and we'll find the perfect match in seconds.</p>
            </div>
            <div class="cta-actions">
                <a href="{{ path('trip_planner') }}" class="btn btn-primary btn-lg">✨ Plan with AI</a>
                <a href="{{ path('travel_contact') }}" class="btn btn-ghost-pro">Contact Us</a>
            </div>
        </div>
    </section>

<style>
/* ── Hero (light luxury) ── */
.hero--pro { min-height: 84vh; display:flex; align-items:center; position:relative; overflow:hidden;
  background:
    linear-gradient(90deg, #fdfbf7 0%, #fdfbf7 36%, rgba(253,251,247,.55) 66%, rgba(253,251,247,.15) 100%),
    url('https://images.unsplash.com/photo-1539768942893-daf53e448371?auto=format&fit=crop&w=1600&q=80') center right/cover no-repeat;
}
.hero-bg-overlay { position:absolute; inset:0; background: radial-gradient(ellipse at 20% 30%, rgba(184,134,46,.06) 0%, transparent 55%); pointer-events:none; }
.hero-content--pro { position:relative; z-index:1; max-width:680px; padding: 90px 48px; }
.eyebrow-pro { color:var(--amazon-orange-dark); font-size:.82rem; font-weight:600; letter-spacing:2.5px; text-transform:uppercase; margin-bottom:18px; }
.hero-title-pro { font-family:var(--font-serif); font-size:clamp(2.8rem, 6vw, 4.6rem); font-weight:600; line-height:1.06; margin:0 0 22px; color:#1b1f24; letter-spacing:.3px; }
.hero-highlight { color:var(--amazon-orange); font-style:italic; }
.hero-sub-pro { font-size:1.18rem; color:var(--text-muted); line-height:1.7; margin-bottom:38px; max-width:540px; }
.hero-actions--pro { display:flex; gap:16px; flex-wrap:wrap; }
.btn-hero { padding:15px 34px; font-size:.82rem; }
.btn-ghost-pro { padding:14px 30px; background:transparent; border:1px solid var(--border-dark); color:var(--text-primary); border-radius:2px; font-weight:600; font-size:.78rem; text-transform:uppercase; letter-spacing:1.5px; text-decoration:none; transition:var(--transition-smooth); display:inline-flex; align-items:center; }
.btn-ghost-pro:hover { border-color:var(--amazon-orange); color:var(--amazon-orange); transform:translateY(-2px); }

/* ── Stats strip ── */
.stats-strip { background:#fff; border-top:1px solid var(--hairline); border-bottom:1px solid var(--hairline); padding:34px 24px; }
.stats-strip-inner { display:flex; justify-content:center; align-items:center; gap:0; max-width:980px; margin:0 auto; flex-wrap:wrap; }
.stat-item { text-align:center; padding:0 46px; display:flex; flex-direction:column; gap:6px; position:relative; }
.stat-num { font-family:var(--font-serif); font-size:2.8rem; font-weight:600; color:var(--amazon-orange); line-height:1; }
.stat-suffix { font-family:var(--font-serif); font-size:1.8rem; font-weight:600; color:var(--amazon-orange); }
.stat-label { font-size:.74rem; color:var(--text-muted); font-weight:600; letter-spacing:1px; text-transform:uppercase; }
.stat-divider { width:1px; height:48px; background:var(--hairline); flex-shrink:0; margin:0 4px; }

/* ── Section eyebrow / titles ── */
.section-eyebrow { color:var(--amazon-orange-dark); font-size:.76rem; font-weight:600; text-transform:uppercase; letter-spacing:2px; margin-bottom:6px; }
.voyages-section { padding:80px 24px; max-width:1160px; margin:0 auto; }
.section-title-row { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:36px; }
.section-title-row h2 { margin:0; }

/* ── Card Pro ── */
.card--pro { border:1px solid var(--hairline); background:#fff; transition:var(--transition-smooth); border-radius:8px; overflow:hidden; }
.card--pro:hover { transform:translateY(-6px); box-shadow:0 22px 45px -22px rgba(31,35,40,.30); border-color:var(--hairline-gold); }
.card-img-wrap { position:relative; overflow:hidden; border-radius:8px 8px 0 0; }
.card-img-wrap .card-image { transition:transform .5s ease; width:100%; height:210px; object-fit:cover; display:block; }
.card--pro:hover .card-image { transform:scale(1.05); }
.card-img-overlay { position:absolute; inset:0; background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.45) 100%); }
.card-dest-badge { position:absolute; bottom:10px; left:12px; background:rgba(27,31,36,.7); color:#fff; font-size:.72rem; font-weight:600; letter-spacing:.5px; padding:4px 11px; border-radius:3px; backdrop-filter:blur(4px); }
.card-desc { color:var(--text-muted); font-size:.9rem; line-height:1.6; margin:6px 0 16px; }
.card-footer--pro { display:flex; justify-content:space-between; align-items:center; }
.card-price-pro { display:flex; flex-direction:column; }
.price-label { font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; }
.card-price-pro strong { font-family:var(--font-serif); font-size:1.4rem; color:var(--amazon-orange); font-weight:600; }
.btn-sm { padding:9px 18px; font-size:.72rem; }
.view-all-link { color:var(--amazon-orange-dark); font-weight:600; text-decoration:none; font-size:.8rem; text-transform:uppercase; letter-spacing:1.5px; }
.view-all-link:hover { color:var(--amazon-orange); }

/* ── Why Us ── */
.why-us { padding:90px 24px; background:#fff; border-top:1px solid var(--hairline); }
.why-us-inner { max-width:1160px; margin:0 auto; display:grid; grid-template-columns:1fr 1.4fr; gap:72px; align-items:center; }
.why-us-text h2 { margin:8px 0 16px; }
.why-us-desc { color:var(--text-muted); line-height:1.8; margin-bottom:30px; }
.why-us-features { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
.why-feature { display:flex; gap:14px; align-items:flex-start; background:#fbf8f3; border:1px solid var(--hairline); border-radius:8px; padding:22px; transition:var(--transition-smooth); }
.why-feature:hover { border-color:var(--hairline-gold); background:#fffdf9; transform:translateY(-3px); }
.why-icon { font-size:1.7rem; flex-shrink:0; }
.why-feature h4 { margin:0 0 5px; font-size:1.15rem; font-weight:600; color:var(--text-primary); }
.why-feature p { margin:0; color:var(--text-muted); font-size:.86rem; line-height:1.6; }

/* ── Trust strip ── */
.trust-strip { padding:26px 24px; background:#faf6ee; border-top:1px solid var(--hairline); border-bottom:1px solid var(--hairline); }
.trust-inner { max-width:1100px; margin:0 auto; display:flex; justify-content:center; flex-wrap:wrap; gap:14px; }
.trust-badge { display:flex; align-items:center; gap:8px; background:#fff; border:1px solid var(--hairline); border-radius:3px; padding:10px 20px; font-size:.8rem; font-weight:500; color:var(--text-secondary); }

/* ── CTA Banner ── */
.cta-banner { padding:84px 24px; background:linear-gradient(135deg,#faf3e2,#f6efe3); }
.cta-banner-inner { max-width:900px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; gap:36px; flex-wrap:wrap; }
.cta-text h2 { margin:0 0 8px; }
.cta-text p { margin:0; color:var(--text-muted); font-size:1.05rem; }
.cta-actions { display:flex; gap:14px; flex-shrink:0; flex-wrap:wrap; }
.btn-lg { padding:16px 38px; font-size:.82rem; }

@media (max-width:900px) {
    .hero--pro { background: linear-gradient(160deg,#fdfbf7,#f6efe3); }
    .hero-content--pro { padding:64px 24px; }
    .why-us-inner { grid-template-columns:1fr; gap:40px; }
    .why-us-features { grid-template-columns:1fr; }
    .section-title-row { flex-direction:column; align-items:flex-start; gap:12px; }
    .cta-banner-inner { flex-direction:column; text-align:center; }
    .stat-item { padding:0 24px; }
    .stat-divider { display:none; }
}
</style>

<script>
// Animated counter
document.addEventListener('DOMContentLoaded', function() {
    var nums = document.querySelectorAll('.stat-num[data-target]');
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            var target = parseInt(el.dataset.target, 10);
            var current = 0;
            var step = Math.ceil(target / 40);
            var timer = setInterval(function() {
                current = Math.min(current + step, target);
                el.textContent = current;
                if (current >= target) clearInterval(timer);
            }, 30);
            observer.unobserve(el);
        });
    }, { threshold: 0.4 });
    nums.forEach(function(n) { observer.observe(n); });
});
</script>

{% endblock %}
