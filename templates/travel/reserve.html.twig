{% extends 'base.html.twig' %}

{% block title %}Reserve Voyage | Evec Tours{% endblock %}

{% block body %}
<section>
    <h1>Reserve: {{ voyage.title }}</h1>
    <p class="lead">Submit your reservation; it will be pending until admin approval.</p>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }}" style="margin-bottom:12px;">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if error is defined and error %}<div class="alert alert-error">{{ error }}</div>{% endif %}
    {% if success is defined and success %}<div class="alert alert-success">{{ success }}</div>{% endif %}

    {# High demand banner #}
    {% if is_high_demand %}
        <div class="demand-warning">
            🔥 <strong>High Demand!</strong> {{ active_count }} people already booked this voyage. Secure your spot now.
        </div>
    {% endif %}

    <div class="card settings-card">
        <p><strong>Destination</strong>: {{ voyage.destination }}</p>
        <p><strong>Dates</strong>: {{ voyage.start_date ? voyage.start_date|date('d M Y') : 'TBD' }} – {{ voyage.end_date ? voyage.end_date|date('d M Y') : 'TBD' }}</p>
        <p><strong>Base price per person</strong>: {{ voyage.price|number_format(2, '.', ',') }} TND</p>
        {% if offer %}<p><strong>Active offer</strong>: {{ offer.title }} (–{{ offer.discount_percentage }}% off)</p>{% endif %}

    </div>

    {# Waitlist mode — show join/leave button instead of reservation form #}
    {% if is_high_demand %}
        <div class="waitlist-section">
            <h3>🧾 Voyage is at high demand capacity</h3>
            <p>This voyage is very popular. You can join the waitlist and we'll notify you by SMS when a spot opens up.</p>
            {% if is_on_waitlist %}
                <p class="waitlist-position">
                    ✅ You are on the waitlist.
                    {% set position = waitlist_position|default(null) %}
                    {% if position %}Position: #{{ position }}{% endif %}
                </p>
                <form method="post" action="{{ path('waitlist_leave', {id: voyage.id}) }}">
                    <button type="submit" class="btn btn-secondary">Leave Waitlist</button>
                </form>
            {% else %}
                <form method="post" action="{{ path('waitlist_join', {id: voyage.id}) }}">
                    <button type="submit" class="btn btn-primary">Join Waitlist</button>
                </form>
            {% endif %}
        </div>
    {% else %}
        {# Normal reservation form #}
        <form method="post" id="reserve-form" data-autosave="reserve-{{ voyage.id }}">
            <span class="tg-autosave">✅ Draft saved</span>
            <div class="form-group" style="margin-bottom:16px;">
                <label for="number_of_people">Number of people</label>
                <input type="number" id="number_of_people" name="number_of_people" value="1" min="1" max="20" required
                    onchange="updatePriceBreakdown()" oninput="updatePriceBreakdown()">
            </div>

            {# Loyalty points redemption #}
            {% if loyalty_balance > 0 %}
                <div class="loyalty-box">
                    <div class="loyalty-pts">⭐ {{ loyalty_balance }} loyalty pts</div>
                    {% if can_redeem %}
                        <label class="loyalty-redeem-label">
                            <input type="checkbox" name="use_loyalty_points" value="1" id="use-points" onchange="updatePriceBreakdown()">
                            Use 100 pts for an extra <strong>5% discount</strong> on this booking
                        </label>
                    {% else %}
                        <p class="loyalty-hint">{{ 100 - loyalty_balance }} more pts for a 5% discount (earn 1 pt per TND spent)</p>
                    {% endif %}
                </div>
            {% endif %}

            {# Live price breakdown #}
            <div class="price-breakdown" id="price-breakdown">
                <div class="breakdown-row">
                    <span>Base price (1 person)</span>
                    <span id="base-price">{{ voyage.price|number_format(2, '.', ',') }} TND</span>
                </div>
                {% if offer %}
                <div class="breakdown-row discount">
                    <span>Offer discount (–{{ offer.discount_percentage }}%)</span>
                    <span id="offer-discount">–{{ ((voyage.price * offer.discount_percentage / 100))|number_format(2, '.', ',') }} TND</span>
                </div>
                {% endif %}
                <div class="breakdown-row loyalty-discount-row" id="loyalty-row" style="display:none;">
                    <span>Loyalty discount (–5%)</span>
                    <span id="loyalty-discount-amount">–0.00 TND</span>
                </div>
                <div class="breakdown-row promo-discount-row" id="promo-row" style="display:none;">
                    <span>Promo discount (<span id="promo-code-label"></span>)</span>
                    <span id="promo-discount-amount" style="color:#22c55e;">–0.00 TND</span>
                </div>
                <div class="breakdown-row total">
                    <span><strong>Estimated Total</strong></span>
                    <strong id="total-price">{{ voyage.price|number_format(2, '.', ',') }} TND</strong>
                </div>
            </div>

            {# Promo code #}
            <div class="promo-box">
                <label for="promo_input">🏷️ Promo Code</label>
                <div class="promo-input-row">
                    <input type="text" id="promo_input" placeholder="Enter code (e.g. WELCOME10)" autocomplete="off" style="text-transform:uppercase">
                    <button type="button" class="btn-promo-apply" onclick="applyPromo()">Apply</button>
                </div>
                <input type="hidden" name="promo_code" id="promo_code_hidden">
                <p id="promo-msg" class="promo-msg"></p>
            </div>

            <button type="submit" class="btn btn-success" style="margin-top:16px;">Reserve Now &amp; Pay</button>
            <p style="margin-top:10px;font-size:.85rem;color:var(--text-muted);">🔒 You'll be redirected to Flouci's secure payment page to complete your booking.</p>
        </form>
    {% endif %}
</section>

<style>
.demand-warning { background:rgba(239,68,68,0.12); border:1px solid rgba(239,68,68,0.4); color:#fca5a5; border-radius:10px; padding:14px 18px; margin-bottom:18px; font-size:0.95rem; }
.waitlist-section { background:rgba(245,158,11,0.08); border:1px solid rgba(245,158,11,0.3); border-radius:12px; padding:24px; margin-top:20px; }
.waitlist-section h3 { margin:0 0 8px; }
.waitlist-position { color:#22c55e; font-weight:600; margin:10px 0; }
.loyalty-box { background:rgba(255,165,0,0.08); border:1px solid rgba(255,165,0,0.25); border-radius:10px; padding:14px 18px; margin-bottom:16px; }
.loyalty-pts { font-size:1rem; font-weight:700; color:var(--amazon-orange); margin-bottom:6px; }
.loyalty-redeem-label { display:flex; align-items:center; gap:8px; cursor:pointer; font-size:0.93rem; }
.loyalty-hint { font-size:0.83rem; color:var(--text-muted); margin:4px 0 0; }
.price-breakdown { background:rgba(0,0,0,0.2); border:1px solid var(--border-dark); border-radius:10px; padding:16px 18px; margin-top:8px; }
.breakdown-row { display:flex; justify-content:space-between; padding:5px 0; font-size:0.92rem; }
.breakdown-row.discount { color:#22c55e; }
.breakdown-row.loyalty-discount-row { color:#f59e0b; }
.breakdown-row.promo-discount-row { color:#22c55e; }
.breakdown-row.total { border-top:1px solid var(--border-dark); margin-top:6px; padding-top:10px; font-size:1rem; }

/* Promo box */
.promo-box { background:rgba(34,197,94,.06); border:1px solid rgba(34,197,94,.2); border-radius:10px; padding:14px 18px; margin-bottom:16px; }
.promo-box label { font-size:.88rem; font-weight:700; color:#22c55e; display:block; margin-bottom:8px; }
.promo-input-row { display:flex; gap:8px; }
.promo-input-row input { flex:1; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.15); border-radius:8px; padding:9px 14px; color:inherit; font-family:inherit; font-size:.9rem; font-weight:700; letter-spacing:1px; }
.promo-input-row input:focus { outline:none; border-color:#22c55e; }
.btn-promo-apply { background:#22c55e; color:#000; border:none; border-radius:8px; padding:9px 18px; font-weight:700; cursor:pointer; white-space:nowrap; transition:opacity .2s; }
.btn-promo-apply:hover { opacity:.85; }
.promo-msg { margin:6px 0 0; font-size:.83rem; min-height:18px; }
</style>

<script>
var basePrice     = {{ voyage.price|default(0) }};
var offerDiscount = {{ offer ? offer.discount_percentage : 0 }} / 100;
var promoDiscount = 0;

function updatePriceBreakdown() {
    var n          = parseInt(document.getElementById('number_of_people').value) || 1;
    var usePoints  = document.getElementById('use-points') ? document.getElementById('use-points').checked : false;
    var loyaltyD   = usePoints ? 0.05 : 0;

    var base       = basePrice * n;
    var afterOffer = base * (1 - offerDiscount);
    var afterLoy   = afterOffer * (1 - loyaltyD);
    var after      = Math.max(0, afterLoy - promoDiscount);

    document.getElementById('base-price').textContent = base.toFixed(2) + ' TND';

    if (offerDiscount > 0) {
        document.getElementById('offer-discount').textContent = '–' + (base * offerDiscount).toFixed(2) + ' TND';
    }

    var loyaltyRow = document.getElementById('loyalty-row');
    if (loyaltyRow) {
        loyaltyRow.style.display = usePoints ? 'flex' : 'none';
        document.getElementById('loyalty-discount-amount').textContent = '–' + (afterOffer * 0.05).toFixed(2) + ' TND';
    }

    var promoRow = document.getElementById('promo-row');
    if (promoRow) {
        promoRow.style.display = promoDiscount > 0 ? 'flex' : 'none';
        document.getElementById('promo-discount-amount').textContent = '–' + promoDiscount.toFixed(2) + ' TND';
    }

    document.getElementById('total-price').textContent = after.toFixed(2) + ' TND';
}

function applyPromo() {
    var code = document.getElementById('promo_input').value.trim().toUpperCase();
    var msg  = document.getElementById('promo-msg');
    if (!code) { msg.textContent = 'Enter a promo code first.'; msg.style.color = '#f87171'; return; }

    var n          = parseInt(document.getElementById('number_of_people').value) || 1;
    var usePoints  = document.getElementById('use-points') ? document.getElementById('use-points').checked : false;
    var subtotal   = basePrice * n * (1 - offerDiscount) * (1 - (usePoints ? 0.05 : 0));

    var btn = document.querySelector('.btn-promo-apply');
    btn.disabled = true; btn.textContent = '…';

    var fd = new FormData();
    fd.append('code', code);
    fd.append('price', subtotal.toFixed(2));

    fetch('{{ path("api_promo_validate") }}', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false; btn.textContent = 'Apply';
            if (data.valid) {
                promoDiscount = parseFloat(data.discount);
                document.getElementById('promo_code_hidden').value = code;
                document.getElementById('promo-code-label').textContent = code;
                msg.textContent = '✅ ' + data.description;
                msg.style.color = '#22c55e';
            } else {
                promoDiscount = 0;
                document.getElementById('promo_code_hidden').value = '';
                msg.textContent = '❌ ' + data.error;
                msg.style.color = '#f87171';
            }
            updatePriceBreakdown();
        })
        .catch(function() { btn.disabled=false; btn.textContent='Apply'; });
}

updatePriceBreakdown();
</script>
{% endblock %}
