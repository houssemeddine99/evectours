{% extends 'base.html.twig' %}
{% block title %}Admin Reservations | Travagir{% endblock %}

{% block body %}
<div class="reservations-page">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <h1>All Reservations</h1>
            <p class="lead">Manage and confirm pending reservations.</p>
        </div>
        <div class="header-stats">
            <div class="stat-pill pending">
                <span class="stat-count">{{ reservations|filter(r => r.status == 'PENDING')|length }}</span>
                <span class="stat-label">Pending</span>
            </div>
            <div class="stat-pill confirmed">
                <span class="stat-count">{{ reservations|filter(r => r.status == 'CONFIRMED')|length }}</span>
                <span class="stat-label">Confirmed</span>
            </div>
            <div class="stat-pill cancelled">
                <span class="stat-count">{{ reservations|filter(r => r.status == 'CANCELLED')|length }}</span>
                <span class="stat-label">Cancelled</span>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="filters-bar">
        <div class="filter-tabs">
            <a href="{{ path('admin_reservations') }}" class="filter-tab {{ app.request.query.get('status') is null ? 'active' : '' }}">All</a>
            <a href="{{ path('admin_reservations') }}?status=PENDING" class="filter-tab {{ app.request.query.get('status') == 'PENDING' ? 'active' : '' }}">Pending</a>
            <a href="{{ path('admin_reservations') }}?status=CONFIRMED" class="filter-tab {{ app.request.query.get('status') == 'CONFIRMED' ? 'active' : '' }}">Confirmed</a>
            <a href="{{ path('admin_reservations') }}?status=CANCELLED" class="filter-tab {{ app.request.query.get('status') == 'CANCELLED' ? 'active' : '' }}">Cancelled</a>
        </div>
        <div class="results-count">
            {{ reservations|length }} reservation{{ reservations|length != 1 ? 's' : '' }}
        </div>
    </div>

    {% if reservations is empty %}
    <div class="empty-state">
        <span class="empty-icon">📋</span>
        <h3>No reservations found</h3>
        <p>There are no reservations to display.</p>
        <a href="{{ path('travel_home') }}" class="btn btn-primary">Back to Home</a>
    </div>
    {% else %}
    <!-- Table -->
    <div class="table-container">
        <table class="reservations-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Voyage</th>
                    <th>Destination</th>
                    <th>Date</th>
                    <th>People</th>
                    <th>Total</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in reservations %}
                <tr>
                    <td class="cell-id">#{{ reservation.id }}</td>
                    <td class="cell-user">
                        <div class="user-info">
                            <strong>{{ reservation.user_name }}</strong>
                            <span>{{ reservation.user_email }}</span>
                        </div>
                    </td>
                    <td class="cell-voyage">
                        <span class="voyage-title">{{ reservation.voyage_title }}</span>
                    </td>
                    <td class="cell-destination">{{ reservation.destination }}</td>
                    <td class="cell-date">
                        <span class="date-main">{{ reservation.reservation_date|date('d M Y') }}</span>
                        <span class="date-time">{{ reservation.reservation_date|date('H:i') }}</span>
                    </td>
                    <td class="cell-people">
                        <span class="people-count">{{ reservation.number_of_people }}</span>
                    </td>
                    <td class="cell-price">${{ reservation.total_price|number_format(2, '.', ',') }}</td>
                    <td class="cell-payment">
                        <span class="payment-badge payment-{{ reservation.payment_status|lower }}">{{ reservation.payment_status }}</span>
                    </td>
                    <td class="cell-status">
                        <span class="status-badge status-{{ reservation.status|lower }}">{{ reservation.status }}</span>
                    </td>
                    <td class="cell-actions">
                        <div class="action-buttons">
                            {% if reservation.status == 'PENDING' %}
                            <form method="post" action="{{ path('admin_reservation_confirm', {id: reservation.id}) }}" class="action-form">
                                <input type="text" name="payment_reference" placeholder="pi_/ch_" title="Optional Stripe payment reference" style="width: 90px; margin-right: 6px;" />
                                <button type="submit" class="btn-action btn-confirm" title="Confirm">
                                    ✓
                                </button>
                            </form>
                            {% endif %}
                            {% if reservation.status in ['PENDING', 'CONFIRMED'] %}
                            <form method="post" action="{{ path('admin_reservation_cancel', {id: reservation.id}) }}" class="action-form">
                                <button type="submit" class="btn-action btn-cancel" title="Cancel" onclick="return confirm('Are you sure you want to cancel this reservation?');">
                                    ✕
                                </button>
                            </form>
                            {% endif %}
                            <a href="{{ path('account_reservation_detail', {id: reservation.id}) }}" class="btn-action btn-view" title="View Details">
                                →
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    <div class="page-footer">
        <a href="{{ path('admin_dashboard') }}" class="back-link">← Back to Admin Dashboard</a>
    </div>
</div>

<style>
.reservations-page {
    padding: 30px 20px;
}

/* Page Header */
.page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
}

.page-header h1 {
    margin: 0 0 8px 0;
    font-size: 2rem;
}

.page-header .lead {
    margin: 0;
    color: var(--text-muted);
}

.header-stats {
    display: flex;
    gap: 12px;
}

.stat-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 20px;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
}

.stat-pill.pending { border-color: rgba(255, 193, 7, 0.4); }
.stat-pill.confirmed { border-color: rgba(22, 163, 74, 0.4); }
.stat-pill.cancelled { border-color: rgba(220, 38, 38, 0.4); }

.stat-count {
    font-size: 1.2rem;
    font-weight: 800;
}

.stat-pill.pending .stat-count { color: #ffc107; }
.stat-pill.confirmed .stat-count { color: #16a34a; }
.stat-pill.cancelled .stat-count { color: #dc2626; }

.stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
}

/* Filters */
.filters-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding: 12px 16px;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 12px;
}

.filter-tabs {
    display: flex;
    gap: 8px;
}

.filter-tab {
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s ease;
}

.filter-tab:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
}

.filter-tab.active {
    color: var(--amazon-orange);
    background: rgba(255, 153, 0, 0.1);
}

.results-count {
    color: var(--text-muted);
    font-size: 0.9rem;
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
}

.empty-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 16px;
}

.empty-state h3 {
    margin: 0 0 8px 0;
    color: var(--text-primary);
}

.empty-state p {
    color: var(--text-muted);
    margin: 0 0 24px 0;
}

/* Table */
.table-container {
    overflow-x: auto;
    background: var(--amazon-white);
    border: 1px solid var(--border-dark);
    border-radius: 16px;
}

.reservations-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
}

.reservations-table th {
    text-align: left;
    padding: 16px;
    background: rgba(15, 23, 34, 0.5);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border-dark);
}

.reservations-table td {
    padding: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: middle;
}

.reservations-table tbody tr {
    transition: background 0.2s ease;
}

.reservations-table tbody tr:hover {
    background: rgba(255, 153, 0, 0.05);
}

.reservations-table tbody tr:last-child td {
    border-bottom: none;
}

/* Cell Styles */
.cell-id {
    font-weight: 700;
    color: var(--amazon-orange);
    font-family: monospace;
}

.user-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.user-info strong {
    color: var(--text-primary);
    font-size: 0.95rem;
}

.user-info span {
    color: var(--text-muted);
    font-size: 0.8rem;
}

.voyage-title {
    color: var(--text-primary);
    font-weight: 500;
    max-width: 180px;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.cell-destination {
    color: var(--text-muted);
}

.cell-date {
    white-space: nowrap;
}

.date-main {
    display: block;
    color: var(--text-primary);
    font-weight: 500;
}

.date-time {
    display: block;
    color: var(--text-muted);
    font-size: 0.8rem;
}

.people-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    background: rgba(68, 121, 207, 0.2);
    border-radius: 8px;
    font-weight: 600;
    color: #60a5fa;
}

.cell-price {
    font-weight: 700;
    color: var(--amazon-orange);
    font-size: 1.05rem;
}

.payment-badge, .status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
}

.payment-paid { background: rgba(22, 163, 74, 0.2); color: #22c55e; }
.payment-pending { background: rgba(255, 193, 7, 0.2); color: #ffc107; }

.status-pending { background: rgba(255, 193, 7, 0.2); color: #ffc107; }
.status-confirmed { background: rgba(22, 163, 74, 0.2); color: #22c55e; }
.status-cancelled { background: rgba(220, 38, 38, 0.2); color: #ef4444; }
.status-completed { background: rgba(59, 130, 246, 0.2); color: #60a5fa; }

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 8px;
}

.btn-action {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    text-decoration: none;
}

.btn-confirm {
    background: rgba(22, 163, 74, 0.2);
    color: #22c55e;
}

.btn-confirm:hover {
    background: #16a34a;
    color: white;
}

.btn-cancel {
    background: rgba(220, 38, 38, 0.2);
    color: #ef4444;
}

.btn-cancel:hover {
    background: #dc2626;
    color: white;
}

.btn-view {
    background: rgba(68, 121, 207, 0.2);
    color: #60a5fa;
}

.btn-view:hover {
    background: #3b82f6;
    color: white;
}

/* Page Footer */
.page-footer {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid var(--border-dark);
}

.back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
}

.back-link:hover {
    color: var(--amazon-orange);
}

/* Responsive */
@media (max-width: 1024px) {
    .page-header {
        flex-direction: column;
    }
    
    .header-stats {
        width: 100%;
        justify-content: flex-start;
    }
    
    .filters-bar {
        flex-direction: column;
        gap: 12px;
        align-items: flex-start;
    }
}

@media (max-width: 768px) {
    .header-stats {
        flex-wrap: wrap;
    }
    
    .filter-tabs {
        flex-wrap: wrap;
    }
    
    .reservations-table th,
    .reservations-table td {
        padding: 12px 8px;
    }
}
</style>
{% endblock %}