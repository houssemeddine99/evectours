{% extends 'base.html.twig' %}

{% block title %}Favorites | Travagir{% endblock %}

{% block body %}
    <section>
        <h1>Favorites</h1>
        <p class="lead">Great choices! Save these favorite destinations before booking.</p>

        {% if favorites is empty %}
            <p>No favorites yet. Browse voyages and mark ones you love.</p>
        {% else %}
            <div class="grid">
                {% for voyage in favorites %}
                    <article class="card">
                        <img src="{{ voyage.image_url ?: 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?auto=format&fit=crop&w=1200&q=80' }}" alt="{{ voyage.title }}" class="card-image">
                        <div class="card-body">
                            <p class="meta">{{ voyage.destination }} • {{ voyage.start_date ? voyage.start_date|date('d M Y') : 'TBD' }} → {{ voyage.end_date ? voyage.end_date|date('d M Y') : 'TBD' }}</p>
                            <h3>{{ voyage.title }}</h3>
                            <p>{{ voyage.description }}</p>
                            <div class="card-footer">
                                <strong>{{ voyage.price is not empty ? '$' ~ voyage.price|number_format(2, '.', ',') : 'Price on request' }}</strong>
                                <a href="{{ path('travel_voyage_detail', {id: voyage.id}) }}">View</a>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
