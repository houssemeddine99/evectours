{% extends 'base.html.twig' %}

{% block title %}Contact Travagir - Get Your Dream Trip Planned{% endblock %}

{% block body %}

    <!-- ===== HERO SECTION ===== -->
    <section class="contact-hero-section">
        <div class="hero-background"></div>
        <div class="container hero-content">
            <span class="hero-badge">✨ We'd love to hear from you</span>
            <h1 class="hero-title">Plan Your Perfect Journey</h1>
            <p class="hero-subtitle">Let our expert travel team create a personalized itinerary tailored to your dreams and budget</p>
        </div>
    </section>

    <!-- ===== MAIN CONTAINER ===== -->
    <section class="contact-main">
        <div class="container">

            <!-- ===== STATS SECTION ===== -->
            <div class="stats-section">
                <div class="stat-item">
                    <div class="stat-icon">⚡</div>
                    <h3>Lightning Fast</h3>
                    <p>Response within 24 hours</p>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">🌎</div>
                    <h3>50+ Destinations</h3>
                    <p>Morocco & North Africa</p>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">👑</div>
                    <h3>Expert Team</h3>
                    <p>15+ years of experience</p>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">💯</div>
                    <h3>100% Customizable</h3>
                    <p>Your dream, your way</p>
                </div>
            </div>

            <!-- ===== TWO COLUMN GRID ===== -->
            <div class="contact-grid">

                <!-- ===== FORM SECTION ===== -->
                <div class="form-card">
                    <div class="form-header">
                        <h2>Tell Us About Your Adventure</h2>
                        <p>Share your travel vision and we'll make it reality</p>
                    </div>

                    <form class="premium-form" >
                        
                        <!-- ROW 1: Name & Email -->
                        <div class="form-row">
                            <div class="form-group">
                                <label for="full_name">Full Name <span class="required">*</span></label>
                                <input type="text" id="full_name" name="full_name" placeholder="Your full name" required>
                                <div class="input-icon">👤</div>
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address <span class="required">*</span></label>
                                <input type="email" id="email" name="email" placeholder="your@email.com" required>
                                <div class="input-icon">✉️</div>
                            </div>
                        </div>

                        <!-- ROW 2: Phone & Destination -->
                        <div class="form-row">
                            <div class="form-group">
                                <label for="phone">Phone Number</label>
                                <input type="tel" id="phone" name="phone" placeholder="+212 5 XX XX XX XX">
                                <div class="input-icon">📞</div>
                            </div>
                            <div class="form-group">
                                <label for="destination">Destination <span class="required">*</span></label>
                                <input type="text" id="destination" name="destination" placeholder="Where are you dreaming of?" required>
                                <div class="input-icon">📍</div>
                            </div>
                        </div>

                        <!-- ROW 3: Travel Type & Trip Duration -->
                        <div class="form-row">
                            <div class="form-group">
                                <label for="travel_type">Travel Type <span class="required">*</span></label>
                                <select id="travel_type" name="travel_type" required>
                                    <option value="">Choose your style...</option>
                                    <option value="adventure">🏔️ Adventure & Trekking</option>
                                    <option value="luxury">💎 Luxury & Relaxation</option>
                                    <option value="cultural">🏛️ Cultural & Historical</option>
                                    <option value="beach">🏖️ Beach & Resort</option>
                                    <option value="family">👨‍👩‍👧‍👦 Family Vacation</option>
                                    <option value="other">🎯 Other</option>
                                </select>
                                <div class="input-icon">✨</div>
                            </div>
                            <div class="form-group">
                                <label for="duration">Trip Duration <span class="required">*</span></label>
                                <input type="text" id="duration" name="duration" placeholder="e.g., 7 days, 2 weeks" required>
                                <div class="input-icon">📅</div>
                            </div>
                        </div>

                        <!-- ROW 4: Budget & Dates -->
                        <div class="form-row">
                            <div class="form-group">
                                <label for="budget">Budget Range (USD) <span class="required">*</span></label>
                                <input type="text" id="budget" name="budget" placeholder="e.g., $1,500 - $4,000" required>
                                <div class="input-icon">💰</div>
                            </div>
                            <div class="form-group">
                                <label for="travel_dates">Preferred Travel Dates <span class="required">*</span></label>
                                <input type="text" id="travel_dates" name="travel_dates" placeholder="e.g., June 15-25, 2024" required>
                                <div class="input-icon">🗓️</div>
                            </div>
                        </div>

                        <!-- ROW 5: Full Width Message -->
                        <div class="form-group full-width">
                            <label for="message">Tell Us Your Story <span class="required">*</span></label>
                            <textarea id="message" name="message" rows="5" placeholder="What makes your dream trip special? What activities excite you? Any special requests?" required></textarea>
                            <div class="char-count">0 / 500</div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="submit-btn">
                            <span class="btn-text">Send My Travel Request</span>
                            <span class="btn-icon">→</span>
                        </button>

                        <p class="form-footer">✓ We respect your privacy. Your information will never be shared with third parties.</p>
                    </form>
                </div>

                <!-- ===== INFO SECTION ===== -->
                <div class="info-card">
                    
                    <!-- Contact Details -->
                    <div class="info-section">
                        <h2>Get in Touch</h2>
                        <div class="contact-methods">
                            <div class="contact-method">
                                <div class="method-icon">📞</div>
                                <div class="method-content">
                                    <strong>Call Us</strong>
                                    <a href="tel:+212522000000">+212 5 22 00 00 00</a>
                                    <small>Mon-Sat: 9 AM - 7 PM</small>
                                </div>
                            </div>
                            <div class="contact-method">
                                <div class="method-icon">✉️</div>
                                <div class="method-content">
                                    <strong>Email Us</strong>
                                    <a href="mailto:contact@travagir.com">contact@travagir.com</a>
                                    <small>Response time: 24 hours</small>
                                </div>
                            </div>
                            <div class="contact-method">
                                <div class="method-icon">📍</div>
                                <div class="method-content">
                                    <strong>Visit Us</strong>
                                    <p>24 Avenue Voyage<br>Casablanca 20000, Morocco</p>
                                </div>
                            </div>
                            <div class="contact-method">
                                <div class="method-icon">⏰</div>
                                <div class="method-content">
                                    <strong>Business Hours</strong>
                                    <p>Mon-Fri: 9 AM - 7 PM<br>Sat: 10 AM - 5 PM<br>Sun: Closed</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Social Links -->
                    <div class="info-section">
                        <h3>Follow Our Adventures</h3>
                        <div class="social-links">
                            <a href="#" title="WhatsApp" class="social-link">💬</a>
                            <a href="#" title="Facebook" class="social-link">📘</a>
                            <a href="#" title="Instagram" class="social-link">📷</a>
                            <a href="#" title="Twitter" class="social-link">🐦</a>
                        </div>
                    </div>

                    <!-- Map -->
                    <div class="info-section">
                        <h3 style="margin-top: 0;">Find Us on Map</h3>
                        <div class="map-container">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3348.1092!2d-7.5889!3d33.5899!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xda7cdb0036a8437%3A0xc59ad864d34f9a03!2sCasablanca!5e0!3m2!1sen!2sma!4v0000000000000" width="100%" height="250" style="border: none; border-radius: 12px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <!-- ===== FAQ SECTION ===== -->
    <section class="faq-section">
        <div class="container">
            <div class="section-header">
                <h2>Frequently Asked Questions</h2>
                <p>Everything you need to know about planning with Travagir</p>
            </div>

            <div class="faq-grid">
                <div class="faq-card">
                    <div class="faq-question">How far in advance should I book?</div>
                    <div class="faq-answer">We recommend 2-3 months ahead for the best options and prices. However, we can accommodate shorter notice requests depending on your destination.</div>
                </div>

                <div class="faq-card">
                    <div class="faq-question">Are your itineraries customizable?</div>
                    <div class="faq-answer">Absolutely! Every itinerary is fully tailored to your preferences, interests, budget, and timeline. We create experiences that match YOUR vision.</div>
                </div>

                <div class="faq-card">
                    <div class="faq-question">What destinations do you cover?</div>
                    <div class="faq-answer">We specialize in Morocco and North Africa, with over 50 unique destinations including deserts, coastal regions, mountain trails, and cultural hotspots.</div>
                </div>

                <div class="faq-card">
                    <div class="faq-question">What payment methods do you accept?</div>
                    <div class="faq-answer">We accept credit cards, bank transfers, and PayPal. A deposit secures your booking with the balance due 30 days before departure.</div>
                </div>

                <div class="faq-card">
                    <div class="faq-question">Is travel insurance included?</div>
                    <div class="faq-answer">Travel insurance is not included but highly recommended. We can provide quotes and help you select the right coverage for your trip.</div>
                </div>

                <div class="faq-card">
                    <div class="faq-question">Do I need a visa for Morocco?</div>
                    <div class="faq-answer">Many nationalities enjoy visa-free entry to Morocco for up to 90 days. We'll provide guidance on all visa requirements and can assist with the process.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== CTA SECTION ===== -->
    <section class="cta-section">
        <div class="container cta-content">
            <h2>Ready to Transform Your Travel Dreams Into Reality?</h2>
            <p>Don't wait—our expert team is ready to craft your unforgettable adventure.</p>
            <button class="cta-button" onclick="document.querySelector('.form-card').scrollIntoView({behavior: 'smooth'})">
                Start Planning Now
            </button>
        </div>
    </section>

    <!-- ===== STYLES ===== -->
    <style>
        /* ========== ROOT VARIABLES ========== */
        :root {
            --primary-orange: #ff9900;
            --primary-orange-light: #febd69;
            --dark-bg: #111827;
            --card-bg: rgba(27, 38, 56, 0.9);
            --text-primary: #e5e7eb;
            --text-muted: #9ca3af;
            --border-color: rgba(68, 121, 207, 0.3);
            --transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        /* ========== HERO SECTION ========== */
        .contact-hero-section {
            position: relative;
            padding: 100px 20px;
            overflow: hidden;
            margin-bottom: 60px;
        }

        .hero-background {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(35, 47, 75, 0.9), rgba(19, 26, 34, 0.95)), 
                        url('https://images.unsplash.com/photo-1488646953014-85cb44e25828?auto=format&fit=crop&w=1200&q=80') center/cover;
            z-index: -1;
        }

        .hero-content {
            position: relative;
            text-align: center;
            max-width: 700px;
            margin: 0 auto;
        }

        .hero-badge {
            display: inline-block;
            background: rgba(255, 153, 0, 0.15);
            color: var(--primary-orange-light);
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            border: 1px solid rgba(255, 153, 0, 0.3);
            margin-bottom: 20px;
        }

        .hero-title {
            font-size: clamp(2rem, 5vw, 3.5rem);
            color: var(--primary-orange-light);
            margin: 20px 0;
            font-weight: 800;
        }

        .hero-subtitle {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.6;
        }

        /* ========== STATS SECTION ========== */
        .stats-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 80px;
        }

        .stat-item {
            background: linear-gradient(135deg, rgba(27, 38, 56, 0.8), rgba(35, 47, 75, 0.6));
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 30px 20px;
            text-align: center;
            transition: var(--transition);
        }

        .stat-item:hover {
            border-color: rgba(255, 153, 0, 0.5);
            background: rgba(27, 38, 56, 0.95);
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(255, 153, 0, 0.15);
        }

        .stat-icon {
            font-size: 3rem;
            margin-bottom: 12px;
            display: inline-block;
            transition: var(--transition);
        }

        .stat-item:hover .stat-icon {
            transform: scale(1.2) rotate(-5deg);
        }

        .stat-item h3 {
            color: var(--text-primary);
            margin: 10px 0 8px;
            font-size: 1.1rem;
        }

        .stat-item p {
            color: var(--text-muted);
            margin: 0;
            font-size: 0.9rem;
        }

        /* ========== CONTACT GRID ========== */
        .contact-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 40px;
            margin-bottom: 80px;
        }

        /* ========== FORM CARD ========== */
        .form-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
        }

        .form-header {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid rgba(255, 153, 0, 0.2);
        }

        .form-header h2 {
            color: var(--primary-orange-light);
            margin: 0 0 8px;
            font-size: 1.8rem;
        }

        .form-header p {
            color: var(--text-muted);
            margin: 0;
        }

        .premium-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .form-group {
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group label {
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .required {
            color: var(--primary-orange);
            margin-left: 3px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            background: rgba(15, 23, 34, 0.8);
            border: 1.5px solid var(--border-color);
            border-radius: 12px;
            padding: 12px 16px;
            color: var(--text-primary);
            font-size: 0.95rem;
            font-family: inherit;
            transition: var(--transition);
            padding-left: 40px;
        }

        .form-group input::placeholder,
        .form-group select::placeholder,
        .form-group textarea::placeholder {
            color: rgba(156, 163, 175, 0.7);
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary-orange);
            background: rgba(15, 23, 34, 0.95);
            box-shadow: 0 0 0 4px rgba(255, 153, 0, 0.2);
        }

        .input-icon {
            position: absolute;
            left: 12px;
            top: 38px;
            font-size: 1.1rem;
            pointer-events: none;
        }

        .form-group textarea {
            resize: vertical;
            padding-left: 40px;
        }

        .char-count {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 4px;
            text-align: right;
        }

        .submit-btn {
            background: linear-gradient(135deg, var(--primary-orange), #ff7700);
            color: #000;
            border: none;
            border-radius: 12px;
            padding: 16px 24px;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            margin-top: 10px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(255, 153, 0, 0.4);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

        .btn-icon {
            font-size: 1.2rem;
            transition: var(--transition);
        }

        .submit-btn:hover .btn-icon {
            transform: translateX(4px);
        }

        .form-footer {
            color: var(--text-muted);
            font-size: 0.85rem;
            text-align: center;
            margin: 0;
            margin-top: 12px;
        }

        /* ========== INFO CARD ========== */
        .info-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 40px;
            display: flex;
            flex-direction: column;
            gap: 40px;
            height: fit-content;
        }

        .info-section {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .info-section h2,
        .info-section h3 {
            color: var(--primary-orange-light);
            margin: 0;
            font-size: 1.4rem;
        }

        .info-section h3 {
            font-size: 1.1rem;
        }

        .contact-methods {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .contact-method {
            display: flex;
            gap: 16px;
            padding: 16px;
            background: rgba(15, 23, 34, 0.5);
            border-radius: 12px;
            transition: var(--transition);
        }

        .contact-method:hover {
            background: rgba(15, 23, 34, 0.8);
            border: 1px solid rgba(255, 153, 0, 0.3);
        }

        .method-icon {
            font-size: 1.8rem;
            display: flex;
            align-items: center;
        }

        .method-content {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .method-content strong {
            color: var(--text-primary);
            font-size: 0.95rem;
        }

        .method-content a,
        .method-content p {
            color: var(--text-muted);
            margin: 0;
            font-size: 0.9rem;
        }

        .method-content a {
            color: var(--primary-orange-light);
            text-decoration: none;
            transition: var(--transition);
        }

        .method-content a:hover {
            color: var(--primary-orange);
        }

        .method-content small {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .social-links {
            display: flex;
            gap: 12px;
        }

        .social-link {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 153, 0, 0.15);
            border: 1.5px solid rgba(255, 153, 0, 0.3);
            border-radius: 50%;
            font-size: 1.4rem;
            transition: var(--transition);
        }

        .social-link:hover {
            background: rgba(255, 153, 0, 0.3);
            border-color: var(--primary-orange);
            transform: scale(1.15) translateY(-3px);
        }

        .map-container {
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        /* ========== FAQ SECTION ========== */
        .faq-section {
            background: rgba(27, 38, 56, 0.4);
            padding: 80px 20px;
            margin-bottom: 60px;
        }

        .section-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .section-header h2 {
            color: var(--primary-orange-light);
            font-size: 2.2rem;
            margin: 0 0 12px;
        }

        .section-header p {
            color: var(--text-muted);
            margin: 0;
            font-size: 1.05rem;
        }

        .faq-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
        }

        .faq-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 28px;
            transition: var(--transition);
            cursor: pointer;
        }

        .faq-card:hover {
            border-color: rgba(255, 153, 0, 0.5);
            background: rgba(27, 38, 56, 0.95);
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(255, 153, 0, 0.1);
        }

        .faq-question {
            color: var(--primary-orange-light);
            font-weight: 700;
            font-size: 1.05rem;
            margin-bottom: 12px;
        }

        .faq-answer {
            color: var(--text-muted);
            line-height: 1.6;
            font-size: 0.95rem;
        }

        /* ========== CTA SECTION ========== */
        .cta-section {
            background: linear-gradient(135deg, rgba(35, 47, 75, 0.9), rgba(19, 26, 34, 0.95));
            padding: 80px 20px;
            text-align: center;
            position: relative;
        }

        .cta-content {
            max-width: 600px;
            margin: 0 auto;
        }

        .cta-section h2 {
            color: var(--primary-orange-light);
            font-size: 2.2rem;
            margin: 0 0 16px;
        }

        .cta-section p {
            color: var(--text-muted);
            margin: 0 0 28px;
            font-size: 1.05rem;
        }

        .cta-button {
            background: linear-gradient(135deg, var(--primary-orange), #ff7700);
            color: #000;
            border: none;
            border-radius: 12px;
            padding: 16px 40px;
            font-size: 1.05rem;
            font-weight: 800;
            cursor: pointer;
            transition: var(--transition);
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(255, 153, 0, 0.4);
        }

        /* ========== CONTACT MAIN ========== */
        .contact-main {
            padding: 0 20px 60px;
        }

        .container {
            width: min(1100px, 92%);
            margin: 0 auto;
        }

        /* ========== RESPONSIVE DESIGN ========== */
        @media (max-width: 1024px) {
            .contact-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }

            .info-card {
                padding: 30px;
            }

            .form-card {
                padding: 30px;
            }
        }

        @media (max-width: 768px) {
            .contact-hero-section {
                padding: 60px 20px;
                margin-bottom: 40px;
            }

            .hero-title {
                font-size: 2rem;
            }

            .hero-subtitle {
                font-size: 1rem;
            }

            .stats-section {
                gap: 16px;
                margin-bottom: 50px;
            }

            .stat-item {
                padding: 20px 16px;
            }

            .stat-icon {
                font-size: 2.2rem;
            }

            .form-row {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .form-card,
            .info-card {
                padding: 24px;
                border-radius: 16px;
            }

