{% extends 'base.html.twig' %}

{% block title %}Réservation {{ b.reference }} | Evec Tours{% endblock %}
{% block meta_description %}Confirmation de votre réservation {{ b.reference }} chez Evec Tours.{% endblock %}

{% block body %}
<div class="cf-page">
  <div class="cf-wrap">

    {% set st = b.status %}
    {% if st == 'CONFIRMED' %}
      {% set tone = 'ok' %}{% set icon = '✅' %}{% set head = 'Réservation confirmée !' %}
      {% set sub = 'Votre paiement a été reçu et votre chambre est réservée.' %}
    {% elseif st == 'PAY_FAIL' %}
      {% set tone = 'err' %}{% set icon = '❌' %}{% set head = 'Paiement non abouti' %}
      {% set sub = "Votre paiement n'a pas pu être confirmé. Aucune somme n'a été débitée." %}
    {% elseif st == 'PAID' or st == 'BOOKING_FAILED' %}
      {% set tone = 'warn' %}{% set icon = '⏳' %}{% set head = 'Paiement reçu — finalisation en cours' %}
      {% set sub = 'Nous avons bien reçu votre paiement. Notre équipe finalise votre réservation et vous confirme sous peu.' %}
    {% else %}
      {% set tone = 'warn' %}{% set icon = '⌛' %}{% set head = 'En attente de paiement' %}
      {% set sub = "Votre réservation est enregistrée mais le paiement n'est pas finalisé. Contactez-nous pour la confirmer." %}
    {% endif %}

    <div class="cf-hero cf-{{ tone }}">
      <div class="cf-icon">{{ icon }}</div>
      <h1>{{ head }}</h1>
      <p>{{ sub }}</p>
      <div class="cf-ref">Référence : <strong>{{ b.reference }}</strong>{% if b.hotelbedsReference %} · Hôtel : <strong>{{ b.hotelbedsReference }}</strong>{% endif %}</div>
    </div>

    <div class="cf-card">
      <div class="cf-hotel">
        <h2>{{ b.hotelName }}</h2>
        <span>{{ b.roomName }}{% if b.board %} · {{ b.board|capitalize }}{% endif %}</span>
      </div>
      <div class="cf-rows">
        <div class="cf-row"><span>Arrivée</span><strong>{{ b.checkIn ? b.checkIn|date('d/m/Y') : '—' }}</strong></div>
        <div class="cf-row"><span>Départ</span><strong>{{ b.checkOut ? b.checkOut|date('d/m/Y') : '—' }}</strong></div>
        <div class="cf-row"><span>Durée</span><strong>{{ b.nights }} nuit{{ b.nights > 1 ? 's' : '' }}</strong></div>
        <div class="cf-row"><span>Voyageurs</span><strong>{{ b.adults }} ad.{{ b.children > 0 ? ', ' ~ b.children ~ ' enf.' : '' }} · {{ b.rooms }} ch.</strong></div>
        <div class="cf-row"><span>Voyageur principal</span><strong>{{ b.holderName }} {{ b.holderSurname }}</strong></div>
        <div class="cf-row cf-row--total"><span>Montant</span><strong>{{ b.amountTnd|number_format(2) }} TND</strong></div>
      </div>
    </div>

    <div class="cf-actions">
      {% if st == 'PAY_FAIL' %}
        <a class="cf-btn cf-btn--primary" href="{{ path('hotel_detail', {code: b.hotelCode, checkIn: b.checkIn|date('Y-m-d'), checkOut: b.checkOut|date('Y-m-d'), adults: b.adults, children: b.children, rooms: b.rooms}) }}">Réessayer</a>
      {% endif %}
      {% if st == 'PAID' or st == 'BOOKING_FAILED' or st == 'PENDING_PAYMENT' %}
        <a class="cf-btn cf-btn--wa" href="https://wa.me/21698365730?text={{ ('Bonjour, ma réservation ' ~ b.reference ~ ' — ' ~ b.hotelName)|url_encode }}" target="_blank" rel="noopener">💬 Nous contacter</a>
      {% endif %}
      <a class="cf-btn" href="{{ path('travel_hotels') }}">Rechercher un autre hôtel</a>
      <a class="cf-btn" href="{{ path('travel_home') }}">Accueil</a>
    </div>

  </div>
</div>

<style>
:root{ --cf-blue:#0078D8; --cf-ink:#0f172a; --cf-mut:#64748b; --cf-line:#e4eaf1; --cf-bg:#f4f7fb; }
.cf-page{ background:var(--cf-bg); padding:32px 20px 70px; min-height:70vh; }
.cf-wrap{ max-width:620px; margin:0 auto; }
.cf-hero{ text-align:center; border-radius:18px; padding:32px 24px; margin-bottom:18px; }
.cf-hero.cf-ok{ background:linear-gradient(135deg,#16a34a,#0f9d58); color:#fff; }
.cf-hero.cf-err{ background:linear-gradient(135deg,#dc2626,#b91c1c); color:#fff; }
.cf-hero.cf-warn{ background:linear-gradient(135deg,#f0792b,#e0620f); color:#fff; }
.cf-icon{ font-size:2.6rem; }
.cf-hero h1{ margin:8px 0 6px; font-size:1.5rem; }
.cf-hero p{ margin:0 0 14px; opacity:.95; font-size:.98rem; }
.cf-ref{ background:rgba(255,255,255,.18); border-radius:10px; padding:10px 14px; display:inline-block; font-size:.9rem; }
.cf-card{ background:#fff; border:1px solid var(--cf-line); border-radius:16px; padding:22px; }
.cf-hotel{ border-bottom:1px solid var(--cf-line); padding-bottom:14px; margin-bottom:6px; }
.cf-hotel h2{ margin:0 0 3px; font-size:1.2rem; color:var(--cf-ink); }
.cf-hotel span{ color:var(--cf-mut); font-size:.9rem; }
.cf-row{ display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--cf-line); font-size:.92rem; }
.cf-row span{ color:var(--cf-mut); } .cf-row strong{ color:var(--cf-ink); }
.cf-row--total{ border-bottom:none; }
.cf-row--total strong{ font-size:1.2rem; color:var(--cf-blue); }
.cf-actions{ display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-top:20px; }
.cf-btn{ padding:12px 20px; border-radius:11px; text-decoration:none; font-weight:700; font-size:.9rem; background:#fff; border:1px solid var(--cf-line); color:var(--cf-ink); }
.cf-btn--primary{ background:var(--cf-blue); color:#fff; border-color:var(--cf-blue); }
.cf-btn--wa{ background:#25D366; color:#fff; border-color:#25D366; }
[data-theme="dark"] .cf-page{ background:#0b1220; }
[data-theme="dark"] .cf-card, [data-theme="dark"] .cf-btn{ background:#111a2b; border-color:#1e293b; color:#e6edf6; }
[data-theme="dark"] .cf-hotel h2, [data-theme="dark"] .cf-row strong{ color:#e6edf6; }
</style>
{% endblock %}
